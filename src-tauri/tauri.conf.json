{
    "productName": "PixelHand",
    "version": "1.0.0",
    "identifier": "com.kilazz.pixelhand",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist",
        "devUrl": "http://localhost:3000"
    },
    "app": {
        "withGlobalTauri": true,
        "security": {
            "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost;",
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "**"
                ]
            }
        },
        "windows": [
            {
                "title": "PixelHand",
                "width": 1200,
                "height": 800
            }
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
