// ui/app.slint

import {
    ListView,
    CheckBox,
    TextEdit,
    LineEdit,
    SpinBox,
    ComboBox,
    ScrollView,
    ProgressIndicator,
    Palette,
    Slider,
} from "std-widgets.slint";

// ---------------------------------------------------------
// CUSTOM UI COMPONENTS
// ---------------------------------------------------------

// Custom component for Dropdown/Context Menu items
component MenuItem {
    in property <string> text;
    in property <color> text-color: #dcddde;
    callback clicked;

    height: 24px;
    rect := Rectangle {
        background: transparent;
        border-radius: 3px;
        txt := Text {
            x: 8px;
            text: root.text;
            color: root.text-color;
            vertical-alignment: center;
            font-size: 12px;
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    states [
        hover when ta.has-hover: {
            rect.background: #4752c4; // Blurple
            txt.color: #ffffff;
        }
    ]
}

// QFormLayout emulation for perfectly aligned settings
component FormRow {
    in property <string> title;
    in property <length> label-width: 90px;

    HorizontalLayout {
        spacing: 6px;
        Text {
            text: root.title;
            width: root.label-width;
            vertical-alignment: center;
            font-size: 12px;
            color: #dcddde;
        }

        @children
    }
}

// Custom Interactive Thumbnail with Corner Zones (R / G / B / A)
component InteractiveThumbnail inherits TouchArea {
    in property <image> source;
    in property <string> path;
    in property <bool> show_corners: true;
    in property <image> checkerboard; // Checkerboard texture background
    callback corner_hovered(string, string); // path, channel

    // Holds current active quadrant to prevent redundant Rust calls
    out property <string> active_quadrant: "RGB";

    width: 32px;
    height: 32px;

    // Real-time mouse quadrant calculation for lightning-fast channel scanning
    pointer-event(evt) => {
        if evt.kind == PointerEventKind.move {
            let half_w = self.width / 2;
            let half_h = self.height / 2;
            if (self.mouse-x < half_w && self.mouse-y < half_h) {
                if (active_quadrant != "R") {
                    active_quadrant = "R";
                    corner_hovered(path, "R");
                }
            } else if (self.mouse-x >= half_w && self.mouse-y < half_h) {
                if (active_quadrant != "G") {
                    active_quadrant = "G";
                    corner_hovered(path, "G");
                }
            } else if (self.mouse-x < half_w && self.mouse-y >= half_h) {
                if (active_quadrant != "B") {
                    active_quadrant = "B";
                    corner_hovered(path, "B");
                }
            } else {
                if (active_quadrant != "A") {
                    active_quadrant = "A";
                    corner_hovered(path, "A");
                }
            }
        }
    }

    // Revert to original composite on mouse leave
    changed has-hover => {
        if (!self.has-hover) {
            active_quadrant = "RGB";
            corner_hovered(path, "RGB");
        }
    }

    rect := Rectangle {
        width: 100%;
        height: 100%;
        background: #111214;
        border-radius: 4px;
        clip: true;

        // Tiled Checkerboard Background
        Image {
            source: checkerboard;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        Image {
            source: source;
            width: 100%;
            height: 100%;
            image-fit: contain;
        }

        // Interactive Channel Hover Indicators (Highlighted dynamically based on active quadrant)
        if show_corners && root.has-hover: Rectangle {
            // Top Left (R - Red Channel)
            Rectangle {
                x: 2px;
                y: 2px;
                width: 12px;
                height: 12px;
                background: root.active_quadrant == "R" ? #f23f43 : #f23f43.darker(30%);
                border-radius: 2px;
                Text {
                    text: "R";
                    font-size: 8px;
                    font-weight: 700;
                    color: #ffffff;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                r_ta := TouchArea {
                    pointer-event(evt) => {
                        if evt.kind == PointerEventKind.move { corner_hovered(path, "R"); }
                    }
                }
            }
            // Top Right (G - Green Channel)
            Rectangle {
                x: parent.width - 14px;
                y: 2px;
                width: 12px;
                height: 12px;
                background: root.active_quadrant == "G" ? #23a55a : #23a55a.darker(30%);
                border-radius: 2px;
                Text {
                    text: "G";
                    font-size: 8px;
                    font-weight: 700;
                    color: #ffffff;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                g_ta := TouchArea {
                    pointer-event(evt) => {
                        if evt.kind == PointerEventKind.move { corner_hovered(path, "G"); }
                    }
                }
            }
            // Bottom Left (B - Blue Channel)
            Rectangle {
                x: 2px;
                y: parent.height - 14px;
                width: 12px;
                height: 12px;
                background: root.active_quadrant == "B" ? #5865f2 : #5865f2.darker(30%);
                border-radius: 2px;
                Text {
                    text: "B";
                    font-size: 8px;
                    font-weight: 700;
                    color: #ffffff;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                b_ta := TouchArea {
                    pointer-event(evt) => {
                        if evt.kind == PointerEventKind.move { corner_hovered(path, "B"); }
                    }
                }
            }
            // Bottom Right (A - Alpha Channel)
            Rectangle {
                x: parent.width - 14px;
                y: parent.height - 14px;
                width: 12px;
                height: 12px;
                background: root.active_quadrant == "A" ? #ffffff : #ffffff.darker(50%);
                border-radius: 2px;
                Text {
                    text: "A";
                    font-size: 8px;
                    font-weight: 700;
                    color: root.active_quadrant == "A" ? #000000 : #ffffff;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                a_ta := TouchArea {
                    pointer-event(evt) => {
                        if evt.kind == PointerEventKind.move { corner_hovered(path, "A"); }
                    }
                }
            }
        }
    }
}

// Custom interactive Tab control
component TabButton {
    in property <string> text;
    in property <bool> active;
    callback clicked;

    width: 100px;
    height: 26px;

    rect := Rectangle {
        background: active ? #2d2d30 : #1e1f22;
        border-color: active ? #3e3e42 : #1f2023;
        border-width: 1px;
        border-radius: 4px;

        animate background { duration: 100ms; }
        animate border-color { duration: 100ms; }

        txt := Text {
            text: root.text;
            color: active ? #ffffff : #858585;
            font-size: 13px;
            font-weight: active ? 600 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            animate color { duration: 100ms; }
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    states [
        hover when ta.has-hover && !active: {
            rect.background: #252526;
            rect.border-color: #3e3e42;
            txt.color: #cccccc;
        }
    ]
}

// Custom channel rendering activation buttons
component ChannelButton {
    in property <string> text;
    in property <color> active-color;
    in property <color> text-color: #ffffff;
    in property <bool> active;
    callback clicked;
    width: 26px;
    height: 26px;

    rect := Rectangle {
        background: active ? active-color : #1e1f22;
        border-color: active ? #ffffff : #1f2023;
        border-width: active ? 1.5px : 1px;
        border-radius: 4px;

        txt := Text {
            text: root.text;
            color: active ? root.text-color : #dcddde;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    TouchArea {
        clicked => { clicked(); }
    }
}

// Custom styled flat Button control
component CustomButton {
    in property <string> text;
    in property <bool> enabled: true;
    in property <color> primary-color: #5865f2; // Default brand blue
    callback clicked;

    height: 22px; // Compact height
    min-width: 75px;

    rect := Rectangle {
        background: !enabled ? #2f3136 : primary-color;
        border-radius: 3px;
        border-width: 1px;
        border-color: !enabled ? #1f2023 : primary-color;
        opacity: !enabled ? 0.5 : 1.0;

        animate background { duration: 100ms; }

        txt := Text {
            text: root.text;
            color: !enabled ? #7c808a : #ffffff;
            font-size: 11px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    states [
        hover when ta.has-hover && enabled: {
            rect.background: primary-color.brighter(12%);
        }
        active when ta.pressed && enabled: {
            rect.background: primary-color.darker(12%);
        }
    ]
}

// Single row of comparative specs layout
component SpecsRow {
    in property <string> name;
    in property <string> val1;
    in property <string> val2;
    height: 24px;
    HorizontalLayout {
        spacing: 8px;
        Text {
            text: name;
            width: 120px;
            color: #949ba4;
            font-size: 12px;
            vertical-alignment: center;
        }

        Text {
            text: val1;
            color: #dcddde;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }

        Text {
            text: val2;
            color: #dcddde;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
    }
}

// Section title widget
component SectionTitle {
    in property <string> text;
    height: 22px;
    VerticalLayout {
        Text {
            text: root.text;
            font-size: 12px;
            font-weight: 700;
            color: #949ba4;
        }

        Rectangle {
            height: 1px;
            background: #1f2023;
        }
    }
}

// Panel Section Box Layout container
component PanelSection {
    in property <string> title;
    VerticalLayout {
        spacing: 4px; // Compacted
        SectionTitle {
            text: root.title;
        }

        @children
    }
}

// Custom interactive Wipe comparative viewport (Responsive rendering)
component WipeViewport {
    in property <image> original;
    in property <image> duplicate;
    in property <float> wipe-val; // 0.0 to 1.0
    in property <image> checkerboard;

    viewport-root := Rectangle {
        background: #111214;
        clip: true;

        Image {
            source: checkerboard;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        Image {
            source: original;
            width: 100%;
            height: 100%;
            image-fit: contain;
        }

        Rectangle {
            clip: true;
            x: 0px;
            y: 0px;
            width: parent.width * wipe-val;
            height: parent.height;

            Image {
                source: duplicate;
                x: 0px;
                y: 0px;
                width: viewport-root.width;
                height: viewport-root.height;
                image-fit: contain;
            }
        }

        Rectangle {
            x: parent.width * wipe-val - 1px;
            y: 0px;
            width: 2px;
            height: parent.height;
            background: #f0b132;
        }
    }
}

export struct ResultsRow {
    is_header: bool,
    is_qc: bool,
    is_ai: bool,
    group_index: int,
    hash_or_issue: string,
    path: string,
    name: string,
    score_or_detail: string,
    size_str: string,
    meta_str: string,
    is_best: bool,
    is_checked: bool,
    thumbnail: image,
}

export struct SelectedFile {
    name: string,
    size_str: string,
    format: string,
    resolution: string,
    bit_depth: string,
    color_space: string,
    mipmaps: string,
    alpha: string,
    similarity: string,
    path: string,
}

export component AppWindow inherits Window {
    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    title: "PixelHand - AI Duplicate & Graphical QC Auditor";

    preferred-width: 1320px;
    preferred-height: 880px;
    min-width: 1000px;
    min-height: 700px;

    background: #1e1f22;

    // --- STATE PROPERTIES ---
    in-out property <int> active_tab: 0;

    in-out property <bool> tonemap_enabled: true;
    in-out property <int> tonemap_operator: 0;

    in-out property <string> dir_a: "";
    in-out property <string> dir_b: "";
    in-out property <string> query_text: "";
    in-out property <float> similarity_threshold: 90;
    in-out property <int> batch_size: 128;
    in-out property <bool> is_scanning: false;
    in-out property <float> progress: 0.0;
    in-out property <string> status_text: "System Ready. Drop images or write path.";

    // Active file format selections (Binds to CheckBoxes inside File Types pop-up) [3]
    in-out property <bool> ext_png: true;
    in-out property <bool> ext_tga: true;
    in-out property <bool> ext_dds: true;
    in-out property <bool> ext_bmp: true;
    in-out property <bool> ext_exr: true;
    in-out property <bool> ext_hdr: true;
    in-out property <bool> ext_tif: true;
    in-out property <bool> ext_webp: true;
    in-out property <bool> ext_gif: true;
    in-out property <bool> ext_psd: true;
    in-out property <bool> ext_jxl: true;
    in-out property <bool> ext_heic: true;
    in-out property <bool> ext_avif: true;

    // Visual Reports (Contact Sheets) Settings
    in-out property <bool> save_visuals: false;
    in-out property <int> visuals_columns: 6;
    in-out property <int> visuals_max_count: 100;
    in-out property <int> visuals_font_size: 14;
    in-out property <float> visuals_scale: 1.5;

    // Image Pre-processing Options
    in-out property <bool> prep_luminance: false;
    in-out property <bool> prep_channels: false;
    in-out property <bool> prep_r: true;
    in-out property <bool> prep_g: true;
    in-out property <bool> prep_b: true;
    in-out property <bool> prep_a: true;
    in-out property <string> prep_tags: "";
    in-out property <bool> prep_ignore_solid: true;

    // Viewport transform configurations
    in-out property <float> zoom_factor: 1.0;
    in-out property <length> pan_x: 0px;
    in-out property <length> pan_y: 0px;

    in-out property <string> excluded_folders: ".git, .svn, cache, temp";
    in-out property <bool> qc_match_by_stem: true;
    in-out property <bool> qc_hide_same_resolution: false;

    // Relative Quality Control parameters
    in-out property <bool> qc_check_bloat: true;
    in-out property <bool> qc_check_alpha: true;
    in-out property <bool> qc_check_colorspace: true;
    in-out property <bool> qc_check_compression: true;

    // Search precision and active model
    in-out property <int> search_precision: 1;
    in-out property <int> ai_model: 0;
    in-out property <string> custom_model_path: "";
    in-out property <int> custom_model_arch: 0;
    in-out property <int> custom_model_dim: 512;

    in-out property <[string]> skipped_files_list: [];
    in-out property <length> skipped_popup_x: 0px;
    in-out property <length> skipped_popup_y: 0px;

    // --- COLUMN & PREVIEW WIDTHS ---
    in-out property <length> col_file_w: 300px;
    in-out property <length> col_score_w: 70px;
    in-out property <length> col_path_w: 350px;
    in-out property <length> list_preview_size: 40px;

    // Draggable Splitters states (Compare Sidebar width is now resizable) [4]
    in-out property <length> duplicates_panel_height: 180px;
    in-out property <length> sidebar_width: 380px;
    in-out property <length> compare_sidebar_width: 440px;
    in-out property <length> grid_card_size: 135px;
    in-out property <image> checkerboard_pattern;

    in-out property <SelectedFile> original_meta: {
        name: "-",
        size_str: "-",
        format: "-",
        resolution: "-",
        bit_depth: "-",
        color_space: "-",
        mipmaps: "-",
        alpha: "-",
        similarity: "-",
        path: ""
    };
    in-out property <SelectedFile> duplicate_meta: {
        name: "-",
        size_str: "-",
        format: "-",
        resolution: "-",
        bit_depth: "-",
        color_space: "-",
        mipmaps: "-",
        alpha: "-",
        similarity: "-",
        path: ""
    };

    in-out property <image> image_original;
    in-out property <image> image_duplicate;
    in-out property <image> image_heatmap;

    in-out property <int> compare_mode: 0;
    in-out property <float> wipe_slider_val: 0.5;
    in-out property <float> bg_alpha: 1.0;

    in-out property <bool> active_r: false;
    in-out property <bool> active_g: false;
    in-out property <bool> active_b: false;
    in-out property <bool> active_a: false;

    in-out property <bool> qc_mode: false;
    in-out property <bool> qc_npot: true;
    in-out property <bool> qc_mipmaps: true;
    in-out property <bool> qc_block_align: true;
    in-out property <bool> qc_bit_depth: true;
    in-out property <bool> qc_solid_colors: true;
    in-out property <bool> qc_normals: true;
    in-out property <string> qc_normals_tags: "";

    in-out property <int> search_method: 0;
    in-out property <int> execution_provider: 0;

    in-out property <bool> results_grid_mode: false;
    in-out property <[ResultsRow]> selected_group_files: [];
    in-out property <[ResultsRow]> results: [];
    in-out property <[ResultsRow]> grid_results: [];

    in-out property <string> results_search_query: "";
    in-out property <float> results_min_similarity: 0.0;
    in-out property <int> results_sort_index: 0;

    in-out property <string> console_log: "Initializing ONNX Runtime Architecture...\nSystem ready.";

    in-out property <length> ext_popup_x: 0px;
    in-out property <length> ext_popup_y: 0px;

    // CONTEXT MENU PROPERTIES
    in-out property <length> menu_x: 0px;
    in-out property <length> menu_y: 0px;
    in-out property <string> context_hovered_path: "";

    // --- CALLBACKS ---
    callback select_folder_a();
    callback select_folder_b();
    callback run_scan();
    callback cancel_scan();
    callback open_file_in_viewer(string);
    callback trigger_action(string);
    callback row_clicked(int, bool, int, string);
    callback row_checkbox_toggled(int);
    callback channel_toggled();
    callback trigger_selection_rule(string);
    callback save_settings();
    callback tonemap_toggled();
    callback export_log(string);
    callback expand_all_groups();
    callback collapse_all_groups();
    callback results_filter_changed();
    callback results_sort_changed(int);
    callback clear_cache();
    callback clear_models();
    callback select_custom_model();
    callback auto_size_columns();

    // CONTEXT MENU CALLBACK
    callback context_menu_action(string, string); // (action, path)

    // HOVER CHANNELS CALLBACK
    callback thumbnail_channel_hovered(string, string); // (path, channel)

    // SELECT REFERENCE PHOTO CALLBACK [2]
    callback select_reference_image();

    // --- POPUPS ---
    ext_popup := PopupWindow {
        x: root.ext_popup_x;
        y: root.ext_popup_y;
        width: 480px; // Expanded width to fit 4 columns beautifully [3]
        height: 180px;
        close-policy: close-on-click;

        Rectangle {
            background: #2b2d31;
            border-color: #1f2023;
            border-width: 1px;
            border-radius: 4px;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;
                Text {
                    text: "File Formats Selector";
                    font-weight: 700;
                    color: #ffffff;
                }

                HorizontalLayout {
                    spacing: 12px;
                    VerticalLayout {
                        spacing: 4px;
                        CheckBox {
                            text: ".png / .jpg";
                            checked <=> root.ext_png;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".tga";
                            checked <=> root.ext_tga;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".dds";
                            checked <=> root.ext_dds;
                            toggled => { root.save_settings(); }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        CheckBox {
                            text: ".bmp";
                            checked <=> root.ext_bmp;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".exr";
                            checked <=> root.ext_exr;
                            toggled => { root.ext_exr; }
                        }

                        CheckBox {
                            text: ".hdr";
                            checked <=> root.ext_hdr;
                            toggled => { root.ext_hdr; }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        CheckBox {
                            text: ".tif / .tiff";
                            checked <=> root.ext_tif;
                            toggled => { root.ext_tif; }
                        }

                        CheckBox {
                            text: ".webp";
                            checked <=> root.ext_webp;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".gif";
                            checked <=> root.ext_gif;
                            toggled => { root.save_settings(); }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        CheckBox {
                            text: ".psd";
                            checked <=> root.ext_psd;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".jxl";
                            checked <=> root.ext_jxl;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".heic / .heif";
                            checked <=> root.ext_heic;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".avif";
                            checked <=> root.ext_avif;
                            toggled => { root.save_settings(); }
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                HorizontalLayout {
                    alignment: end;
                    CustomButton {
                        text: "Close";
                        clicked => { ext_popup.close(); }
                    }
                }
            }
        }
    }

    skipped_popup := PopupWindow {
        x: root.skipped_popup_x;
        y: root.skipped_popup_y;
        width: 450px;
        height: 300px;
        close-policy: close-on-click;

        Rectangle {
            background: #2b2d31;
            border-color: #f23f43;
            border-width: 1.5px;
            border-radius: 4px;

            VerticalLayout {
                padding: 12px;
                spacing: 8px;

                Text {
                    text: "Skipped / Corrupted Files List";
                    font-weight: 700;
                    color: #ffffff;
                    font-size: 13px;
                }

                Rectangle {
                    background: #111214;
                    border-radius: 4px;
                    vertical-stretch: 1;
                    clip: true;

                    ListView {
                        width: 100%;
                        height: 100%;
                        for file in root.skipped_files_list: Rectangle {
                            height: 26px;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                Text {
                                    text: file;
                                    color: #dcddde;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    alignment: end;
                    CustomButton {
                        text: "Dismiss";
                        clicked => { skipped_popup.close(); }
                    }
                }
            }
        }
    }

    // CONTEXT MENU POPUP (Right Click)
    context_popup := PopupWindow {
        x: root.menu_x;
        y: root.menu_y;
        width: 160px;
        close-policy: close-on-click;

        Rectangle {
            background: #2b2d31;
            border-color: #1f2023;
            border-width: 1px;
            border-radius: 4px;

            VerticalLayout {
                padding: 4px;
                spacing: 2px;
                MenuItem {
                    text: "Open File";
                    clicked => { root.context_menu_action("open", root.context_hovered_path); context_popup.close(); }
                }

                MenuItem {
                    text: "Show in Explorer";
                    clicked => { root.context_menu_action("explore", root.context_hovered_path); context_popup.close(); }
                }

                Rectangle {
                    height: 1px;
                    background: #1f2023;
                } // Divider
                MenuItem {
                    text: "Move to Trash";
                    text-color: #f23f43;
                    clicked => { root.context_menu_action("trash", root.context_hovered_path); context_popup.close(); }
                }
            }
        }
    }

    // MAIN ROOT WINDOW LAYOUT
    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        // Navigation Tab Bar Layout
        HorizontalLayout {
            spacing: 4px;
            height: 32px;
            TabButton {
                text: "Find";
                active: root.active_tab == 0;
                clicked => { root.active_tab = 0; }
            }

            TabButton {
                text: "Compare";
                active: root.active_tab == 1;
                clicked => { root.active_tab = 1; }
            }

            TabButton {
                text: "Log";
                active: root.active_tab == 2;
                clicked => { root.active_tab = 2; }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        // Tab Content switches root container
        Rectangle {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            background: #1e1f22;

            // ------------------ TAB 0: FIND (Results List/Grid & Sidebar) ------------------
            if root.active_tab == 0: HorizontalLayout {
                spacing: 0px;
                width: 100%;
                height: 100%;

                // 1. Sidebar Config Section
                Rectangle {
                    width: root.sidebar_width;
                    background: #2b2d31;
                    border-color: #1f2023;
                    border-width: 1px;
                    border-radius: 4px;

                    ScrollView {
                        VerticalLayout {
                            padding: 6px; // Compact padding
                            spacing: 8px; // Compact spacing

                            PanelSection {
                                title: "Scan Configuration";
                                VerticalLayout {
                                    spacing: 4px;

                                    FormRow {
                                        title: "Folder A:";
                                        HorizontalLayout {
                                            spacing: 4px;
                                            LineEdit {
                                                text <=> root.dir_a;
                                                height: 22px;
                                                placeholder-text: "Source folder...";
                                                horizontal-stretch: 1;
                                                edited => { root.save_settings(); }
                                            }

                                            CustomButton {
                                                text: "...";
                                                width: 26px;
                                                height: 22px;
                                                clicked => { root.select_folder_a(); }
                                            }
                                        }
                                    }

                                    if root.qc_mode: FormRow {
                                        title: "Folder B:";
                                        HorizontalLayout {
                                            spacing: 4px;
                                            LineEdit {
                                                text <=> root.dir_b;
                                                height: 22px;
                                                placeholder-text: "Comparison...";
                                                horizontal-stretch: 1;
                                                edited => { root.save_settings(); }
                                            }

                                            CustomButton {
                                                text: "...";
                                                width: 26px;
                                                height: 22px;
                                                clicked => { root.select_folder_b(); }
                                            }
                                        }
                                    }

                                    FormRow {
                                        title: "Exclude:";
                                        LineEdit {
                                            text <=> root.excluded_folders;
                                            placeholder-text: "e.g. .cache, previews, temp_files";
                                            height: 22px;
                                            edited => { root.save_settings(); }
                                        }
                                    }

                                    FormRow {
                                        title: "Query AI:";
                                        HorizontalLayout {
                                            spacing: 4px;
                                            LineEdit {
                                                text <=> root.query_text;
                                                placeholder-text: root.ai_model == 4 ? "Text query disabled for DINOv2-B..." : "Optional text or path...";
                                                enabled: root.ai_model != 4;
                                                height: 22px;
                                                edited => { root.save_settings(); }
                                            }

                                            CustomButton {
                                                text: "🖼️";
                                                width: 26px;
                                                height: 22px;
                                                enabled: root.ai_model != 4;
                                                clicked => { root.select_reference_image(); }
                                            }
                                        }
                                    }

                                    FormRow {
                                        title: "Similarity:";
                                        HorizontalLayout {
                                            spacing: 6px;
                                            Slider {
                                                value <=> root.similarity_threshold;
                                                minimum: 50;
                                                maximum: 100;
                                                height: 22px;
                                                changed(val) => { root.save_settings(); }
                                            }

                                            Text {
                                                text: Math.round(root.similarity_threshold) + "%";
                                                width: 36px;
                                                horizontal-alignment: right;
                                                vertical-alignment: center;
                                                font-size: 12px;
                                                color: #ffffff;
                                            }
                                        }
                                    }

                                    FormRow {
                                        title: "Batch Sz:";
                                        SpinBox {
                                            value <=> root.batch_size;
                                            minimum: 16;
                                            maximum: 1024;
                                            height: 22px;
                                            edited(val) => { root.save_settings(); }
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 6px;
                                        padding-top: 4px;
                                        CustomButton {
                                            text: "File Types";
                                            width: 80px;
                                            clicked => {
                                                root.ext_popup_x = self.absolute-position.x;
                                                root.ext_popup_y = self.absolute-position.y + self.height;
                                                ext_popup.show();
                                            }
                                        }

                                        CustomButton {
                                            text: "Clear Caches";
                                            width: 85px;
                                            clicked => { root.clear_cache(); }
                                        }

                                        CustomButton {
                                            text: "Clear Models";
                                            width: 85px;
                                            clicked => { root.clear_models(); }
                                        }

                                        Rectangle {
                                            horizontal-stretch: 1;
                                        }
                                    }

                                    CheckBox {
                                        text: "Save Visual Reports";
                                        checked <=> root.save_visuals;
                                        height: 20px;
                                        toggled => { root.save_settings(); }
                                    }

                                    if root.save_visuals: VerticalLayout {
                                        spacing: 4px;
                                        padding-left: 8px;
                                        HorizontalLayout {
                                            spacing: 6px;
                                            Text {
                                                text: "Cols:";
                                                vertical-alignment: center;
                                                font-size: 11px;
                                                color: #dcddde;
                                                width: 35px;
                                            }

                                            SpinBox {
                                                value <=> root.visuals_columns;
                                                minimum: 2;
                                                maximum: 12;
                                                height: 22px;
                                                width: 80px;
                                                edited(val) => { root.save_settings(); }
                                            }

                                            Text {
                                                text: "Max:";
                                                vertical-alignment: center;
                                                font-size: 11px;
                                                color: #dcddde;
                                                width: 35px;
                                            }

                                            SpinBox {
                                                value <=> root.visuals_max_count;
                                                minimum: 1;
                                                maximum: 1000;
                                                height: 22px;
                                                width: 90px;
                                                edited(val) => { root.save_settings(); }
                                            }

                                            Rectangle {
                                                horizontal-stretch: 1;
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: 6px;
                                            Text {
                                                text: "Font:";
                                                vertical-alignment: center;
                                                font-size: 11px;
                                                color: #dcddde;
                                                width: 35px;
                                            }

                                            SpinBox {
                                                value <=> root.visuals_font_size;
                                                minimum: 8;
                                                maximum: 36;
                                                height: 22px;
                                                width: 80px;
                                                edited(val) => { root.save_settings(); }
                                            }

                                            Text {
                                                text: "Scale:";
                                                vertical-alignment: center;
                                                font-size: 11px;
                                                color: #dcddde;
                                                width: 35px;
                                            }

                                            Slider {
                                                value <=> root.visuals_scale;
                                                minimum: 1.0;
                                                maximum: 3.0;
                                                height: 22px;
                                                width: 70px;
                                                changed(val) => { root.save_settings(); }
                                            }

                                            Text {
                                                text: (Math.round(root.visuals_scale * 10) / 10) + "x";
                                                width: 30px;
                                                horizontal-alignment: right;
                                                vertical-alignment: center;
                                                font-size: 11px;
                                                color: #ffffff;
                                            }
                                        }
                                    }

                                    CustomButton {
                                        text: root.is_scanning ? "Stop / Cancel Scan" : "Start Scan";
                                        primary-color: root.is_scanning ? #f23f43 : #23a55a;
                                        height: 26px;
                                        clicked => { if root.is_scanning { root.cancel_scan(); } else { root.run_scan(); } }
                                    }
                                }
                            }

                            PanelSection {
                                title: "Image Preparation Options";
                                VerticalLayout {
                                    spacing: 4px;
                                    CheckBox {
                                        text: "Compare by luminance only";
                                        checked <=> root.prep_luminance;
                                        height: 20px;
                                        toggled => { root.save_settings(); }
                                    }

                                    CheckBox {
                                        text: "Compare by specific channels";
                                        checked <=> root.prep_channels;
                                        height: 20px;
                                        toggled => { root.save_settings(); }
                                    }

                                    CheckBox {
                                        text: "Enable HDR Tonemapping";
                                        checked <=> root.tonemap_enabled;
                                        height: 20px;
                                        toggled => { root.tonemap_toggled(); }
                                    }

                                    if root.tonemap_enabled: ComboBox {
                                        model: ["ACES Filmic", "ICtCp Perceptual", "Khronos PBR Neutral"];
                                        current-index <=> root.tonemap_operator;
                                        height: 22px;
                                        selected(val) => { root.tonemap_toggled(); }
                                    }

                                    if root.prep_channels: VerticalLayout {
                                        spacing: 4px;
                                        padding-left: 12px;
                                        HorizontalLayout {
                                            spacing: 12px;
                                            CheckBox {
                                                text: "R";
                                                checked <=> root.prep_r;
                                                toggled => { root.save_settings(); }
                                            }

                                            CheckBox {
                                                text: "G";
                                                checked <=> root.prep_g;
                                                toggled => { root.save_settings(); }
                                            }

                                            CheckBox {
                                                text: "B";
                                                checked <=> root.prep_b;
                                                toggled => { root.save_settings(); }
                                            }

                                            CheckBox {
                                                text: "A";
                                                checked <=> root.prep_a;
                                                toggled => { root.save_settings(); }
                                            }

                                            Rectangle {
                                                horizontal-stretch: 1;
                                            }
                                        }

                                        FormRow {
                                            title: "Tags:";
                                            label-width: 40px;
                                            LineEdit {
                                                text <=> root.prep_tags;
                                                placeholder-text: "_mask, _ddn";
                                                height: 22px;
                                                edited => { root.save_settings(); }
                                            }
                                        }

                                        CheckBox {
                                            text: "Ignore solid channels";
                                            checked <=> root.prep_ignore_solid;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }
                                    }
                                }
                            }

                            PanelSection {
                                title: "Quality Control (QC) Options";
                                VerticalLayout {
                                    spacing: 4px;
                                    CheckBox {
                                        text: "Enable Technical QC Mode";
                                        checked <=> root.qc_mode;
                                        height: 20px;
                                        toggled => { root.save_settings(); }
                                    }

                                    if root.qc_mode: VerticalLayout {
                                        spacing: 2px;
                                        padding-left: 8px;
                                        CheckBox {
                                            text: "Match by stem";
                                            checked <=> root.qc_match_by_stem;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Hide same resolution";
                                            checked <=> root.qc_hide_same_resolution;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check NPOT (Power of 2)";
                                            checked <=> root.qc_npot;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Mip-Maps";
                                            checked <=> root.qc_mipmaps;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check BlockAlignment";
                                            checked <=> root.qc_block_align;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Bit Depth";
                                            checked <=> root.qc_bit_depth;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Solid Colors";
                                            checked <=> root.qc_solid_colors;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Validate Normal Maps";
                                            checked <=> root.qc_normals;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        if root.qc_normals: LineEdit {
                                            text <=> root.qc_normals_tags;
                                            placeholder-text: "Tags: _norm, _ddn";
                                            height: 22px;
                                            edited => { root.save_settings(); }
                                        }

                                        // Relative QC parameters
                                        CheckBox {
                                            text: "Check Size Bloat";
                                            checked <=> root.qc_check_bloat;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Alpha Mismatch";
                                            checked <=> root.qc_check_alpha;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Color Space";
                                            checked <=> root.qc_check_colorspace;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Compression Change";
                                            checked <=> root.qc_check_compression;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }
                                    }
                                }
                            }

                            PanelSection {
                                title: "Search Methods (Non-QC)";
                                ComboBox {
                                    model: [
                                        "Exact Match (xxHash)",
                                        "Simple Duplicates (dHash)",
                                        "AI Semantic/Visual Search"
                                    ];
                                    current-index <=> root.search_method;
                                    height: 22px;
                                    selected(val) => { root.save_settings(); }
                                }
                            }

                            if root.search_method == 2: PanelSection {
                                title: "AI Model";
                                ComboBox {
                                    model: [
                                        "Fastest (CLIP-B/32)",
                                        "Balanced (CLIP-L/14)",
                                        "Compact (SigLIP-B)",
                                        "High Quality (SigLIP-L)",
                                        "Visual Structure (DINOv2-B)",
                                        "Custom (Local ONNX)"
                                    ];
                                    current-index <=> root.ai_model;
                                    height: 22px;
                                    selected(val) => { root.save_settings(); }
                                }
                            }

                            if root.search_method == 2 && root.ai_model == 5: VerticalLayout {
                                spacing: 4px;
                                FormRow {
                                    title: "Local Path:";
                                    HorizontalLayout {
                                        spacing: 4px;
                                        LineEdit {
                                            text <=> root.custom_model_path;
                                            height: 22px;
                                            horizontal-stretch: 1;
                                            edited => { root.save_settings(); }
                                        }

                                        CustomButton {
                                            text: "...";
                                            width: 26px;
                                            height: 22px;
                                            clicked => { root.select_custom_model(); }
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "Arch:";
                                        vertical-alignment: center;
                                        font-size: 11px;
                                        color: #dcddde;
                                        width: 30px;
                                    }

                                    ComboBox {
                                        model: ["CLIP", "SigLIP", "DINOv2"];
                                        current-index <=> root.custom_model_arch;
                                        height: 22px;
                                        selected(val) => { root.save_settings(); }
                                    }

                                    Text {
                                        text: "Dim:";
                                        vertical-alignment: center;
                                        font-size: 11px;
                                        color: #dcddde;
                                        width: 30px;
                                    }

                                    SpinBox {
                                        value <=> root.custom_model_dim;
                                        minimum: 64;
                                        maximum: 4096;
                                        height: 22px;
                                        edited(val) => { root.save_settings(); }
                                    }
                                }
                            }

                            if root.search_method == 2: PanelSection {
                                title: "Search Precision (LanceDB)";
                                ComboBox {
                                    model: ["Fast", "Balanced", "Accurate", "Exhaustive"];
                                    current-index <=> root.search_precision;
                                    height: 22px;
                                    selected(val) => { root.save_settings(); }
                                }
                            }

                            PanelSection {
                                title: "Execution Provider";
                                ComboBox {
                                    model: ["CPU", "DirectML", "CUDA", "TensorRT", "CoreML"];
                                    current-index <=> root.execution_provider;
                                    height: 22px;
                                    selected(val) => { root.save_settings(); }
                                }
                            }

                            Rectangle {
                                vertical-stretch: 1;
                            }
                        }
                    }
                }

                // Tactile Horizontal Draggable Splitter
                Rectangle {
                    width: 8px;
                    background: sidebar-splitter-ta.has-hover ? #4e5058 : #1e1f22;

                    // Centered handle - no layouts needed, Slint automatically centers children of a Rectangle
                    Rectangle {
                        width: 2px;
                        height: 20px;
                        background: #6d6f78;
                        border-radius: 1px;
                    }

                    sidebar-splitter-ta := TouchArea {
                        mouse-cursor: MouseCursor.col-resize;
                        moved => {
                            if (self.pressed) {
                                root.sidebar_width = (self.x + self.mouse-x - self.pressed-x).clamp(320px, 600px);
                                root.save_settings();
                            }
                        }
                    }
                }

                // 2. Results List Pane & Quick Action Console Section
                VerticalLayout {
                    padding-left: 12px;
                    horizontal-stretch: 1;
                    spacing: 8px;

                    VerticalLayout {
                        spacing: 8px;
                        vertical-stretch: 1;

                        HorizontalLayout {
                            alignment: space-between;

                            // Left-side header with count, Search, and Sort
                            HorizontalLayout {
                                spacing: 12px;
                                Text {
                                    text: "Results (" + root.results.length + " items)";
                                    font-size: 14px;
                                    font-weight: 700;
                                    color: #ffffff;
                                    vertical-alignment: center;
                                }

                                LineEdit {
                                    text <=> root.results_search_query;
                                    placeholder-text: "Filter by name...";
                                    height: 24px;
                                    width: 130px;
                                    edited => { root.results_filter_changed(); }
                                }

                                ComboBox {
                                    model: ["By Duplicate Count", "By Size on Disk", "By Filename"];
                                    current-index <=> root.results_sort_index;
                                    height: 24px;
                                    width: 145px;
                                    selected(val) => { root.results_sort_changed(root.results_sort_index); }
                                }

                                if root.search_method == 2: HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "Min Sim:";
                                        vertical-alignment: center;
                                        font-size: 12px;
                                        color: #dcddde;
                                    }

                                    Slider {
                                        value <=> root.results_min_similarity;
                                        minimum: 0.0;
                                        maximum: 100.0;
                                        width: 80px;
                                        height: 24px;
                                        changed(val) => { root.results_filter_changed(); }
                                    }

                                    Text {
                                        text: Math.round(root.results_min_similarity) + "%";
                                        vertical-alignment: center;
                                        font-size: 12px;
                                        color: #ffffff;
                                        width: 35px;
                                    }
                                }

                                if !root.results_grid_mode && root.results.length > 0: HorizontalLayout {
                                    spacing: 6px;
                                    CustomButton {
                                        text: "Expand All";
                                        height: 24px;
                                        clicked => { root.expand_all_groups(); }
                                    }

                                    CustomButton {
                                        text: "Collapse All";
                                        height: 24px;
                                        clicked => { root.collapse_all_groups(); }
                                    }

                                    CustomButton {
                                        text: "Auto Cols";
                                        height: 24px;
                                        primary-color: #5865f2;
                                        clicked => { root.auto_size_columns(); }
                                    }

                                    CustomButton {
                                        text: "Reset Cols";
                                        height: 24px;
                                        primary-color: #4e5058;
                                        clicked => { root.col_file_w = 300px; root.col_score_w = 70px; root.col_path_w = 350px; }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;

                                // Single dynamic slider to resize previews in both Grid and List Mode [1]
                                if root.results.length > 0: HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: root.results_grid_mode ? "Card Size:" : "Row Size:";
                                        vertical-alignment: center;
                                        font-size: 12px;
                                        color: #dcddde;
                                    }

                                    Slider {
                                        value: root.results_grid_mode ? (root.grid_card_size / 1px) : (root.list_preview_size / 1px);
                                        minimum: root.results_grid_mode ? 100 : 32;
                                        maximum: root.results_grid_mode ? 250 : 120;
                                        width: 100px;
                                        height: 24px;
                                        changed(val) => {
                                            if (root.results_grid_mode) {
                                                root.grid_card_size = val * 1px;
                                            } else {
                                                root.list_preview_size = val * 1px;
                                            }
                                            root.save_settings();
                                        }
                                    }
                                }

                                if root.skipped_files_list.length > 0: CustomButton {
                                    text: "⚠️ Skipped Files (" + root.skipped_files_list.length + ")";
                                    primary-color: #f23f43; // warning red
                                    height: 24px;
                                    clicked => {
                                        root.skipped_popup_x = self.absolute-position.x - 120px;
                                        root.skipped_popup_y = self.absolute-position.y + self.height;
                                        skipped_popup.show();
                                    }
                                }

                                CustomButton {
                                    text: root.results_grid_mode ? "List Mode (☰)" : "Grid Mode (⊞)";
                                    height: 24px;
                                    clicked => { root.results_grid_mode = !root.results_grid_mode; }
                                }
                            }
                        }

                        Rectangle {
                            border-color: #1f2023;
                            border-width: 1px;
                            background: #2b2d31;
                            border-radius: 4px;
                            vertical-stretch: 1;
                            clip: true;

                            VerticalLayout {
                                // ---- COLUMN HEADERS (Table Headers) ----
                                if !root.results_grid_mode && root.results.length > 0: VerticalLayout {
                                    vertical-stretch: 0;
                                    Rectangle {
                                        height: 24px;
                                        background: #1e1f22;
                                        HorizontalLayout {
                                            padding-left: 28px;
                                            padding-right: 8px;
                                            spacing: 0px; // Removing spacing for manual width control

                                            Rectangle {
                                                width: 32px;
                                            } // Checkbox spacer

                                            // 1. FILE
                                            HorizontalLayout {
                                                width: root.col_file_w;
                                                Text {
                                                    text: "FILE";
                                                    color: #949ba4;
                                                    font-size: 11px;
                                                    font-weight: 700;
                                                    vertical-alignment: center;
                                                }
                                            }
                                            // Splitter FILE -> SCORE
                                            Rectangle {
                                                width: 8px;
                                                background: file_split.has-hover ? #4e5058 : transparent;
                                                file_split := TouchArea {
                                                    mouse-cursor: col-resize;
                                                    moved => { if (self.pressed) { root.col_file_w = (root.col_file_w + self.mouse-x - self.pressed-x).clamp(100px, 800px); } }
                                                }
                                            }

                                            // 2. SCORE
                                            HorizontalLayout {
                                                width: root.col_score_w;
                                                Text {
                                                    text: "SCORE";
                                                    color: #949ba4;
                                                    font-size: 11px;
                                                    font-weight: 700;
                                                    vertical-alignment: center;
                                                    horizontal-alignment: center;
                                                    width: 100%;
                                                }
                                            }
                                            // Splitter SCORE -> PATH
                                            Rectangle {
                                                width: 8px;
                                                background: score_split.has-hover ? #4e5058 : transparent;
                                                score_split := TouchArea {
                                                    mouse-cursor: col-resize;
                                                    moved => { if (self.pressed) { root.col_score_w = (root.col_score_w + self.mouse-x - self.pressed-x).clamp(50px, 200px); } }
                                                }
                                            }

                                            // 3. PATH
                                            HorizontalLayout {
                                                width: root.col_path_w;
                                                Text {
                                                    text: "PATH";
                                                    color: #949ba4;
                                                    font-size: 11px;
                                                    font-weight: 700;
                                                    vertical-alignment: center;
                                                }
                                            }
                                            // Splitter PATH -> METADATA
                                            Rectangle {
                                                width: 8px;
                                                background: path_split.has-hover ? #4e5058 : transparent;
                                                path_split := TouchArea {
                                                    mouse-cursor: col-resize;
                                                    moved => { if (self.pressed) { root.col_path_w = (root.col_path_w + self.mouse-x - self.pressed-x).clamp(100px, 1000px); } }
                                                }
                                            }

                                            // 4. METADATA
                                            HorizontalLayout {
                                                horizontal-stretch: 1;
                                                Text {
                                                    text: "METADATA";
                                                    color: #949ba4;
                                                    font-size: 11px;
                                                    font-weight: 700;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }

                                    Rectangle {
                                        height: 1px;
                                        background: #1f2023;
                                    } // Divider
                                }

                                // ---- LIST VIEW (Tree-like Indentation with Aligned Columns) ----
                                if !root.results_grid_mode && root.results.length > 0: ListView {
                                    for row[idx] in root.results: Rectangle {
                                        // Dynamic row height calculated based on row size slider [1]
                                        height: row.is_header ? 28px : (root.list_preview_size + 8px);
                                        background: row.is_header ? #1e1f22 : (row.is_best ? #2c3e50 : (main_row_ta.has-hover ? #393c41 : #2b2d31));
                                        border-color: #1f2023;
                                        border-width: 1px;

                                        // Outer Row Wrapper TouchArea (Click on the text background selects the item)
                                        main_row_ta := TouchArea {
                                            clicked => {
                                                root.row_clicked(idx, row.is_header, row.group_index, row.path);
                                                if (!row.is_header) { root.active_tab = 1; }
                                            }
                                            pointer-event(evt) => {
                                                if (evt.button == PointerEventButton.right && evt.kind == PointerEventKind.down) {
                                                    if (!row.is_header) {
                                                        root.context_hovered_path = row.path;
                                                        root.menu_x = self.absolute-position.x + self.mouse-x;
                                                        root.menu_y = self.absolute-position.y + self.mouse-y;
                                                        context_popup.show();
                                                    }
                                                }
                                            }

                                            // Header Row Layout
                                            if row.is_header: HorizontalLayout {
                                                padding-left: 8px;
                                                padding-right: 8px;
                                                spacing: 8px;
                                                alignment: space-between;

                                                Text {
                                                    text: (row.is_checked ? "▶ " : "▼ ") + "Group #" + (row.group_index + 1) + " (Hash: " + row.hash_or_issue + ")";
                                                    color: #949ba4;
                                                    font-size: 12px;
                                                    font-weight: 700;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                }

                                                Text {
                                                    text: row.size_str;
                                                    color: #949ba4;
                                                    font-size: 11px;
                                                    vertical-alignment: center;
                                                }
                                            }

                                            // Child Row Layout
                                            if !row.is_header: HorizontalLayout {
                                                padding-left: 28px; // Indentation for tree-view style
                                                padding-right: 8px;
                                                spacing: 0px;

                                                CheckBox {
                                                    checked: row.is_checked;
                                                    toggled => { root.row_checkbox_toggled(idx); }
                                                    width: 24px;
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                }

                                                // 1. FILE
                                                HorizontalLayout {
                                                    width: root.col_file_w;
                                                    spacing: 8px;
                                                    InteractiveThumbnail {
                                                        source: row.thumbnail;
                                                        path: row.path;
                                                        show_corners: true;
                                                        checkerboard: root.checkerboard_pattern;
                                                        width: root.list_preview_size; // Dynamic width based on row size slider [1]
                                                        height: root.list_preview_size; // Dynamic height based on row size slider [1]
                                                        corner_hovered(path, chan) => {
                                                            root.thumbnail_channel_hovered(path, chan);
                                                        }
                                                    }

                                                    Text {
                                                        text: row.name;
                                                        color: #dcddde;
                                                        font-size: 12px;
                                                        vertical-alignment: center;
                                                        overflow: elide;
                                                    }
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                } // Spacer aligned with splitter

                                                // 2. SCORE
                                                HorizontalLayout {
                                                    width: root.col_score_w;
                                                    Text {
                                                        text: row.is_best ? "[Best]" : row.score_or_detail;
                                                        color: row.is_best ? #f0b132 : #dcddde;
                                                        font-size: 12px;
                                                        vertical-alignment: center;
                                                        horizontal-alignment: center;
                                                        width: 100%;
                                                    }
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                } // Spacer aligned with splitter

                                                // 3. PATH
                                                HorizontalLayout {
                                                    width: root.col_path_w;
                                                    Text {
                                                        text: row.path;
                                                        color: #949ba4;
                                                        font-size: 11px;
                                                        vertical-alignment: center;
                                                        overflow: elide;
                                                    }
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                } // Spacer aligned with splitter

                                                // 4. METADATA
                                                HorizontalLayout {
                                                    horizontal-stretch: 1;
                                                    Text {
                                                        text: row.meta_str;
                                                        color: #949ba4;
                                                        font-size: 11px;
                                                        vertical-alignment: center;
                                                        overflow: elide;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }

                                // ---- GRID VIEW ----
                                if root.results_grid_mode && root.grid_results.length > 0: ScrollView {
                                    HorizontalLayout {
                                        spacing: 12px;
                                        padding: 10px;
                                        alignment: start;

                                        // Column 0
                                        VerticalLayout {
                                            width: root.grid_results.length > 0 ? root.grid_card_size : 0px;
                                            spacing: 12px;
                                            alignment: start;
                                            for row[idx] in root.grid_results: Rectangle {
                                                property <bool> show: idx.mod(4) == 0;
                                                width: show ? root.grid_card_size : 0px;
                                                height: show ? root.grid_card_size + 45px : 0px;
                                                visible: show;
                                                background: show ? #2b2d31 : transparent;
                                                border-color: show ? #1f2023 : transparent;
                                                border-width: show ? 1px : 0px;
                                                border-radius: 6px;

                                                if show: card_ta_0 := TouchArea {
                                                    width: 100%;
                                                    height: 100%;
                                                    clicked => { root.row_clicked(-1, false, row.group_index, row.path); root.active_tab = 1; }

                                                    VerticalLayout {
                                                        padding: 8px;
                                                        spacing: 6px;
                                                        InteractiveThumbnail {
                                                            source: row.thumbnail;
                                                            path: row.path;
                                                            show_corners: true;
                                                            checkerboard: root.checkerboard_pattern;
                                                            width: parent.width - 16px;
                                                            height: parent.height - 52px;
                                                            corner_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                                        }

                                                        Text {
                                                            text: "Group #" + (row.group_index + 1);
                                                            color: #ffffff;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            horizontal-alignment: center;
                                                            overflow: elide;
                                                        }

                                                        Text {
                                                            text: row.size_str;
                                                            color: #949ba4;
                                                            font-size: 10px;
                                                            horizontal-alignment: center;
                                                            overflow: elide;
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        // Column 1
                                        VerticalLayout {
                                            width: root.grid_results.length > 1 ? root.grid_card_size : 0px;
                                            spacing: 12px;
                                            alignment: start;
                                            for row[idx] in root.grid_results: Rectangle {
                                                property <bool> show: idx.mod(4) == 1;
                                                width: show ? root.grid_card_size : 0px;
                                                height: show ? root.grid_card_size + 45px : 0px;
                                                visible: show;
                                                background: show ? #2b2d31 : transparent;
                                                border-color: show ? #1f2023 : transparent;
                                                border-width: show ? 1px : 0px;
                                                border-radius: 6px;

                                                if show: card_ta_1 := TouchArea {
                                                    width: 100%;
                                                    height: 100%;
                                                    clicked => { root.row_clicked(-1, false, row.group_index, row.path); root.active_tab = 1; }

                                                    VerticalLayout {
                                                        padding: 8px;
                                                        spacing: 6px;
                                                        InteractiveThumbnail {
                                                            source: row.thumbnail;
                                                            path: row.path;
                                                            show_corners: true;
                                                            checkerboard: root.checkerboard_pattern;
                                                            width: parent.width - 16px;
                                                            height: parent.height - 52px;
                                                            corner_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                                        }

                                                        Text {
                                                            text: "Group #" + (row.group_index + 1);
                                                            color: #ffffff;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            horizontal-alignment: center;
                                                            overflow: elide;
                                                        }

                                                        Text {
                                                            text: row.size_str;
                                                            color: #949ba4;
                                                            font-size: 10px;
                                                            horizontal-alignment: center;
                                                            overflow: elide;
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        // Column 2
                                        VerticalLayout {
                                            width: root.grid_results.length > 2 ? root.grid_card_size : 0px;
                                            spacing: 12px;
                                            alignment: start;
                                            for row[idx] in root.grid_results: Rectangle {
                                                property <bool> show: idx.mod(4) == 2;
                                                width: show ? root.grid_card_size : 0px;
                                                height: show ? root.grid_card_size + 45px : 0px;
                                                visible: show;
                                                background: show ? #2b2d31 : transparent;
                                                border-color: show ? #1f2023 : transparent;
                                                border-width: show ? 1px : 0px;
                                                border-radius: 6px;

                                                if show: card_ta_2 := TouchArea {
                                                    width: 100%;
                                                    height: 100%;
                                                    clicked => { root.row_clicked(-1, false, row.group_index, row.path); root.active_tab = 1; }

                                                    VerticalLayout {
                                                        padding: 8px;
                                                        spacing: 6px;
                                                        InteractiveThumbnail {
                                                            source: row.thumbnail;
                                                            path: row.path;
                                                            show_corners: true;
                                                            checkerboard: root.checkerboard_pattern;
                                                            width: parent.width - 16px;
                                                            height: parent.height - 52px;
                                                            corner_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                                        }

                                                        Text {
                                                            text: "Group #" + (row.group_index + 1);
                                                            color: #ffffff;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            horizontal-alignment: center;
                                                            overflow: elide;
                                                        }

                                                        Text {
                                                            text: row.size_str;
                                                            color: #949ba4;
                                                            font-size: 10px;
                                                            horizontal-alignment: center;
                                                            overflow: elide;
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        // Column 3
                                        VerticalLayout {
                                            width: root.grid_results.length > 3 ? root.grid_card_size : 0px;
                                            spacing: 12px;
                                            alignment: start;
                                            for row[idx] in root.grid_results: Rectangle {
                                                property <bool> show: idx.mod(4) == 3;
                                                width: show ? root.grid_card_size : 0px;
                                                height: show ? root.grid_card_size + 45px : 0px;
                                                visible: show;
                                                background: show ? #2b2d31 : transparent;
                                                border-color: show ? #1f2023 : transparent;
                                                border-width: show ? 1px : 0px;
                                                border-radius: 6px;

                                                if show: card_ta_3 := TouchArea {
                                                    width: 100%;
                                                    height: 100%;
                                                    clicked => { root.row_clicked(-1, false, row.group_index, row.path); root.active_tab = 1; }

                                                    VerticalLayout {
                                                        padding: 8px;
                                                        spacing: 6px;
                                                        InteractiveThumbnail {
                                                            source: row.thumbnail;
                                                            path: row.path;
                                                            show_corners: true;
                                                            checkerboard: root.checkerboard_pattern;
                                                            width: parent.width - 16px;
                                                            height: parent.height - 52px;
                                                            corner_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                                        }

                                                        Text {
                                                            text: "Group #" + (row.group_index + 1);
                                                            color: #ffffff;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            horizontal-alignment: center;
                                                            overflow: elide;
                                                        }

                                                        Text {
                                                            text: row.size_str;
                                                            color: #949ba4;
                                                            font-size: 10px;
                                                            horizontal-alignment: center;
                                                            overflow: elide;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }

                                if root.results.length == 0: VerticalLayout {
                                    alignment: center;
                                    spacing: 12px;
                                    Text {
                                        text: "No duplicate assets loaded. Choose scan parameters in the left pane and begin auditing.";
                                        color: #7c808a;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }

                    // Selection tools section box
                    Rectangle {
                        background: #2b2d31;
                        border-color: #1f2023;
                        border-width: 1px;
                        border-radius: 4px;
                        height: 56px;
                        VerticalLayout {
                            padding: 8px;
                            spacing: 4px;
                            Text {
                                text: "Selection Rules";
                                font-size: 12px;
                                font-weight: 700;
                                color: #949ba4;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                CustomButton {
                                    text: "Select All";
                                    primary-color: #4e5058;
                                    width: 85px;
                                    clicked => { root.trigger_selection_rule("all"); }
                                }

                                CustomButton {
                                    text: "Deselect All";
                                    primary-color: #4e5058;
                                    width: 95px;
                                    clicked => { root.trigger_selection_rule("none"); }
                                }

                                CustomButton {
                                    text: "Select All Except Best";
                                    primary-color: #4e5058;
                                    width: 140px;
                                    clicked => { root.trigger_selection_rule("except_best"); }
                                }

                                CustomButton {
                                    text: "Invert Selection";
                                    primary-color: #4e5058;
                                    width: 110px;
                                    clicked => { root.trigger_selection_rule("invert"); }
                                }
                            }
                        }
                    }

                    // Link actions footer section
                    HorizontalLayout {
                        spacing: 8px;
                        height: 24px;
                        CustomButton {
                            text: "Replace with Hardlink";
                            primary-color: #5865f2;
                            width: 145px;
                            clicked => { root.trigger_action("hardlink"); }
                        }

                        CustomButton {
                            text: "Replace with Reflink";
                            primary-color: #5865f2;
                            width: 135px;
                            clicked => { root.trigger_action("reflink"); }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        CustomButton {
                            text: "Move to Trash";
                            primary-color: #f23f43;
                            width: 105px;
                            clicked => { root.trigger_action("trash"); }
                        }
                    }
                }
            } // End of Tab 0

            // ------------------ TAB 1: COMPARE (Large Side-by-Side Canvas) ------------------
            if root.active_tab == 1: HorizontalLayout {
                spacing: 0px; // Removing default spacing for beautiful splitter integration
                width: 100%;
                height: 100%;

                // Left panel (Interactive Compare Viewport)
                VerticalLayout {
                    horizontal-stretch: 1;
                    padding-right: 12px; // Restore spacing inside padding
                    spacing: 12px;

                    Text {
                        text: "Interactive Compare Viewport";
                        font-size: 15px;
                        font-weight: 700;
                        color: #ffffff;
                    }

                    // Canvas control bar
                    HorizontalLayout {
                        spacing: 8px;
                        height: 28px;
                        ComboBox {
                            model: ["Side-by-Side", "Wipe Mode", "Overlay Blend", "Difference Heatmap"];
                            current-index <=> root.compare_mode;
                            width: 160px;
                            height: 24px;
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "Wipe Shift:";
                                vertical-alignment: center;
                                font-size: 12px;
                                color: #dcddde;
                            }

                            Slider {
                                value <=> root.wipe_slider_val;
                                minimum: 0.0;
                                maximum: 1.0;
                                height: 24px;
                            }
                        }

                        CheckBox {
                            text: "HDR";
                            checked <=> root.tonemap_enabled;
                            height: 24px;
                            toggled => { root.tonemap_toggled(); }
                        }

                        if root.tonemap_enabled: ComboBox {
                            model: ["ACES Filmic", "ICtCp Perceptual", "Khronos PBR Neutral"];
                            current-index <=> root.tonemap_operator;
                            height: 24px;
                            width: 165px;
                            selected(val) => { root.tonemap_toggled(); }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        CustomButton {
                            text: "Reset Zoom";
                            height: 24px;
                            primary-color: #4e5058;
                            clicked => { root.zoom_factor = 1.0; root.pan_x = 0px; root.pan_y = 0px; }
                        }
                    }

                    // Double click to open, scroll to zoom, left click & drag to pan
                    viewport_root := Rectangle {
                        background: #111214;
                        clip: true;
                        vertical-stretch: 1;
                        horizontal-stretch: 1;

                        // Master Touch gesture intercept area sits on top
                        TouchArea {
                            property <length> start_x;
                            property <length> start_y;

                            pointer-event(evt) => {
                                if (evt.button == PointerEventButton.right && evt.kind == PointerEventKind.down) {
                                    root.zoom_factor = 1.0;
                                    root.pan_x = 0px;
                                    root.pan_y = 0px;
                                }
                                if (evt.button == PointerEventButton.left && evt.kind == PointerEventKind.down) {
                                    self.start_x = self.mouse-x;
                                    self.start_y = self.mouse-y;
                                }
                                if (evt.button == PointerEventButton.left && evt.kind == PointerEventKind.move) {
                                    if (self.pressed) {
                                        root.pan_x = root.pan_x + (self.mouse-x - self.start_x);
                                        root.pan_y = root.pan_y + (self.mouse-y - self.start_y);
                                        self.start_x = self.mouse-x;
                                        self.start_y = self.mouse-y;
                                    }
                                }
                            }

                            scroll-event(evt) => {
                                let zoom_delta = (evt.delta-y / 1px) / 120.0 * 0.15;
                                root.zoom_factor = (root.zoom_factor + zoom_delta).clamp(1.0, 10.0);
                                if (root.zoom_factor == 1.0) { root.pan_x = 0px; root.pan_y = 0px; }
                                EventResult.accept
                            }

                            double-clicked => {
                                if (self.mouse-x < parent.width / 2) { root.open_file_in_viewer(root.original_meta.path); }
                                else { root.open_file_in_viewer(root.duplicate_meta.path); }
                            }
                        }

                        // Mode 1: Side-by-Side Viewport
                        if root.compare_mode == 0: Rectangle {
                            width: 100%;
                            height: 100%;
                            Rectangle {
                                x: 0px;
                                y: 0px;
                                width: parent.width / 2 - 6px;
                                height: parent.height;
                                clip: true;
                                Rectangle {
                                    width: parent.width;
                                    height: parent.height;
                                    background: #111214;
                                    border-color: #3e3e42;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    clip: true;
                                    Image {
                                        source: root.checkerboard_pattern;
                                        horizontal-tiling: repeat;
                                        vertical-tiling: repeat;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    Image {
                                        source: root.image_original;
                                        image-fit: contain;
                                        width: parent.width * root.zoom_factor;
                                        height: parent.height * root.zoom_factor;
                                        x: parent.width / 2 - self.width / 2 + root.pan_x;
                                        y: parent.height / 2 - self.height / 2 + root.pan_y;
                                    }
                                }
                            }

                            Rectangle {
                                x: parent.width / 2 + 6px;
                                y: 0px;
                                width: parent.width / 2 - 6px;
                                height: parent.height;
                                clip: true;
                                Rectangle {
                                    width: parent.width;
                                    height: parent.height;
                                    background: #111214;
                                    border-color: #3e3e42;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    clip: true;
                                    Image {
                                        source: root.checkerboard_pattern;
                                        horizontal-tiling: repeat;
                                        vertical-tiling: repeat;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    Image {
                                        source: root.image_duplicate;
                                        image-fit: contain;
                                        width: parent.width * root.zoom_factor;
                                        height: parent.height * root.zoom_factor;
                                        x: parent.width / 2 - self.width / 2 + root.pan_x;
                                        y: parent.height / 2 - self.height / 2 + root.pan_y;
                                    }
                                }
                            }
                        }

                        // Mode 2: Wipe slider
                        if root.compare_mode == 1: WipeViewport {
                            original: root.image_original;
                            duplicate: root.image_duplicate;
                            checkerboard: root.checkerboard_pattern;
                            wipe-val: root.wipe_slider_val;
                            width: parent.width * root.zoom_factor;
                            height: parent.height * root.zoom_factor;
                            x: parent.width / 2 - self.width / 2 + root.pan_x;
                            y: parent.height / 2 - self.height / 2 + root.pan_y;
                        }

                        // Mode 3: Transparency overlay blend
                        if root.compare_mode == 2: Rectangle {
                            width: 100%;
                            height: 100%;
                            clip: true;
                            Image {
                                source: root.checkerboard_pattern;
                                horizontal-tiling: repeat;
                                vertical-tiling: repeat;
                                width: 100%;
                                height: 100%;
                            }

                            Image {
                                source: root.image_original;
                                image-fit: contain;
                                width: parent.width * root.zoom_factor;
                                height: parent.height * root.zoom_factor;
                                x: parent.width / 2 - self.width / 2 + root.pan_x;
                                y: parent.height / 2 - self.height / 2 + root.pan_y;
                            }

                            Image {
                                source: root.image_duplicate;
                                image-fit: contain;
                                opacity: root.wipe_slider_val;
                                width: parent.width * root.zoom_factor;
                                height: parent.height * root.zoom_factor;
                                x: parent.width / 2 - self.width / 2 + root.pan_x;
                                y: parent.height / 2 - self.height / 2 + root.pan_y;
                            }
                        }

                        // Mode 4: Generated difference heatmap view
                        if root.compare_mode == 3: Rectangle {
                            width: 100%;
                            height: 100%;
                            clip: true;
                            Image {
                                source: root.checkerboard_pattern;
                                horizontal-tiling: repeat;
                                vertical-tiling: repeat;
                                width: 100%;
                                height: 100%;
                            }

                            Image {
                                source: root.image_heatmap;
                                image-fit: contain;
                                width: parent.width * root.zoom_factor;
                                height: parent.height * root.zoom_factor;
                                x: parent.width / 2 - self.width / 2 + root.pan_x;
                                y: parent.height / 2 - self.height / 2 + root.pan_y;
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        height: 28px;
                        alignment: center;
                        ChannelButton {
                            text: "R";
                            active-color: #f23f43;
                            active <=> root.active_r;
                            clicked => { root.active_r = !root.active_r; if root.active_r { root.active_g = false; root.active_b = false; root.active_a = false; } root.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "G";
                            active-color: #23a55a;
                            active <=> root.active_g;
                            clicked => { root.active_g = !root.active_g; if root.active_g { root.active_r = false; root.active_b = false; root.active_a = false; } root.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "B";
                            active-color: #5865f2;
                            active <=> root.active_b;
                            clicked => { root.active_b = !root.active_b; if root.active_b { root.active_r = false; root.active_g = false; root.active_a = false; } root.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "A";
                            active-color: #ffffff;
                            text-color: #000000;
                            active <=> root.active_a;
                            clicked => { root.active_a = !root.active_a; if root.active_a { root.active_r = false; root.active_g = false; root.active_b = false; } root.channel_toggled(); }
                        }
                    }
                }

                // Tactile Vertical Splitter for Compare Tab! [4]
                Rectangle {
                    width: 8px;
                    background: compare-splitter-ta.has-hover ? #4e5058 : #1e1f22;

                    // Centered handle line
                    Rectangle {
                        width: 2px;
                        height: 20px;
                        background: #6d6f78;
                        border-radius: 1px;
                    }

                    compare-splitter-ta := TouchArea {
                        mouse-cursor: col-resize;
                        moved => {
                            if (self.pressed) {
                                // Dynamically resize compare sidebar width by dragging!
                                root.compare_sidebar_width = (root.compare_sidebar_width + self.pressed-x - self.mouse-x).clamp(380px, 800px);
                                root.save_settings();
                            }
                        }
                    }
                }

                // Specifications tables & Group Details (Right Panel)
                VerticalLayout {
                    width: root.compare_sidebar_width; // DYNAMIC SIDEBAR WIDTH! [4]
                    padding-left: 12px; // Restore spacing inside padding
                    spacing: 12px;

                    Text {
                        text: "Group Duplicates (" + root.selected_group_files.length + " items)";
                        font-size: 13px;
                        font-weight: 700;
                        color: #949ba4;
                    }

                    Rectangle {
                        height: root.duplicates_panel_height;
                        background: #111214;
                        border-color: #1f2023;
                        border-width: 1px;
                        border-radius: 4px;
                        if root.selected_group_files.length > 0: ListView {
                            for row[idx] in root.selected_group_files: Rectangle {
                                height: 38px;
                                background: (row.path == root.duplicate_meta.path) ? #2c3e50 : (right-row-ta.has-hover ? #393c41 : #111214);
                                border-radius: 4px;
                                right-row-ta := TouchArea {
                                    clicked => { root.row_clicked(idx, false, row.group_index, row.path); }

                                    HorizontalLayout {
                                        padding-left: 6px;
                                        padding-right: 6px;
                                        spacing: 8px;
                                        alignment: space-between;
                                        InteractiveThumbnail {
                                            source: row.thumbnail;
                                            path: row.path;
                                            show_corners: true;
                                            checkerboard: root.checkerboard_pattern;
                                            width: 32px;
                                            height: 32px;
                                            corner_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                        }

                                        Text {
                                            text: row.name;
                                            color: #dcddde;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }

                                        Text {
                                            text: row.is_best ? "[Best]" : row.score_or_detail;
                                            color: row.is_best ? #f0b132 : #dcddde;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                        if root.selected_group_files.length == 0: VerticalLayout {
                            alignment: center;
                            Text {
                                text: "No duplicates selected.";
                                color: #7c808a;
                                horizontal-alignment: center;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // Tactile Horizontal Splitter
                    Rectangle {
                        height: 8px;
                        background: splitter-ta.has-hover ? #4e5058 : #2b2d31;
                        border-radius: 4px;

                        // Perfectly centered handle [4]
                        Rectangle {
                            width: 20px;
                            height: 2px;
                            background: #6d6f78;
                            border-radius: 1px;
                        }

                        splitter-ta := TouchArea {
                            mouse-cursor: MouseCursor.row-resize;
                            moved => { if (self.pressed) { root.duplicates_panel_height = (self.y + self.mouse-y - self.pressed-y).clamp(80px, 450px); } }
                        }
                    }

                    Text {
                        text: "Comparison Specifications Matrix";
                        font-size: 13px;
                        font-weight: 700;
                        color: #949ba4;
                    }

                    Rectangle {
                        border-color: #1f2023;
                        border-width: 1px;
                        background: #111214;
                        border-radius: 4px;
                        vertical-stretch: 1;
                        ScrollView {
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                HorizontalLayout {
                                    Text {
                                        text: "Specification";
                                        width: 120px;
                                        font-weight: 700;
                                        color: #949ba4;
                                        font-size: 12px;
                                    }

                                    Text {
                                        text: "Original [Best]";
                                        font-weight: 700;
                                        color: #f0b132;
                                        font-size: 12px;
                                    }

                                    Text {
                                        text: "Duplicate";
                                        font-weight: 700;
                                        color: #dcddde;
                                        font-size: 12px;
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: #1f2023;
                                    vertical-stretch: 0;
                                }

                                SpecsRow {
                                    name: "File Name";
                                    val1: root.original_meta.name;
                                    val2: root.duplicate_meta.name;
                                }

                                SpecsRow {
                                    name: "File Size";
                                    val1: root.original_meta.size_str;
                                    val2: root.duplicate_meta.size_str;
                                }

                                SpecsRow {
                                    name: "Format / Codec";
                                    val1: root.original_meta.format;
                                    val2: root.duplicate_meta.format;
                                }

                                SpecsRow {
                                    name: "Resolution";
                                    val1: root.original_meta.resolution;
                                    val2: root.duplicate_meta.resolution;
                                }

                                SpecsRow {
                                    name: "Bit Depth";
                                    val1: root.original_meta.bit_depth;
                                    val2: root.duplicate_meta.bit_depth;
                                }

                                SpecsRow {
                                    name: "Color Space";
                                    val1: root.original_meta.color_space;
                                    val2: root.duplicate_meta.color_space;
                                }

                                SpecsRow {
                                    name: "Mipmaps";
                                    val1: root.original_meta.mipmaps;
                                    val2: root.duplicate_meta.mipmaps;
                                }

                                SpecsRow {
                                    name: "Alpha Channel";
                                    val1: root.original_meta.alpha;
                                    val2: root.duplicate_meta.alpha;
                                }

                                SpecsRow {
                                    name: "Similarity";
                                    val1: "100.0%";
                                    val2: root.duplicate_meta.similarity;
                                }

                                Rectangle {
                                    height: 1px;
                                    background: #1f2023;
                                    vertical-stretch: 0;
                                }

                                SpecsRow {
                                    name: "Full Path";
                                    val1: root.original_meta.path;
                                    val2: root.duplicate_meta.path;
                                }

                                Rectangle {
                                    vertical-stretch: 1;
                                }
                            }
                        }
                    }
                }
            } // End of Tab 1

            // ------------------ TAB 2: LOG (Console Output) ------------------
            if root.active_tab == 2: VerticalLayout {
                padding: 15px;
                spacing: 10px;
                width: 100%;
                height: 100%;
                Text {
                    text: "System Console Logs & Compiler Diagnostics";
                    font-weight: 700;
                    font-size: 14px;
                    color: #ffffff;
                }

                TextEdit {
                    text <=> root.console_log;
                    read-only: true;
                    font-family: "Consolas";
                    font-size: 12px;
                    vertical-stretch: 1;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    CustomButton {
                        text: "Export Log Output...";
                        width: 140px;
                        primary-color: #0e639c;
                        clicked => { root.export_log(root.console_log); }
                    }

                    CustomButton {
                        text: "Clear Console Buffer";
                        width: 140px;
                        primary-color: #3a3a3a;
                        clicked => { root.console_log = "Buffer cleared."; }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }
                }
            } // End of Tab 2
        }

        // Progress Overlay Container (Pinned to bottom if scanning)
        if root.is_scanning: Rectangle {
            background: #2b2d31;
            border-radius: 4px;
            border-color: #1f2023;
            border-width: 1px;
            height: 48px;
            HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text {
                    text: root.status_text;
                    color: #dcddde;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 250px;
                    overflow: elide;
                }

                ProgressIndicator {
                    progress: root.progress;
                    horizontal-stretch: 1;
                    height: 16px;
                }

                Text {
                    text: Math.round(root.progress * 100) + "%";
                    color: #ffffff;
                    font-weight: 700;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 40px;
                }
            }
        }
    }
}
