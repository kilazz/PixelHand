import {
    ListView,
    CheckBox,
    TextEdit,
    LineEdit,
    SpinBox,
    ComboBox,
    ScrollView,
    ProgressIndicator,
    Palette,
    Slider,
} from "std-widgets.slint";

// Custom Interactive Thumbnail with Corner Zones (R / G / B / A)
component InteractiveThumbnail {
    in property <image> source;
    in property <string> path;
    in property <bool> show_corners: false;
    in property <image> checkerboard; // Checkerboard texture background
    callback corner_clicked(string, string); // path, channel

    width: 32px;
    height: 32px;

    rect := Rectangle {
        background: #111214;
        border-radius: 4px;
        clip: true;

        // Tiled Checkerboard Background
        Image {
            source: checkerboard;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        Image {
            source: source;
            width: 100%;
            height: 100%;
            image-fit: contain;
        }

        if show_corners: Rectangle {
            // Top Left (R)
            TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width * 0.45;
                height: parent.height * 0.45;
                clicked => { corner_clicked(path, "R"); }
            }
            // Top Right (G)
            TouchArea {
                x: parent.width * 0.55;
                y: 0px;
                width: parent.width * 0.45;
                height: parent.height * 0.45;
                clicked => { corner_clicked(path, "G"); }
            }
            // Bottom Left (B)
            TouchArea {
                x: 0px;
                y: parent.height * 0.55;
                width: parent.width * 0.45;
                height: parent.height * 0.45;
                clicked => { corner_clicked(path, "B"); }
            }
            // Bottom Right (A)
            TouchArea {
                x: parent.width * 0.55;
                y: parent.height * 0.55;
                width: parent.width * 0.45;
                height: parent.height * 0.45;
                clicked => { corner_clicked(path, "A"); }
            }
        }
    }
}

// Custom interactive Tab control
component TabButton {
    in property <string> text;
    in property <bool> active;
    callback clicked;

    width: 100px;
    height: 26px;

    rect := Rectangle {
        background: active ? #2d2d30 : #1e1f22;
        border-color: active ? #3e3e42 : #1f2023;
        border-width: 1px;
        border-radius: 4px;

        animate background { duration: 100ms; }
        animate border-color { duration: 100ms; }

        txt := Text {
            text: root.text;
            color: active ? #ffffff : #858585;
            font-size: 13px;
            font-weight: active ? 600 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            animate color { duration: 100ms; }
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    states [
        hover when ta.has-hover && !active: {
            rect.background: #252526;
            rect.border-color: #3e3e42;
            txt.color: #cccccc;
        }
    ]
}

// Custom channel rendering activation buttons
component ChannelButton {
    in property <string> text;
    in property <color> active-color;
    in property <color> text-color: #ffffff;
    in property <bool> active;
    callback clicked;
    width: 26px;
    height: 26px;

    rect := Rectangle {
        background: active ? active-color : #1e1f22;
        border-color: active ? #ffffff : #1f2023;
        border-width: active ? 1.5px : 1px;
        border-radius: 4px;

        txt := Text {
            text: root.text;
            color: active ? root.text-color : #dcddde;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    TouchArea {
        clicked => { clicked(); }
    }
}

// Custom styled flat Button control
component CustomButton {
    in property <string> text;
    in property <bool> enabled: true;
    in property <color> primary-color: #5865f2; // Default brand blue
    callback clicked;

    height: 24px;
    min-width: 75px;

    rect := Rectangle {
        background: !enabled ? #2f3136 : primary-color;
        border-radius: 3px;
        border-width: 1px;
        border-color: !enabled ? #1f2023 : primary-color;
        opacity: !enabled ? 0.5 : 1.0;

        animate background { duration: 100ms; }

        txt := Text {
            text: root.text;
            color: !enabled ? #7c808a : #ffffff;
            font-size: 11px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    states [
        hover when ta.has-hover && enabled: {
            rect.background: primary-color.brighter(12%);
        }
        active when ta.pressed && enabled: {
            rect.background: primary-color.darker(12%);
        }
    ]
}

// Single row of comparative specs layout
component SpecsRow {
    in property <string> name;
    in property <string> val1;
    in property <string> val2;
    height: 24px;
    HorizontalLayout {
        spacing: 8px;
        Text {
            text: name;
            width: 120px;
            color: #949ba4;
            font-size: 12px;
            vertical-alignment: center;
        }

        Text {
            text: val1;
            color: #dcddde;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }

        Text {
            text: val2;
            color: #dcddde;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
    }
}

// Section title widget
component SectionTitle {
    in property <string> text;
    height: 22px;
    VerticalLayout {
        Text {
            text: root.text;
            font-size: 12px;
            font-weight: 700;
            color: #949ba4;
        }

        Rectangle {
            height: 1px;
            background: #1f2023;
        }
    }
}

// Panel Section Box Layout container
component PanelSection {
    in property <string> title;
    VerticalLayout {
        spacing: 6px;
        SectionTitle {
            text: root.title;
        }

        @children
    }
}

// Custom interactive Wipe comparative viewport (Responsive rendering)
component WipeViewport {
    in property <image> original;
    in property <image> duplicate;
    in property <float> wipe-val; // 0.0 to 1.0
    in property <image> checkerboard;

    viewport-root := Rectangle {
        background: #111214;
        clip: true;

        Image {
            source: checkerboard;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        Image {
            source: original;
            width: 100%;
            height: 100%;
            image-fit: contain;
        }

        Rectangle {
            clip: true;
            x: 0px;
            y: 0px;
            width: parent.width * wipe-val;
            height: parent.height;

            Image {
                source: duplicate;
                x: 0px;
                y: 0px;
                width: viewport-root.width;
                height: viewport-root.height;
                image-fit: contain;
            }
        }

        Rectangle {
            x: parent.width * wipe-val - 1px;
            y: 0px;
            width: 2px;
            height: parent.height;
            background: #f0b132;
        }
    }
}

export struct ResultsRow {
    is_header: bool,
    is_qc: bool,
    is_ai: bool,
    group_index: int,
    hash_or_issue: string,
    path: string,
    name: string,
    score_or_detail: string,
    size_str: string,
    meta_str: string,
    is_best: bool,
    is_checked: bool,
    thumbnail: image,
}

export struct SelectedFile {
    name: string,
    size_str: string,
    format: string,
    resolution: string,
    bit_depth: string,
    color_space: string,
    mipmaps: string,
    alpha: string,
    similarity: string,
    path: string,
}

export component AppWindow inherits Window {
    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    title: "PixelHand - AI Duplicate & Graphical QC Auditor";

    preferred-width: 1320px;
    preferred-height: 880px;
    min-width: 1000px;
    min-height: 700px;

    background: #1e1f22;

    in-out property <int> active_tab: 0;

    in-out property <string> dir_a: "";
    in-out property <string> dir_b: "";
    in-out property <string> query_text: "";
    in-out property <float> similarity_threshold: 90;
    in-out property <int> batch_size: 128;
    in-out property <bool> is_scanning: false;
    in-out property <float> progress: 0.0;
    in-out property <string> status_text: "System Ready. Drop images or write path.";

    in-out property <bool> ext_png: true;
    in-out property <bool> ext_tga: true;
    in-out property <bool> ext_dds: true;
    in-out property <bool> ext_bmp: true;
    in-out property <bool> ext_exr: true;
    in-out property <bool> ext_hdr: true;
    in-out property <bool> ext_tif: true;
    in-out property <bool> ext_webp: true;

    in-out property <bool> save_visuals: false;
    in-out property <int> visuals_columns: 6;
    in-out property <int> visuals_max_count: 100;
    in-out property <int> visuals_font_size: 14;
    in-out property <float> visuals_scale: 1.5;

    in-out property <length> duplicates_panel_height: 180px;
    in-out property <length> sidebar_width: 380px;

    in-out property <image> checkerboard_pattern;

    in-out property <SelectedFile> original_meta: {
        name: "-",
        size_str: "-",
        format: "-",
        resolution: "-",
        bit_depth: "-",
        color_space: "-",
        mipmaps: "-",
        alpha: "-",
        similarity: "-",
        path: ""
    };
    in-out property <SelectedFile> duplicate_meta: {
        name: "-",
        size_str: "-",
        format: "-",
        resolution: "-",
        bit_depth: "-",
        color_space: "-",
        mipmaps: "-",
        alpha: "-",
        similarity: "-",
        path: ""
    };

    in-out property <image> image_original;
    in-out property <image> image_duplicate;
    in-out property <image> image_heatmap;

    in-out property <int> compare_mode: 0;
    in-out property <float> wipe_slider_val: 0.5;
    in-out property <float> bg_alpha: 1.0;

    in-out property <bool> active_r: false;
    in-out property <bool> active_g: false;
    in-out property <bool> active_b: false;
    in-out property <bool> active_a: false;

    in-out property <bool> qc_mode: false;
    in-out property <bool> qc_npot: true;
    in-out property <bool> qc_mipmaps: true;
    in-out property <bool> qc_block_align: true;
    in-out property <bool> qc_bit_depth: true;
    in-out property <bool> qc_solid_colors: true;
    in-out property <bool> qc_normals: true;
    in-out property <string> qc_normals_tags: "";

    in-out property <bool> ignore_hidden: true;
    in-out property <bool> ignore_errors: true;
    in-out property <bool> skip_system: true;

    in-out property <int> search_method: 0;
    in-out property <int> execution_provider: 0;

    in-out property <bool> results_grid_mode: false;
    in-out property <[ResultsRow]> selected_group_files: [];

    in-out property <[ResultsRow]> results: [];
    in-out property <string> console_log: "Initializing ONNX Runtime Architecture...\nSystem ready.";

    in-out property <length> ext_popup_x: 0px;
    in-out property <length> ext_popup_y: 0px;

    callback select_folder_a();
    callback select_folder_b();
    callback run_scan();
    callback cancel_scan();
    callback open_file_in_viewer(string);
    callback trigger_action(string);
    callback row_clicked(int, bool, int, string);
    callback row_checkbox_toggled(int);
    callback channel_toggled();
    callback trigger_selection_rule(string);

    ext_popup := PopupWindow {
        x: root.ext_popup_x;
        y: root.ext_popup_y;
        width: 320px;
        height: 180px;
        close-policy: close-on-click;

        Rectangle {
            background: #2b2d31;
            border-color: #1f2023;
            border-width: 1px;
            border-radius: 4px;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;
                Text {
                    text: "File Formats Selector";
                    font-weight: 700;
                    color: #ffffff;
                }

                HorizontalLayout {
                    spacing: 12px;
                    VerticalLayout {
                        spacing: 4px;
                        CheckBox {
                            text: ".png";
                            checked <=> root.ext_png;
                        }

                        CheckBox {
                            text: ".tga";
                            checked <=> root.ext_tga;
                        }

                        CheckBox {
                            text: ".dds";
                            checked <=> root.ext_dds;
                        }

                        CheckBox {
                            text: ".bmp";
                            checked <=> root.ext_bmp;
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        CheckBox {
                            text: ".exr";
                            checked <=> root.ext_exr;
                        }

                        CheckBox {
                            text: ".hdr";
                            checked <=> root.ext_hdr;
                        }

                        CheckBox {
                            text: ".tif";
                            checked <=> root.ext_tif;
                        }

                        CheckBox {
                            text: ".webp";
                            checked <=> root.ext_webp;
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                HorizontalLayout {
                    alignment: end;
                    CustomButton {
                        text: "Close";
                        clicked => { ext_popup.close(); }
                    }
                }
            }
        }
    }

    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        // Navigation Tab Bar Layout
        HorizontalLayout {
            spacing: 4px;
            height: 32px;
            TabButton {
                text: "Find";
                active: root.active_tab == 0;
                clicked => { root.active_tab = 0; }
            }

            TabButton {
                text: "Compare";
                active: root.active_tab == 1;
                clicked => { root.active_tab = 1; }
            }

            TabButton {
                text: "Log";
                active: root.active_tab == 2;
                clicked => { root.active_tab = 2; }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            background: #1e1f22;

            // ------------------ TAB 0: FIND (Results List/Grid & Sidebar) ------------------
            if root.active_tab == 0: HorizontalLayout {
                spacing: 0px;
                width: 100%;
                height: 100%;

                // 1. Sidebar Config Section
                Rectangle {
                    width: root.sidebar_width;
                    background: #2b2d31;
                    border-color: #1f2023;
                    border-width: 1px;
                    border-radius: 4px;

                    ScrollView {
                        VerticalLayout {
                            padding: 12px;
                            spacing: 12px;

                            PanelSection {
                                title: "Scan Configuration";
                                VerticalLayout {
                                    spacing: 8px;
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text {
                                            text: "Folder A:";
                                            width: 70px;
                                            vertical-alignment: center;
                                            font-size: 12px;
                                        }

                                        LineEdit {
                                            text <=> root.dir_a;
                                            placeholder-text: "Source folder path...";
                                            horizontal-stretch: 1;
                                            height: 24px;
                                        }

                                        CustomButton {
                                            text: "...";
                                            width: 26px;
                                            height: 24px;
                                            clicked => { root.select_folder_a(); }
                                        }
                                    }

                                    if root.qc_mode: HorizontalLayout {
                                        spacing: 6px;
                                        Text {
                                            text: "Folder B:";
                                            width: 70px;
                                            vertical-alignment: center;
                                            font-size: 12px;
                                        }

                                        LineEdit {
                                            text <=> root.dir_b;
                                            placeholder-text: "Comparison folder...";
                                            horizontal-stretch: 1;
                                            height: 24px;
                                        }

                                        CustomButton {
                                            text: "...";
                                            width: 26px;
                                            height: 24px;
                                            clicked => { root.select_folder_b(); }
                                        }
                                    }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text {
                                            text: "Query AI:";
                                            width: 70px;
                                            vertical-alignment: center;
                                            font-size: 12px;
                                        }

                                        LineEdit {
                                            text <=> root.query_text;
                                            placeholder-text: "Optional text or path...";
                                            height: 24px;
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text {
                                            text: "Similarity:";
                                            width: 70px;
                                            vertical-alignment: center;
                                            font-size: 12px;
                                        }

                                        Slider {
                                            value <=> root.similarity_threshold;
                                            minimum: 50;
                                            maximum: 100;
                                            height: 24px;
                                        }

                                        Text {
                                            text: Math.round(root.similarity_threshold) + "%";
                                            width: 36px;
                                            horizontal-alignment: right;
                                            vertical-alignment: center;
                                            font-size: 12px;
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text {
                                            text: "Batch Sz:";
                                            width: 70px;
                                            vertical-alignment: center;
                                            font-size: 12px;
                                        }

                                        SpinBox {
                                            value <=> root.batch_size;
                                            minimum: 16;
                                            maximum: 1024;
                                            height: 24px;
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 8px;
                                        CustomButton {
                                            text: "File Types...";
                                            width: 100px;
                                            height: 24px;
                                            clicked => {
                                                root.ext_popup_x = self.absolute-position.x;
                                                root.ext_popup_y = self.absolute-position.y + self.height;
                                                ext_popup.show();
                                            }
                                        }

                                        Rectangle {
                                            horizontal-stretch: 1;
                                        }
                                    }

                                    CheckBox {
                                        text: "Save Visual Reports";
                                        checked <=> root.save_visuals;
                                        height: 20px;
                                    }

                                    if root.save_visuals: VerticalLayout {
                                        spacing: 6px;
                                        padding-left: 12px;
                                        padding-bottom: 4px;

                                        HorizontalLayout {
                                            alignment: start;
                                            spacing: 8px;

                                            Text {
                                                text: "Cols:";
                                                vertical-alignment: center;
                                                font-size: 11px;
                                                color: #dcddde;
                                                width: 35px;
                                            }

                                            SpinBox {
                                                value <=> root.visuals_columns;
                                                minimum: 2;
                                                maximum: 12;
                                                height: 22px;
                                                width: 80px;
                                            }

                                            Text {
                                                text: "Max:";
                                                vertical-alignment: center;
                                                font-size: 11px;
                                                color: #dcddde;
                                                width: 35px;
                                            }

                                            SpinBox {
                                                value <=> root.visuals_max_count;
                                                minimum: 1;
                                                maximum: 1000;
                                                height: 22px;
                                                width: 90px;
                                            }

                                            Rectangle {
                                                horizontal-stretch: 1;
                                            }
                                        }

                                        HorizontalLayout {
                                            alignment: start;
                                            spacing: 8px;

                                            Text {
                                                text: "Font:";
                                                vertical-alignment: center;
                                                font-size: 11px;
                                                color: #dcddde;
                                                width: 35px;
                                            }

                                            SpinBox {
                                                value <=> root.visuals_font_size;
                                                minimum: 8;
                                                maximum: 36;
                                                height: 22px;
                                                width: 80px;
                                            }

                                            Text {
                                                text: "Scale:";
                                                vertical-alignment: center;
                                                font-size: 11px;
                                                color: #dcddde;
                                                width: 35px;
                                            }

                                            Slider {
                                                value <=> root.visuals_scale;
                                                minimum: 1.0;
                                                maximum: 3.0;
                                                height: 22px;
                                                horizontal-stretch: 1;
                                            }

                                            Text {
                                                text: (Math.round(root.visuals_scale * 10) / 10) + "x";
                                                width: 26px;
                                                horizontal-alignment: right;
                                                vertical-alignment: center;
                                                font-size: 11px;
                                                color: #ffffff;
                                            }
                                        }
                                    }

                                    CustomButton {
                                        text: root.is_scanning ? "Stop / Cancel Scan" : "Start Scan";
                                        primary-color: root.is_scanning ? #f23f43 : #23a55a;
                                        height: 28px;
                                        clicked => {
                                            if root.is_scanning { root.cancel_scan(); } else { root.run_scan(); }
                                        }
                                    }
                                }
                            }

                            PanelSection {
                                title: "Quality Control (QC) Options";
                                VerticalLayout {
                                    spacing: 6px;
                                    CheckBox {
                                        text: "Enable Technical QC Mode";
                                        checked <=> root.qc_mode;
                                        height: 20px;
                                    }

                                    if root.qc_mode: VerticalLayout {
                                        spacing: 4px;
                                        padding-left: 8px;
                                        CheckBox {
                                            text: "Check NPOT (Power of 2)";
                                            checked <=> root.qc_npot;
                                            height: 20px;
                                        }

                                        CheckBox {
                                            text: "Check Mip-Maps";
                                            checked <=> root.qc_mipmaps;
                                            height: 20px;
                                        }

                                        CheckBox {
                                            text: "Check BlockAlignment (4px)";
                                            checked <=> root.qc_block_align;
                                            height: 20px;
                                        }

                                        CheckBox {
                                            text: "Check Bit Depth";
                                            checked <=> root.qc_bit_depth;
                                            height: 20px;
                                        }

                                        CheckBox {
                                            text: "Check Solid Colors";
                                            checked <=> root.qc_solid_colors;
                                            height: 20px;
                                        }

                                        CheckBox {
                                            text: "Validate Normal Maps";
                                            checked <=> root.qc_normals;
                                            height: 20px;
                                        }

                                        LineEdit {
                                            text <=> root.qc_normals_tags;
                                            placeholder-text: "Tags: _norm, _ddn";
                                            enabled: root.qc_normals;
                                            height: 24px;
                                        }
                                    }
                                }
                            }

                            PanelSection {
                                title: "Search Methods (Non-QC)";
                                ComboBox {
                                    model: [
                                        "Exact Match (xxHash)",
                                        "Simple Duplicates (dHash)",
                                        "AI Semantic/Visual Search"
                                    ];
                                    current-index <=> root.search_method;
                                    height: 24px;
                                }
                            }

                            PanelSection {
                                title: "Execution Provider";
                                ComboBox {
                                    model: ["CPU", "DirectML", "CUDA", "TensorRT", "CoreML"];
                                    current-index <=> root.execution_provider;
                                    height: 24px;
                                }
                            }

                            Rectangle {
                                vertical-stretch: 1;
                            }
                        }
                    }
                }

                // Tactile Horizontal Draggable Splitter
                Rectangle {
                    width: 8px;
                    background: sidebar-splitter-ta.has-hover ? #4e5058 : #1e1f22;

                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 2px;
                            height: 20px;
                            background: #6d6f78;
                            border-radius: 1px;
                        }
                    }

                    sidebar-splitter-ta := TouchArea {
                        mouse-cursor: MouseCursor.col-resize;
                        moved => {
                            if (self.pressed) {
                                root.sidebar_width = (self.x + self.mouse-x - self.pressed-x).clamp(340px, 600px);
                            }
                        }
                    }
                }

                // 2. Results List Pane & Quick Action Console Section
                VerticalLayout {
                    padding-left: 12px;
                    horizontal-stretch: 1;
                    spacing: 8px;

                    VerticalLayout {
                        spacing: 8px;
                        vertical-stretch: 1;

                        HorizontalLayout {
                            alignment: space-between;
                            Text {
                                text: "Results (" + root.results.length + " items)";
                                font-size: 14px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }

                            HorizontalLayout {
                                spacing: 6px;
                                CustomButton {
                                    text: root.results_grid_mode ? "List Mode (☰)" : "Grid Mode (⊞)";
                                    height: 24px;
                                    clicked => { root.results_grid_mode = !root.results_grid_mode; }
                                }
                            }
                        }

                        Rectangle {
                            border-color: #1f2023;
                            border-width: 1px;
                            background: #2b2d31;
                            border-radius: 4px;
                            vertical-stretch: 1;

                            if !root.results_grid_mode && root.results.length > 0: ListView {
                                for row[idx] in root.results: Rectangle {
                                    height: row.is_header ? 34px : 44px;
                                    background: row.is_header ? #1e1f22 : (row.is_best ? #2c3e50 : (row-ta.has-hover ? #393c41 : #2b2d31));
                                    border-color: #1f2023;
                                    border-width: 1px;

                                    row-ta := TouchArea {
                                        clicked => { root.row_clicked(idx, row.is_header, row.group_index, row.path); if (!row.is_header) { root.active_tab = 1; } }
                                    }

                                    if row.is_header: HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        spacing: 8px;
                                        alignment: space-between;
                                        Text {
                                            text: "Group # " + (row.group_index + 1) + " (Hash: " + row.hash_or_issue + ")";
                                            color: #949ba4;
                                            font-size: 13px;
                                            font-weight: 700;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }

                                        Text {
                                            text: row.meta_str;
                                            color: #f0b132;
                                            font-size: 12px;
                                            font-weight: 700;
                                            vertical-alignment: center;
                                        }

                                        Text {
                                            text: row.size_str;
                                            color: #949ba4;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }

                                    if !row.is_header: HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        spacing: 8px;

                                        CheckBox {
                                            checked: row.is_checked;
                                            toggled => { root.row_checkbox_toggled(idx); }
                                            width: 24px;
                                        }

                                        HorizontalLayout {
                                            spacing: 8px;
                                            width: 240px;
                                            InteractiveThumbnail {
                                                source: row.thumbnail;
                                                path: row.path;
                                                show_corners: true;
                                                checkerboard: root.checkerboard_pattern;
                                                corner_clicked(path, chan) => {
                                                    if chan == "R" { root.active_r = !root.active_r; root.active_g = false; root.active_b = false; root.active_a = false; }
                                                    if chan == "G" { root.active_g = !root.active_g; root.active_r = false; root.active_b = false; root.active_a = false; }
                                                    if chan == "B" { root.active_b = !root.active_b; root.active_r = false; root.active_g = false; root.active_a = false; }
                                                    if chan == "A" { root.active_a = !root.active_a; root.active_r = false; root.active_g = false; root.active_b = false; }
                                                    root.channel_toggled();
                                                    root.row_clicked(idx, false, row.group_index, row.path);
                                                    root.active_tab = 1;
                                                }
                                            }

                                            Text {
                                                text: row.name;
                                                color: #dcddde;
                                                font-size: 13px;
                                                vertical-alignment: center;
                                                overflow: elide;
                                            }
                                        }

                                        Text {
                                            text: row.is_best ? "[Best]" : row.score_or_detail;
                                            color: row.is_best ? #f0b132 : #dcddde;
                                            font-size: 13px;
                                            vertical-alignment: center;
                                            horizontal-alignment: center;
                                            width: 60px;
                                        }

                                        Text {
                                            text: row.path;
                                            color: #949ba4;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }

                                        Text {
                                            text: row.meta_str;
                                            color: #949ba4;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            overflow: elide;
                                            width: 120px;
                                        }
                                    }
                                }
                            }

                            if root.results_grid_mode && root.results.length > 0: ScrollView {
                                HorizontalLayout {
                                    spacing: 12px;
                                    padding: 10px;
                                    VerticalLayout {
                                        spacing: 0px;
                                        alignment: start;
                                        for row[idx] in root.results: Rectangle {
                                            property <bool> show: idx.mod(3) == 0 && !row.is_header && row.is_best;
                                            width: show ? 135px : 0px;
                                            height: show ? 175px : 0px;
                                            visible: show;
                                            Rectangle {
                                                y: 0px;
                                                height: parent.height - 10px;
                                                width: parent.width;
                                                background: #2b2d31;
                                                border-color: #1f2023;
                                                border-width: 1px;
                                                border-radius: 6px;
                                                TouchArea {
                                                    clicked => { root.row_clicked(idx, false, row.group_index, row.path); root.active_tab = 1; }
                                                }

                                                VerticalLayout {
                                                    padding: 8px;
                                                    spacing: 6px;
                                                    InteractiveThumbnail {
                                                        source: row.thumbnail;
                                                        path: row.path;
                                                        show_corners: false;
                                                        checkerboard: root.checkerboard_pattern;
                                                        width: 115px;
                                                        height: 95px;
                                                    }

                                                    Text {
                                                        text: "Group #" + (row.group_index + 1);
                                                        color: #ffffff;
                                                        font-size: 11px;
                                                        font-weight: 700;
                                                        horizontal-alignment: center;
                                                    }

                                                    Text {
                                                        text: row.size_str;
                                                        color: #949ba4;
                                                        font-size: 10px;
                                                        horizontal-alignment: center;
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        spacing: 0px;
                                        alignment: start;
                                        for row[idx] in root.results: Rectangle {
                                            property <bool> show: idx.mod(3) == 1 && !row.is_header && row.is_best;
                                            width: show ? 135px : 0px;
                                            height: show ? 175px : 0px;
                                            visible: show;
                                            Rectangle {
                                                y: 0px;
                                                height: parent.height - 10px;
                                                width: parent.width;
                                                background: #2b2d31;
                                                border-color: #1f2023;
                                                border-width: 1px;
                                                border-radius: 6px;
                                                TouchArea {
                                                    clicked => { root.row_clicked(idx, false, row.group_index, row.path); root.active_tab = 1; }
                                                }

                                                VerticalLayout {
                                                    padding: 8px;
                                                    spacing: 6px;
                                                    InteractiveThumbnail {
                                                        source: row.thumbnail;
                                                        path: row.path;
                                                        show_corners: false;
                                                        checkerboard: root.checkerboard_pattern;
                                                        width: 115px;
                                                        height: 95px;
                                                    }

                                                    Text {
                                                        text: "Group #" + (row.group_index + 1);
                                                        color: #ffffff;
                                                        font-size: 11px;
                                                        font-weight: 700;
                                                        horizontal-alignment: center;
                                                    }

                                                    Text {
                                                        text: row.size_str;
                                                        color: #949ba4;
                                                        font-size: 10px;
                                                        horizontal-alignment: center;
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        spacing: 0px;
                                        alignment: start;
                                        for row[idx] in root.results: Rectangle {
                                            property <bool> show: idx.mod(3) == 2 && !row.is_header && row.is_best;
                                            width: show ? 135px : 0px;
                                            height: show ? 175px : 0px;
                                            visible: show;
                                            Rectangle {
                                                y: 0px;
                                                height: parent.height - 10px;
                                                width: parent.width;
                                                background: #2b2d31;
                                                border-color: #1f2023;
                                                border-width: 1px;
                                                border-radius: 6px;
                                                TouchArea {
                                                    clicked => { root.row_clicked(idx, false, row.group_index, row.path); root.active_tab = 1; }
                                                }

                                                VerticalLayout {
                                                    padding: 8px;
                                                    spacing: 6px;
                                                    InteractiveThumbnail {
                                                        source: row.thumbnail;
                                                        path: row.path;
                                                        show_corners: false;
                                                        checkerboard: root.checkerboard_pattern;
                                                        width: 115px;
                                                        height: 95px;
                                                    }

                                                    Text {
                                                        text: "Group #" + (row.group_index + 1);
                                                        color: #ffffff;
                                                        font-size: 11px;
                                                        font-weight: 700;
                                                        horizontal-alignment: center;
                                                    }

                                                    Text {
                                                        text: row.size_str;
                                                        color: #949ba4;
                                                        font-size: 10px;
                                                        horizontal-alignment: center;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            if root.results.length == 0: VerticalLayout {
                                alignment: center;
                                spacing: 12px;
                                Text {
                                    text: "No duplicate assets loaded. Choose scan parameters in the left pane and begin auditing.";
                                    color: #7c808a;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    Rectangle {
                        background: #2b2d31;
                        border-color: #1f2023;
                        border-width: 1px;
                        border-radius: 4px;
                        height: 56px;
                        VerticalLayout {
                            padding: 8px;
                            spacing: 4px;
                            Text {
                                text: "Selection Rules";
                                font-size: 12px;
                                font-weight: 700;
                                color: #949ba4;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                CustomButton {
                                    text: "Select All";
                                    primary-color: #4e5058;
                                    width: 85px;
                                    clicked => { root.trigger_selection_rule("all"); }
                                }

                                CustomButton {
                                    text: "Deselect All";
                                    primary-color: #4e5058;
                                    width: 95px;
                                    clicked => { root.trigger_selection_rule("none"); }
                                }

                                CustomButton {
                                    text: "Select All Except Best";
                                    primary-color: #4e5058;
                                    width: 140px;
                                    clicked => { root.trigger_selection_rule("except_best"); }
                                }

                                CustomButton {
                                    text: "Invert Selection";
                                    primary-color: #4e5058;
                                    width: 110px;
                                    clicked => { root.trigger_selection_rule("invert"); }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        height: 24px;
                        CustomButton {
                            text: "Replace with Hardlink";
                            primary-color: #5865f2;
                            width: 145px;
                            clicked => { root.trigger_action("hardlink"); }
                        }

                        CustomButton {
                            text: "Replace with Reflink";
                            primary-color: #5865f2;
                            width: 135px;
                            clicked => { root.trigger_action("reflink"); }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        CustomButton {
                            text: "Move to Trash";
                            primary-color: #f23f43;
                            width: 105px;
                            clicked => { root.trigger_action("trash"); }
                        }
                    }
                }
            } // End of Tab 0

            // ------------------ TAB 1: COMPARE (Large Side-by-Side Canvas) ------------------
            if root.active_tab == 1: HorizontalLayout {
                spacing: 12px;
                width: 100%;
                height: 100%;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 12px;
                    Text {
                        text: "Interactive Compare Viewport";
                        font-size: 15px;
                        font-weight: 700;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        height: 28px;
                        ComboBox {
                            model: ["Side-by-Side", "Wipe Mode", "Overlay Blend", "Difference Heatmap"];
                            current-index <=> root.compare_mode;
                            width: 160px;
                            height: 24px;
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "Wipe Shift:";
                                vertical-alignment: center;
                                font-size: 12px;
                            }

                            Slider {
                                value <=> root.wipe_slider_val;
                                minimum: 0.0;
                                maximum: 1.0;
                                height: 24px;
                            }
                        }
                    }

                    viewport_root := Rectangle {
                        background: #111214;
                        clip: true;
                        vertical-stretch: 1;
                        horizontal-stretch: 1;

                        if root.compare_mode == 0: Rectangle {
                            width: 100%;
                            height: 100%;
                            Rectangle {
                                x: 0px;
                                y: 0px;
                                width: parent.width / 2 - 6px;
                                height: parent.height;
                                VerticalLayout {
                                    width: 100%;
                                    height: 100%;
                                    spacing: 4px;
                                    Text {
                                        text: "ORIGINAL (Double-click to open)";
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                    }

                                    Rectangle {
                                        vertical-stretch: 1;
                                        background: #111214;
                                        border-color: #3e3e42;
                                        border-width: 1px;
                                        border-radius: 4px;
                                        clip: true;
                                        Image {
                                            source: root.checkerboard_pattern;
                                            horizontal-tiling: repeat;
                                            vertical-tiling: repeat;
                                            width: 100%;
                                            height: 100%;
                                        }

                                        Image {
                                            source: root.image_original;
                                            image-fit: contain;
                                            width: 100%;
                                            height: 100%;
                                        }

                                        TouchArea {
                                            double-clicked => { root.open_file_in_viewer(root.original_meta.path); }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                x: parent.width / 2 + 6px;
                                y: 0px;
                                width: parent.width / 2 - 6px;
                                height: parent.height;
                                VerticalLayout {
                                    width: 100%;
                                    height: 100%;
                                    spacing: 4px;
                                    Text {
                                        text: "DUPLICATE (Double-click to open)";
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                    }

                                    Rectangle {
                                        vertical-stretch: 1;
                                        background: #111214;
                                        border-color: #3e3e42;
                                        border-width: 1px;
                                        border-radius: 4px;
                                        clip: true;
                                        Image {
                                            source: root.checkerboard_pattern;
                                            horizontal-tiling: repeat;
                                            vertical-tiling: repeat;
                                            width: 100%;
                                            height: 100%;
                                        }

                                        Image {
                                            source: root.image_duplicate;
                                            image-fit: contain;
                                            width: 100%;
                                            height: 100%;
                                        }

                                        TouchArea {
                                            double-clicked => { root.open_file_in_viewer(root.duplicate_meta.path); }
                                        }
                                    }
                                }
                            }
                        }

                        if root.compare_mode == 1: Rectangle {
                            width: 100%;
                            height: 100%;
                            VerticalLayout {
                                width: 100%;
                                height: 100%;
                                spacing: 4px;
                                Text {
                                    text: "WIPE COMPARE (ORIGINAL / DUPLICATE)";
                                    font-size: 11px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                }

                                Rectangle {
                                    vertical-stretch: 1;
                                    background: #111214;
                                    border-color: #3e3e42;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    clip: true;
                                    WipeViewport {
                                        original: root.image_original;
                                        duplicate: root.image_duplicate;
                                        wipe-val: root.wipe_slider_val;
                                        checkerboard: root.checkerboard_pattern;
                                        width: 100%;
                                        height: 100%;
                                    }
                                }
                            }
                        }

                        if root.compare_mode == 2: Rectangle {
                            width: 100%;
                            height: 100%;
                            VerticalLayout {
                                width: 100%;
                                height: 100%;
                                spacing: 4px;
                                Text {
                                    text: "OVERLAY BLEND";
                                    font-size: 11px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                }

                                Rectangle {
                                    vertical-stretch: 1;
                                    background: #111214;
                                    border-color: #3e3e42;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    clip: true;
                                    Image {
                                        source: root.checkerboard_pattern;
                                        horizontal-tiling: repeat;
                                        vertical-tiling: repeat;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    Image {
                                        source: root.image_original;
                                        image-fit: contain;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    Image {
                                        source: root.image_duplicate;
                                        image-fit: contain;
                                        width: 100%;
                                        height: 100%;
                                        opacity: root.wipe_slider_val;
                                    }
                                }
                            }
                        }

                        if root.compare_mode == 3: Rectangle {
                            width: 100%;
                            height: 100%;
                            VerticalLayout {
                                width: 100%;
                                height: 100%;
                                spacing: 4px;
                                Text {
                                    text: "DIFFERENCE HEATMAP";
                                    font-size: 11px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                }

                                Rectangle {
                                    vertical-stretch: 1;
                                    background: #111214;
                                    border-color: #3e3e42;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    clip: true;
                                    Image {
                                        source: root.checkerboard_pattern;
                                        horizontal-tiling: repeat;
                                        vertical-tiling: repeat;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    Image {
                                        source: root.image_heatmap;
                                        image-fit: contain;
                                        width: 100%;
                                        height: 100%;
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        height: 28px;
                        alignment: center;
                        ChannelButton {
                            text: "R";
                            active-color: #f23f43;
                            active <=> root.active_r;
                            clicked => { root.active_r = !root.active_r; if root.active_r { root.active_g = false; root.active_b = false; root.active_a = false; } root.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "G";
                            active-color: #23a55a;
                            active <=> root.active_g;
                            clicked => { root.active_g = !root.active_g; if root.active_g { root.active_r = false; root.active_b = false; root.active_a = false; } root.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "B";
                            active-color: #5865f2;
                            active <=> root.active_b;
                            clicked => { root.active_b = !root.active_b; if root.active_b { root.active_r = false; root.active_g = false; root.active_a = false; } root.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "A";
                            active-color: #ffffff;
                            text-color: #000000;
                            active <=> root.active_a;
                            clicked => { root.active_a = !root.active_a; if root.active_a { root.active_r = false; root.active_g = false; root.active_b = false; } root.channel_toggled(); }
                        }
                    }
                }

                VerticalLayout {
                    width: 440px;
                    spacing: 12px;

                    Text {
                        text: "Group Duplicates (" + root.selected_group_files.length + " items)";
                        font-size: 13px;
                        font-weight: 700;
                        color: #949ba4;
                    }

                    Rectangle {
                        height: root.duplicates_panel_height;
                        background: #111214;
                        border-color: #1f2023;
                        border-width: 1px;
                        border-radius: 4px;
                        if root.selected_group_files.length > 0: ListView {
                            for row[idx] in root.selected_group_files: Rectangle {
                                height: 38px;
                                background: (row.path == root.duplicate_meta.path) ? #2c3e50 : (right-row-ta.has-hover ? #393c41 : #111214);
                                border-radius: 4px;
                                right-row-ta := TouchArea {
                                    clicked => { root.row_clicked(idx, false, row.group_index, row.path); }
                                }

                                HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    spacing: 8px;
                                    alignment: space-between;
                                    InteractiveThumbnail {
                                        source: row.thumbnail;
                                        path: row.path;
                                        show_corners: false;
                                        checkerboard: root.checkerboard_pattern;
                                    }

                                    Text {
                                        text: row.name;
                                        color: #dcddde;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }

                                    Text {
                                        text: row.is_best ? "[Best]" : row.score_or_detail;
                                        color: row.is_best ? #f0b132 : #dcddde;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        if root.selected_group_files.length == 0: VerticalLayout {
                            alignment: center;
                            Text {
                                text: "No duplicates selected.";
                                color: #7c808a;
                                horizontal-alignment: center;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    Rectangle {
                        height: 8px;
                        background: splitter-ta.has-hover ? #4e5058 : #2b2d31;
                        border-radius: 4px;
                        HorizontalLayout {
                            alignment: center;
                            Rectangle {
                                width: 20px;
                                height: 2px;
                                background: #6d6f78;
                                border-radius: 1px;
                            }
                        }

                        splitter-ta := TouchArea {
                            mouse-cursor: MouseCursor.row-resize;
                            moved => { if (self.pressed) { root.duplicates_panel_height = (self.y + self.mouse-y - self.pressed-y).clamp(80px, 450px); } }
                        }
                    }

                    Text {
                        text: "Comparison Specifications Matrix";
                        font-size: 13px;
                        font-weight: 700;
                        color: #949ba4;
                    }

                    Rectangle {
                        border-color: #1f2023;
                        border-width: 1px;
                        background: #111214;
                        border-radius: 4px;
                        vertical-stretch: 1;
                        ScrollView {
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                HorizontalLayout {
                                    Text {
                                        text: "Specification";
                                        width: 120px;
                                        font-weight: 700;
                                        color: #949ba4;
                                        font-size: 12px;
                                    }

                                    Text {
                                        text: "Original [Best]";
                                        font-weight: 700;
                                        color: #f0b132;
                                        font-size: 12px;
                                    }

                                    Text {
                                        text: "Duplicate";
                                        font-weight: 700;
                                        color: #dcddde;
                                        font-size: 12px;
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: #1f2023;
                                    vertical-stretch: 0;
                                }

                                SpecsRow {
                                    name: "File Name";
                                    val1: root.original_meta.name;
                                    val2: root.duplicate_meta.name;
                                }

                                SpecsRow {
                                    name: "File Size";
                                    val1: root.original_meta.size_str;
                                    val2: root.duplicate_meta.size_str;
                                }

                                SpecsRow {
                                    name: "Format / Codec";
                                    val1: root.original_meta.format;
                                    val2: root.duplicate_meta.format;
                                }

                                SpecsRow {
                                    name: "Resolution";
                                    val1: root.original_meta.resolution;
                                    val2: root.duplicate_meta.resolution;
                                }

                                SpecsRow {
                                    name: "Bit Depth";
                                    val1: root.original_meta.bit_depth;
                                    val2: root.duplicate_meta.bit_depth;
                                }

                                SpecsRow {
                                    name: "Color Space";
                                    val1: root.original_meta.color_space;
                                    val2: root.duplicate_meta.color_space;
                                }

                                SpecsRow {
                                    name: "Mipmaps";
                                    val1: root.original_meta.mipmaps;
                                    val2: root.duplicate_meta.mipmaps;
                                }

                                SpecsRow {
                                    name: "Alpha Channel";
                                    val1: root.original_meta.alpha;
                                    val2: root.duplicate_meta.alpha;
                                }

                                SpecsRow {
                                    name: "Similarity";
                                    val1: "100.0%";
                                    val2: root.duplicate_meta.similarity;
                                }

                                Rectangle {
                                    height: 1px;
                                    background: #1f2023;
                                    vertical-stretch: 0;
                                }

                                SpecsRow {
                                    name: "Full Path";
                                    val1: root.original_meta.path;
                                    val2: root.duplicate_meta.path;
                                }

                                Rectangle {
                                    vertical-stretch: 1;
                                }
                            }
                        }
                    }
                }
            } // End of Tab 1

            // ------------------ TAB 2: LOG (Console Output) ------------------
            if root.active_tab == 2: VerticalLayout {
                padding: 15px;
                spacing: 10px;
                width: 100%;
                height: 100%;
                Text {
                    text: "System Console Logs & Compiler Diagnostics";
                    font-weight: 700;
                    font-size: 14px;
                }

                TextEdit {
                    text <=> root.console_log;
                    read-only: true;
                    font-family: "Consolas";
                    font-size: 12px;
                    vertical-stretch: 1;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    CustomButton {
                        text: "Export Log Output...";
                        primary-color: #0e639c;
                    }

                    CustomButton {
                        text: "Clear Console Buffer";
                        primary-color: #3a3a3a;
                        clicked => { root.console_log = "Buffer cleared."; }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }
                }
            } // End of Tab 2
        }

        // Progress Overlay Container (Pinned to bottom if scanning)
        if root.is_scanning: Rectangle {
            background: #2b2d31;
            border-radius: 4px;
            border-color: #1f2023;
            border-width: 1px;
            height: 48px;
            HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text {
                    text: root.status_text;
                    color: #dcddde;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 250px;
                    overflow: elide;
                }

                ProgressIndicator {
                    progress: root.progress;
                    horizontal-stretch: 1;
                    height: 16px;
                }

                Text {
                    text: Math.round(root.progress * 100) + "%";
                    color: #ffffff;
                    font-weight: 700;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 40px;
                }
            }
        }

        // Hidden placeholder required by Slint analyzer
        Rectangle {
            visible: false;
            width: 0px;
            height: 0px;
            WipeViewport { }
        }
    }
}
