// ui/app.slint

import {
    ProgressIndicator,
    Palette,
} from "std-widgets.slint";

import {
    ResultsRow,
    SelectedFile,
    GridRow,
    PathSettings,
    ExtensionSettings,
    UiLayoutSettings,
    VisualReportSettings,
    PreprocessingSettings,
    QcSettings,
    AiSettings,
    TonemapSettings,
    ViewerConfig,
    PreviewSettings,
    SearchMethod,
    ExecutionProvider,
    AiModelType,
} from "./structs.slint";

export {
    ResultsRow,
    SelectedFile,
    GridRow,
    PathSettings,
    ExtensionSettings,
    UiLayoutSettings,
    VisualReportSettings,
    PreprocessingSettings,
    QcSettings,
    AiSettings,
    TonemapSettings,
    ViewerConfig,
    PreviewSettings,
    SearchMethod,
    ExecutionProvider,
    AiModelType,
}from "./structs.slint";

// Import and export the split modular singletons
import { ScanConfig, ViewportState, Diagnostics } from "./store.slint";
export { ScanConfig, ViewportState, Diagnostics }
import { TabButton } from "./components/buttons.slint";

// IMPORT CUSTOM POPUPS
import { SkippedFilesPopup } from "./components/skipped_popup.slint";
import { ContextMenuPopup } from "./components/context_menu.slint";
import { FileFormatsPopup } from "./components/file_formats_popup.slint";

// IMPORT MODULAR TABS
import { FindTab } from "./tabs/find_tab.slint";
import { CompareTab } from "./tabs/compare_tab.slint";
import { LogTab } from "./tabs/log_tab.slint";

export component AppWindow inherits Window {
    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    title: "PixelHand - AI Duplicate & Graphical QC Auditor";

    // Window title bar and Alt-Tab navigation icon
    icon: @image-url("../assets/icon.png");

    preferred-width: 1320px;
    preferred-height: 880px;
    min-width: 1000px;
    min-height: 700px;
    background: #1e1e1e;

    // --- ADAPTIVE GRID BEHAVIOR ---
    property <int> calc_cols: Math.max(1, Math.round(Math.floor((self.width - ScanConfig.ui.sidebar_width - 40px) / (ScanConfig.ui.grid_card_size + 12px))));
    changed calc_cols => {
        ScanConfig.grid_columns = self.calc_cols;
        ScanConfig.grid_columns_changed();
    }

    skipped_popup := SkippedFilesPopup { }

    context_popup := ContextMenuPopup { }

    ext_popup := FileFormatsPopup { }

    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        // TOP NAVIGATION TABS
        HorizontalLayout {
            spacing: 4px;
            alignment: start;
            height: 32px;
            TabButton {
                text: "Find";
                active: Diagnostics.active_tab == 0;
                clicked => { Diagnostics.active_tab = 0; }
            }

            TabButton {
                text: "Compare";
                active: Diagnostics.active_tab == 1;
                clicked => { Diagnostics.active_tab = 1; }
            }

            TabButton {
                text: "Log";
                active: Diagnostics.active_tab == 2;
                clicked => { Diagnostics.active_tab = 2; }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            background: #1e1e1e;

            // ================== TAB 0: FIND ==================
            if Diagnostics.active_tab == 0: FindTab {
                show_formats_popup => {
                    ext_popup.show();
                }
                show_skipped_popup(x_pos, y_pos) => {
                    Diagnostics.skipped_popup_x = x_pos;
                    Diagnostics.skipped_popup_y = y_pos;
                    skipped_popup.show();
                }
                show_context_menu(x_pos, y_pos, path) => {
                    Diagnostics.context_hovered_path = path;
                    Diagnostics.menu_x = x_pos;
                    Diagnostics.menu_y = y_pos;
                    context_popup.show();
                }
            }

            // ================== TAB 1: COMPARE ==================
            if Diagnostics.active_tab == 1: CompareTab { }

            // ================== TAB 2: LOG ==================
            if Diagnostics.active_tab == 2: LogTab { }
        }

        // FIXED BOTTOM SCANNING STATUS BANNER
        if Diagnostics.is_scanning: Rectangle {
            background: #2d2d2d;
            border-radius: 4px;
            border-color: #353535;
            border-width: 1px;
            height: 48px;
            HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text {
                    text: Diagnostics.status_text;
                    color: #cfcfcf;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 250px;
                    overflow: elide;
                }

                ProgressIndicator {
                    progress: Diagnostics.progress;
                    horizontal-stretch: 1;
                    height: 16px;
                }

                Text {
                    text: Math.round(Diagnostics.progress * 100) + "%";
                    color: #ffffff;
                    font-weight: 700;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 40px;
                }
            }
        }
    }
}
