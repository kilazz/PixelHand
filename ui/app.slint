// ui/app.slint

import {
    ProgressIndicator,
    Palette,
    TextEdit,
    ListView,
    ScrollView,
    Slider,
    SpinBox,
    ComboBox,
    LineEdit,
    CheckBox,
} from "std-widgets.slint";

import { ResultsRow, SelectedFile, GridRow } from "./structs.slint";
export { ResultsRow, SelectedFile, GridRow }from "./structs.slint";

import { Store } from "./store.slint";
export { Store }
import {
    TabButton,
    ChannelButton,
    CustomButton,
} from "./components/buttons.slint";
import { TableHeader } from "./components/table_header.slint";
import { ListRow } from "./components/list_row.slint";
import { GridCard } from "./components/grid_card.slint";
import {
    InteractiveCompareViewport,
} from "./components/compare_viewport.slint";
import { FindSidebar } from "./components/find_sidebar.slint";
import { InteractiveThumbnail } from "./components/thumbnail.slint";

// IMPORT COMMON STYLINGS
import {
    FormRow,
    SpecsRow,
    SectionTitle,
    PanelSection,
    WipeViewport,
} from "./components/common.slint";

// IMPORT CUSTOM POPUPS (All consolidated in components folder)
import { SkippedFilesPopup } from "./components/skipped_popup.slint";
import { ContextMenuPopup } from "./components/context_menu.slint";
import { FileFormatsPopup } from "./components/file_formats_popup.slint";

export component AppWindow inherits Window {
    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    title: "PixelHand - AI Duplicate & Graphical QC Auditor";
    preferred-width: 1320px;
    preferred-height: 880px;
    min-width: 1000px;
    min-height: 700px;
    background: #1e1f22;

    // --- ALIAS ALL PROPERTIES & STATE (Keeps Rust Backend 100% Unchanged) ---
    in-out property <int> active_tab <=> Store.active_tab;
    in-out property <bool> tonemap_enabled <=> Store.tonemap_enabled;
    in-out property <int> tonemap_operator <=> Store.tonemap_operator;
    in-out property <string> dir_a <=> Store.dir_a;
    in-out property <string> dir_b <=> Store.dir_b;
    in-out property <string> query_text <=> Store.query_text;
    in-out property <float> similarity_threshold <=> Store.similarity_threshold;
    in-out property <int> batch_size <=> Store.batch_size;
    in-out property <bool> is_scanning <=> Store.is_scanning;
    in-out property <float> progress <=> Store.progress;
    in-out property <string> status_text <=> Store.status_text;

    in-out property <bool> ext_png <=> Store.ext_png;
    in-out property <bool> ext_jpg <=> Store.ext_jpg;
    in-out property <bool> ext_tga <=> Store.ext_tga;
    in-out property <bool> ext_dds <=> Store.ext_dds;
    in-out property <bool> ext_bmp <=> Store.ext_bmp;
    in-out property <bool> ext_exr <=> Store.ext_exr;
    in-out property <bool> ext_hdr <=> Store.ext_hdr;
    in-out property <bool> ext_tif <=> Store.ext_tif;
    in-out property <bool> ext_webp <=> Store.ext_webp;
    in-out property <bool> ext_gif <=> Store.ext_gif;
    in-out property <bool> ext_psd <=> Store.ext_psd;
    in-out property <bool> ext_jxl <=> Store.ext_jxl;
    in-out property <bool> ext_heic <=> Store.ext_heic;
    in-out property <bool> ext_avif <=> Store.ext_avif;

    in-out property <bool> save_visuals <=> Store.save_visuals;
    in-out property <int> visuals_columns <=> Store.visuals_columns;
    in-out property <int> visuals_max_count <=> Store.visuals_max_count;
    in-out property <int> visuals_font_size <=> Store.visuals_font_size;
    in-out property <float> visuals_scale <=> Store.visuals_scale;

    in-out property <bool> prep_luminance <=> Store.prep_luminance;
    in-out property <bool> prep_channels <=> Store.prep_channels;
    in-out property <bool> prep_r <=> Store.prep_r;
    in-out property <bool> prep_g <=> Store.prep_g;
    in-out property <bool> prep_b <=> Store.prep_b;
    in-out property <bool> prep_a <=> Store.prep_a;
    in-out property <string> prep_tags <=> Store.prep_tags;
    in-out property <bool> prep_ignore_solid <=> Store.prep_ignore_solid;

    in-out property <bool> show_advanced <=> Store.show_advanced;
    in-out property <string> excluded_folders <=> Store.excluded_folders;
    in-out property <bool> qc_match_by_stem <=> Store.qc_match_by_stem;
    in-out property <bool> qc_hide_same_resolution <=> Store.qc_hide_same_resolution;

    in-out property <bool> qc_check_bloat <=> Store.qc_check_bloat;
    in-out property <bool> qc_check_alpha <=> Store.qc_check_alpha;
    in-out property <bool> qc_check_colorspace <=> Store.qc_check_colorspace;
    in-out property <bool> qc_check_compression <=> Store.qc_check_compression;

    in-out property <int> search_precision <=> Store.search_precision;
    in-out property <int> ai_model <=> Store.ai_model;
    in-out property <string> custom_model_path <=> Store.custom_model_path;
    in-out property <int> custom_model_arch <=> Store.custom_model_arch;
    in-out property <int> custom_model_dim <=> Store.custom_model_dim;

    in-out property <[string]> skipped_files_list <=> Store.skipped_files_list;

    in-out property <length> col_file_w <=> Store.col_file_w;
    in-out property <length> col_score_w <=> Store.col_score_w;
    in-out property <length> col_path_w <=> Store.col_path_w;
    in-out property <length> list_preview_size <=> Store.list_preview_size;
    in-out property <length> col_format_w <=> Store.col_format_w;
    in-out property <length> col_dimensions_w <=> Store.col_dimensions_w;
    in-out property <length> col_mipmaps_w <=> Store.col_mipmaps_w;
    in-out property <length> col_cubemap_w <=> Store.col_cubemap_w;
    in-out property <length> col_size_w <=> Store.col_size_w;

    in-out property <length> duplicates_panel_height <=> Store.duplicates_panel_height;
    in-out property <length> sidebar_width <=> Store.sidebar_width;
    in-out property <length> compare_sidebar_width <=> Store.compare_sidebar_width;
    in-out property <length> grid_card_size <=> Store.grid_card_size;
    in-out property <image> checkerboard_pattern <=> Store.checkerboard_pattern;

    in-out property <SelectedFile> original_meta <=> Store.original_meta;
    in-out property <SelectedFile> duplicate_meta <=> Store.duplicate_meta;

    in-out property <image> image_original <=> Store.image_original;
    in-out property <image> image_duplicate <=> Store.image_duplicate;
    in-out property <image> image_heatmap <=> Store.image_heatmap;

    in-out property <int> compare_mode <=> Store.compare_mode;
    in-out property <float> wipe_slider_val <=> Store.wipe_slider_val;
    in-out property <float> bg_alpha <=> Store.bg_alpha;

    in-out property <bool> active_r <=> Store.active_r;
    in-out property <bool> active_g <=> Store.active_g;
    in-out property <bool> active_b <=> Store.active_b;
    in-out property <bool> active_a <=> Store.active_a;

    in-out property <int> active_mip_level <=> Store.active_mip_level;
    in-out property <int> max_available_mips <=> Store.max_available_mips;

    in-out property <bool> flicker_show_duplicate <=> Store.flicker_show_duplicate;
    in-out property <float> flicker_interval_val <=> Store.flicker_interval_val;
    in-out property <image> histogram_image <=> Store.histogram_image;

    in-out property <bool> qc_mode <=> Store.qc_mode;
    in-out property <bool> qc_npot <=> Store.qc_npot;
    in-out property <bool> qc_mipmaps <=> Store.qc_mipmaps;
    in-out property <bool> qc_block_align <=> Store.qc_block_align;
    in-out property <bool> qc_bit_depth <=> Store.qc_bit_depth;
    in-out property <bool> qc_solid_colors <=> Store.qc_solid_colors;
    in-out property <bool> qc_normals <=> Store.qc_normals;
    in-out property <string> qc_normals_tags <=> Store.qc_normals_tags;

    in-out property <int> search_method <=> Store.search_method;
    in-out property <int> execution_provider <=> Store.execution_provider;

    in-out property <bool> results_grid_mode <=> Store.results_grid_mode;
    in-out property <[ResultsRow]> selected_group_files <=> Store.selected_group_files;
    in-out property <[ResultsRow]> results <=> Store.results;
    in-out property <[GridRow]> grid_row_results <=> Store.grid_row_results;

    in-out property <string> results_search_query <=> Store.results_search_query;
    in-out property <float> results_min_similarity <=> Store.results_min_similarity;
    in-out property <int> results_sort_index <=> Store.results_sort_index;

    in-out property <string> active_sort_column <=> Store.active_sort_column;
    in-out property <bool> sort_ascending <=> Store.sort_ascending;

    in-out property <bool> enable_previews <=> Store.enable_previews;
    in-out property <int> preview_quality <=> Store.preview_quality;
    in-out property <bool> filter_only_npot <=> Store.filter_only_npot;
    in-out property <bool> filter_only_uncompressed <=> Store.filter_only_uncompressed;
    in-out property <bool> filter_only_missing_mips <=> Store.filter_only_missing_mips;
    in-out property <bool> filter_only_cubemaps <=> Store.filter_only_cubemaps;

    in-out property <string> console_log <=> Store.console_log;
    in-out property <string> context_hovered_path <=> Store.context_hovered_path;

    // --- POPUPS INSTANTIATION ---
    skipped_popup := SkippedFilesPopup { }

    context_popup := ContextMenuPopup { }

    ext_popup := FileFormatsPopup { }

    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        // TOP NAVIGATION TABS
        HorizontalLayout {
            spacing: 4px;
            height: 32px;
            TabButton {
                text: "Find";
                active: Store.active_tab == 0;
                clicked => { Store.active_tab = 0; }
            }

            TabButton {
                text: "Compare";
                active: Store.active_tab == 1;
                clicked => { Store.active_tab = 1; }
            }

            TabButton {
                text: "Log";
                active: Store.active_tab == 2;
                clicked => { Store.active_tab = 2; }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            background: #1e1f22;

            // ================== TAB 0: FIND ==================
            if Store.active_tab == 0: HorizontalLayout {
                spacing: 0px;
                width: 100%;
                height: 100%;

                // ENCAPSULATED FIND CONFIGURATION SIDEBAR
                FindSidebar {
                    // Corrected child-to-parent callback routing
                    show_formats_popup => {
                        ext_popup.show();
                    }
                }

                // SIDEBAR SPLITTER
                Rectangle {
                    width: 8px;
                    horizontal-stretch: 0;
                    background: sidebar-splitter-ta.has-hover ? #4e5058 : #1e1f22;
                    Rectangle {
                        width: 2px;
                        height: 20px;
                        background: #6d6f78;
                        border-radius: 1px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }

                    sidebar-splitter-ta := TouchArea {
                        mouse-cursor: MouseCursor.col-resize;
                        moved => { if (self.pressed) { Store.sidebar_width = (self.x + self.mouse-x - self.pressed-x).clamp(320px, 600px); } }
                    }
                }

                // MAIN RESULTS PANEL
                VerticalLayout {
                    padding-left: 12px;
                    horizontal-stretch: 1;
                    spacing: 8px;
                    VerticalLayout {
                        spacing: 8px;
                        vertical-stretch: 1;

                        // RESULTS HEADER CONTROLS
                        HorizontalLayout {
                            alignment: space-between;
                            HorizontalLayout {
                                spacing: 12px;
                                Text {
                                    text: "Results (" + Store.results.length + " items)";
                                    font-size: 14px;
                                    font-weight: 700;
                                    color: #ffffff;
                                    vertical-alignment: center;
                                }

                                LineEdit {
                                    text <=> Store.results_search_query;
                                    placeholder-text: "Filter by name...";
                                    height: 24px;
                                    width: 130px;
                                    edited => { Store.results_filter_changed(); }
                                }

                                ComboBox {
                                    model: Store.search_method == 3 ? ["By Format Type", "By Size on Disk", "By Filename"] : ["By Duplicate Count", "By Size on Disk", "By Filename"];
                                    current-index <=> Store.results_sort_index;
                                    height: 24px;
                                    width: 145px;
                                    selected(val) => { Store.results_sort_changed(Store.results_sort_index); }
                                }

                                // Conditionally render expand/collapse only when in List Mode and when results exist [1]
                                if !Store.results_grid_mode && Store.has_results: CustomButton {
                                    text: "Expand All";
                                    height: 24px;
                                    primary-color: #4e5058; // Secondary neutral styling
                                    clicked => { Store.expand_all_groups(); }
                                }

                                if !Store.results_grid_mode && Store.has_results: CustomButton {
                                    text: "Collapse All";
                                    height: 24px;
                                    primary-color: #4e5058; // Secondary neutral styling
                                    clicked => { Store.collapse_all_groups(); }
                                }

                                // Columns resizing utility buttons
                                if Store.has_results: CustomButton {
                                    text: "Auto Cols";
                                    height: 24px;
                                    primary-color: #4e5058; // Secondary neutral styling
                                    clicked => { Store.auto_size_columns(); }
                                }

                                if Store.has_results: CustomButton {
                                    text: "Reset Cols";
                                    height: 24px;
                                    primary-color: #4e5058; // Secondary neutral styling
                                    clicked => { Store.reset_size_columns(); }
                                }

                                // Integrated missing Export CSV Button [2]
                                if Store.has_results: CustomButton {
                                    text: "Export CSV";
                                    height: 24px;
                                    primary-color: #0e639c; // Muted steel blue for exports
                                    clicked => { Store.export_csv(); }
                                }

                                if Store.search_method == 2: HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "Min Sim:";
                                        vertical-alignment: center;
                                        font-size: 12px;
                                        color: #dcddde;
                                    }

                                    Slider {
                                        value <=> Store.results_min_similarity;
                                        minimum: 0.0;
                                        maximum: 100.0;
                                        width: 80px;
                                        height: 24px;
                                        changed(val) => { Store.results_filter_changed(); }
                                    }

                                    Text {
                                        text: Math.round(Store.results_min_similarity) + "%";
                                        vertical-alignment: center;
                                        font-size: 12px;
                                        color: #ffffff;
                                        width: 35px;
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                if Store.skipped_files_list.length > 0: CustomButton {
                                    text: "⚠️ Skipped Files (" + Store.skipped_files_list.length + ")";
                                    primary-color: #f23f43;
                                    height: 24px;
                                    clicked => { Store.skipped_popup_x = self.absolute-position.x - 120px; Store.skipped_popup_y = self.absolute-position.y + self.height; skipped_popup.show(); }
                                }
                                CustomButton {
                                    text: Store.results_grid_mode ? "List Mode" : "Grid Mode";
                                    icon-type: Store.results_grid_mode ? 2 : 3; // Swapped dynamically between Vector List and Grid
                                    height: 24px;
                                    clicked => { Store.results_grid_mode = !Store.results_grid_mode; }
                                }
                            }
                        }

                        // SMART FILTER CHECKS - Bound to has_results, keeping filters persistently visible [1]
                        if Store.has_results: HorizontalLayout {
                            spacing: 12px;
                            padding-left: 4px;
                            padding-bottom: 4px;
                            alignment: start;
                            Text {
                                text: "Smart Filters:";
                                vertical-alignment: center;
                                font-size: 12px;
                                color: #949ba4;
                            }

                            CheckBox {
                                text: "NPOT Only";
                                checked <=> Store.filter_only_npot;
                                toggled => { Store.results_filter_changed(); }
                            }

                            CheckBox {
                                text: "Uncompressed Only";
                                checked <=> Store.filter_only_uncompressed;
                                toggled => { Store.results_filter_changed(); }
                            }

                            CheckBox {
                                text: "Missing Mips Only";
                                checked <=> Store.filter_only_missing_mips;
                                toggled => { Store.results_filter_changed(); }
                            }

                            CheckBox {
                                text: "Cubemaps Only";
                                checked <=> Store.filter_only_cubemaps;
                                toggled => { Store.results_filter_changed(); }
                            }
                        }

                        // VIRTUALIZED SCROLL CONTENT
                        Rectangle {
                            border-color: #1f2023;
                            border-width: 1px;
                            background: #2b2d31;
                            border-radius: 4px;
                            vertical-stretch: 1;
                            clip: true;

                            VerticalLayout {
                                if !Store.results_grid_mode && Store.results.length > 0: TableHeader { }
                                if !Store.results_grid_mode && Store.results.length > 0: ListView {
                                    for row[idx] in Store.results: ListRow {
                                        row-data: row; // Cleaned parameter mapping to updated components
                                        row_clicked(is_header, grp_idx, pth) => { Store.row_clicked(idx, is_header, grp_idx, pth); if !is_header { Store.active_tab = 1; } }
                                        checkbox_toggled() => { Store.row_checkbox_toggled(idx); }
                                        right_clicked(mx, my) => { Store.context_hovered_path = row.path; Store.menu_x = mx; Store.menu_y = my; context_popup.show(); }
                                        channel_hovered(pth, chan) => { Store.thumbnail_channel_hovered(pth, chan); }
                                    }
                                }
                                if Store.results_grid_mode && Store.grid_row_results.length > 0: ListView {
                                    for row in Store.grid_row_results: HorizontalLayout {
                                        spacing: 12px;
                                        padding: 10px;
                                        alignment: start;
                                        if row.has-col1: GridCard {
                                            row-data: row.col1;
                                            checkerboard: Store.checkerboard_pattern;
                                            width: Store.grid_card_size;
                                            height: Store.grid_card_size + 45px;
                                            clicked => { Store.row_clicked(-1, false, row.col1.group_index, row.col1.path); Store.active_tab = 1; }
                                            right_clicked(mx, my) => { Store.context_hovered_path = row.col1.path; Store.menu_x = mx; Store.menu_y = my; context_popup.show(); }
                                            channel_hovered(path, chan) => { Store.thumbnail_channel_hovered(path, chan); }
                                        }
                                        if row.has-col2: GridCard {
                                            row-data: row.col2;
                                            checkerboard: Store.checkerboard_pattern;
                                            width: Store.grid_card_size;
                                            height: Store.grid_card_size + 45px;
                                            clicked => { Store.row_clicked(-1, false, row.col2.group_index, row.col2.path); Store.active_tab = 1; }
                                            right_clicked(mx, my) => { Store.context_hovered_path = row.col2.path; Store.menu_x = mx; Store.menu_y = my; context_popup.show(); }
                                            channel_hovered(path, chan) => { Store.thumbnail_channel_hovered(path, chan); }
                                        }
                                    }
                                }

                                // Scenario 1: Initial state before any scans are performed
                                if !Store.has_results: VerticalLayout {
                                    alignment: center;
                                    spacing: 12px;
                                    Text {
                                        text: "No duplicate assets loaded. Choose scan parameters in the left pane and begin auditing.";
                                        color: #7c808a;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }

                                // Scenario 2: Active scan exists, but user filters completely cleared the view [1]
                                if Store.has_results && Store.results.length == 0: VerticalLayout {
                                    alignment: center;
                                    spacing: 12px;
                                    Text {
                                        text: "No results match your active smart filters or search query.";
                                        color: #7c808a;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }

                    // SELECTION CONTROL PANELS
                    Rectangle {
                        background: #2b2d31;
                        border-color: #1f2023;
                        border-width: 1px;
                        border-radius: 4px;
                        height: 56px;
                        VerticalLayout {
                            padding: 8px;
                            spacing: 4px;
                            Text {
                                text: "Selection Rules";
                                font-size: 12px;
                                font-weight: 700;
                                color: #949ba4;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                CustomButton {
                                    text: "Select All";
                                    primary-color: #4e5058;
                                    clicked => { Store.trigger_selection_rule("all"); }
                                }

                                CustomButton {
                                    text: "Deselect All";
                                    primary-color: #4e5058;
                                    clicked => { Store.trigger_selection_rule("none"); }
                                }

                                CustomButton {
                                    text: "Select All Except Best";
                                    primary-color: #4e5058;
                                    clicked => { Store.trigger_selection_rule("except_best"); }
                                }

                                CustomButton {
                                    text: "Invert Selection";
                                    primary-color: #4e5058;
                                    clicked => { Store.trigger_selection_rule("invert"); }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        height: 24px;
                        CustomButton {
                            text: "Replace with Hardlink";
                            primary-color: #5865f2;
                            clicked => { Store.trigger_action("hardlink"); }
                        }

                        CustomButton {
                            text: "Replace with Reflink";
                            primary-color: #5865f2;
                            clicked => { Store.trigger_action("reflink"); }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        CustomButton {
                            text: "Move to Trash";
                            primary-color: #f23f43;
                            clicked => { Store.trigger_action("trash"); }
                        }
                    }
                }
            }

            // ================== TAB 1: COMPARE ==================
            if Store.active_tab == 1: HorizontalLayout {
                spacing: 0px;
                width: 100%;
                height: 100%;
                VerticalLayout {
                    horizontal-stretch: 1;
                    padding-right: 12px;
                    spacing: 12px;
                    Text {
                        text: "Interactive Compare Viewport";
                        font-size: 15px;
                        font-weight: 700;
                        color: #ffffff;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        height: 28px;
                        ComboBox {
                            model: [
                                "Side-by-Side",
                                "Wipe Mode",
                                "Overlay Blend",
                                "Difference Heatmap",
                                "Flicker Mode"
                            ];
                            current-index <=> Store.compare_mode;
                            width: 160px;
                            selected(val) => { Store.compare_mode_changed(); }
                        }

                        if Store.compare_mode == 1 || Store.compare_mode == 2: HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "Wipe Shift:";
                                vertical-alignment: center;
                                font-size: 12px;
                                color: #dcddde;
                            }

                            Slider {
                                value <=> Store.wipe_slider_val;
                                minimum: 0.0;
                                maximum: 1.0;
                                height: 24px;
                            }
                        }
                        if Store.compare_mode == 4: HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "Flicker Speed:";
                                vertical-alignment: center;
                                font-size: 12px;
                                color: #dcddde;
                            }

                            Slider {
                                value <=> Store.flicker_interval_val;
                                minimum: 50;
                                maximum: 1000;
                                height: 24px;
                            }

                            Text {
                                text: Math.round(Store.flicker_interval_val) + "ms";
                                vertical-alignment: center;
                                font-size: 11px;
                                color: #ffffff;
                                width: 45px;
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            width: 180px;
                            Text {
                                text: "Mip Level:";
                                vertical-alignment: center;
                                font-size: 12px;
                                color: Store.max_available_mips > 1 ? #dcddde : #555555;
                            }

                            SpinBox {
                                value: Store.active_mip_level;
                                minimum: 0;
                                maximum: Store.max_available_mips > 1 ? Store.max_available_mips - 1 : 0;
                                height: 24px;
                                width: 100px;
                                enabled: Store.max_available_mips > 1;
                                edited(val) => { Store.active_mip_level = val; Store.mip_level_changed(); }
                            }
                        }

                        CheckBox {
                            text: "HDR";
                            checked <=> Store.tonemap_enabled;
                            height: 24px;
                            toggled => { Store.tonemap_toggled(); }
                        }

                        if Store.tonemap_enabled: ComboBox {
                            model: ["ACES Filmic", "ICtCp Perceptual", "Khronos PBR Neutral"];
                            current-index <=> Store.tonemap_operator;
                            height: 24px;
                            width: 165px;
                            selected(val) => { Store.tonemap_toggled(); }
                        }
                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        CustomButton {
                            text: "Reset Zoom";
                            height: 24px;
                            primary-color: #4e5058;
                            clicked => { Store.zoom_factor = 1.0; Store.pan_x = 0px; Store.pan_y = 0px; }
                        }
                    }

                    // ENCAPSULATED COMPARISON VIEWPORT
                    InteractiveCompareViewport { }

                    HorizontalLayout {
                        spacing: 6px;
                        height: 28px;
                        alignment: center;
                        ChannelButton {
                            text: "R";
                            active-color: #f23f43;
                            active <=> Store.active_r;
                            clicked => { Store.active_r = !Store.active_r; if Store.active_r { Store.active_g = false; Store.active_b = false; Store.active_a = false; } Store.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "G";
                            active-color: #23a55a;
                            active <=> Store.active_g;
                            clicked => { Store.active_g = !Store.active_g; if Store.active_g { Store.active_r = false; Store.active_b = false; Store.active_a = false; } Store.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "B";
                            active-color: #5865f2;
                            active <=> Store.active_b;
                            clicked => { Store.active_b = !Store.active_b; if Store.active_b { Store.active_r = false; Store.active_g = false; Store.active_a = false; } Store.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "A";
                            active-color: #ffffff;
                            text-color: #000000;
                            active <=> Store.active_a;
                            clicked => { Store.active_a = !Store.active_a; if Store.active_a { Store.active_r = false; Store.active_g = false; Store.active_b = false; } Store.channel_toggled(); }
                        }
                    }
                }

                // SPLITTER
                Rectangle {
                    width: 8px;
                    horizontal-stretch: 0;
                    background: compare-splitter-ta.has-hover ? #4e5058 : #1e1f22;
                    Rectangle {
                        width: 2px;
                        height: 20px;
                        background: #6d6f78;
                        border-radius: 1px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }

                    compare-splitter-ta := TouchArea {
                        mouse-cursor: MouseCursor.col-resize;
                        moved => { if (self.pressed) { Store.compare_sidebar_width = (Store.compare_sidebar_width + self.pressed-x - self.mouse-x).clamp(380px, 800px); } }
                    }
                }

                // COMPARISON SIDEBAR
                VerticalLayout {
                    width: Store.compare_sidebar_width;
                    padding-left: 12px;
                    spacing: 12px;
                    Text {
                        text: "Group Duplicates (" + Store.selected_group_files.length + " items)";
                        font-size: 13px;
                        font-weight: 700;
                        color: #949ba4;
                    }

                    Rectangle {
                        height: Store.duplicates_panel_height;
                        background: #111214;
                        border-color: #1f2023;
                        border-width: 1px;
                        border-radius: 4px;
                        if Store.selected_group_files.length > 0: ListView {
                            for row[idx] in Store.selected_group_files: Rectangle {
                                height: 38px;
                                background: (row.path == Store.duplicate_meta.path) ? #2c3e50 : (right_row_ta.has-hover ? #393c41 : #111214);
                                border-radius: 4px;
                                right_row_ta := TouchArea {
                                    x: 46px;
                                    width: parent.width - self.x;
                                    height: 100%;
                                    clicked => { Store.row_clicked(idx, false, row.group_index, row.path); }
                                }

                                HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    spacing: 8px;
                                    alignment: space-between;
                                    InteractiveThumbnail {
                                        source: row.thumbnail;
                                        path: row.path;
                                        show_corners: true;
                                        checkerboard: Store.checkerboard_pattern;
                                        width: 32px;
                                        height: 32px;
                                        corner_hovered(path, chan) => { Store.thumbnail_channel_hovered(path, chan); }
                                        clicked => { Store.row_clicked(idx, false, row.group_index, row.path); }
                                    }

                                    Text {
                                        text: row.name;
                                        color: #dcddde;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }

                                    Text {
                                        text: row.is_best ? "[Best]" : row.score_or_detail;
                                        color: row.is_best ? #f0b132 : #dcddde;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 8px;
                        vertical-stretch: 0;
                        background: splitter-ta.has-hover ? #4e5058 : #2b2d31;
                        border-radius: 4px;
                        Rectangle {
                            width: 20px;
                            height: 2px;
                            background: #6d6f78;
                            border-radius: 1px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }

                        splitter-ta := TouchArea {
                            mouse-cursor: row-resize;
                            moved => { if (self.pressed) { Store.duplicates_panel_height = (self.y + self.mouse-y - self.pressed-y).clamp(80px, 450px); } }
                        }
                    }

                    Text {
                        text: "Luminance Histogram Comparison";
                        font-size: 13px;
                        font-weight: 700;
                        color: #949ba4;
                    }

                    Rectangle {
                        height: 130px;
                        background: #111214;
                        border-color: #1f2023;
                        border-width: 1px;
                        border-radius: 4px;
                        clip: true;
                        Image {
                            source: Store.histogram_image;
                            width: 100%;
                            height: 100%;
                            image-fit: contain;
                        }
                    }

                    Text {
                        text: "Comparison Specifications Matrix";
                        font-size: 13px;
                        font-weight: 700;
                        color: #949ba4;
                    }

                    Rectangle {
                        border-color: #1f2023;
                        border-width: 1px;
                        background: #111214;
                        border-radius: 4px;
                        vertical-stretch: 1;
                        ScrollView {
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                HorizontalLayout {
                                    spacing: 8px; // Added spacing [1]
                                    Text {
                                        text: "Specification";
                                        width: 130px; // Proportional column alignment [1]
                                        font-weight: 700;
                                        color: #949ba4;
                                        font-size: 12px;
                                    }

                                    Rectangle {
                                        width: 1px;
                                        background: transparent; // Header spacer matching row divider [2]
                                    }

                                    Text {
                                        text: "Original [Best]";
                                        font-weight: 700;
                                        color: #f0b132;
                                        font-size: 12px;
                                        horizontal-stretch: 1; // Elastic stretch [1]
                                    }

                                    Rectangle {
                                        width: 1px;
                                        background: transparent; // Header spacer matching row divider [2]
                                    }

                                    Text {
                                        text: "Duplicate";
                                        font-weight: 700;
                                        color: #dcddde;
                                        font-size: 12px;
                                        horizontal-stretch: 1; // Elastic stretch [1]
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: #1f2023;
                                    vertical-stretch: 0;
                                }

                                SpecsRow {
                                    name: "File Name";
                                    val1: Store.original_meta.name;
                                    val2: Store.duplicate_meta.name;
                                }

                                SpecsRow {
                                    name: "File Size";
                                    val1: Store.original_meta.size_str;
                                    val2: Store.duplicate_meta.size_str;
                                }

                                SpecsRow {
                                    name: "Format / Codec";
                                    val1: Store.original_meta.format;
                                    val2: Store.duplicate_meta.format;
                                }

                                SpecsRow {
                                    name: "Resolution";
                                    val1: Store.original_meta.resolution;
                                    val2: Store.duplicate_meta.resolution;
                                }

                                SpecsRow {
                                    name: "Bit Depth";
                                    val1: Store.original_meta.bit_depth;
                                    val2: Store.duplicate_meta.bit_depth;
                                }

                                SpecsRow {
                                    name: "Color Space";
                                    val1: Store.original_meta.color_space;
                                    val2: Store.duplicate_meta.color_space;
                                }

                                SpecsRow {
                                    name: "Mipmaps";
                                    val1: Store.original_meta.mipmaps;
                                    val2: Store.duplicate_meta.mipmaps;
                                }

                                SpecsRow {
                                    name: "Alpha Channel";
                                    val1: Store.original_meta.alpha;
                                    val2: Store.duplicate_meta.alpha;
                                }

                                SpecsRow {
                                    name: "Similarity";
                                    val1: "100.0%";
                                    val2: Store.duplicate_meta.similarity;
                                }

                                Rectangle {
                                    height: 1px;
                                    background: #1f2023;
                                    vertical-stretch: 0;
                                }

                                SpecsRow {
                                    name: "Full Path";
                                    val1: Store.original_meta.path;
                                    val2: Store.duplicate_meta.path;
                                }

                                Rectangle {
                                    vertical-stretch: 1;
                                }
                            }
                        }
                    }
                }
            }

            // ================== TAB 2: LOG ==================
            if Store.active_tab == 2: VerticalLayout {
                padding: 15px;
                spacing: 10px;
                width: 100%;
                height: 100%;
                Text {
                    text: "System Console Logs & Compiler Diagnostics";
                    font-weight: 700;
                    font-size: 14px;
                    color: #ffffff;
                }

                TextEdit {
                    text <=> Store.console_log;
                    read-only: true;
                    font-family: "Consolas";
                    font-size: 12px;
                    vertical-stretch: 1;
                    wrap: TextWrap.word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    CustomButton {
                        text: "Export Log Output...";
                        primary-color: #0e639c;
                        clicked => { Store.export_log(Store.console_log); }
                    }

                    CustomButton {
                        text: "Clear Console Buffer";
                        primary-color: #3a3a3a;
                        clicked => { Store.console_log = "Buffer cleared."; }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }
                }
            }
        }

        // FIXED BOTTOM SCANNING STATUS BANNER
        if Store.is_scanning: Rectangle {
            background: #2b2d31;
            border-radius: 4px;
            border-color: #1f2023;
            border-width: 1px;
            height: 48px;
            HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text {
                    text: Store.status_text;
                    color: #dcddde;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 250px;
                    overflow: elide;
                }

                ProgressIndicator {
                    progress: Store.progress;
                    horizontal-stretch: 1;
                    height: 16px;
                }

                Text {
                    text: Math.round(Store.progress * 100) + "%";
                    color: #ffffff;
                    font-weight: 700;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 40px;
                }
            }
        }
    }
}
