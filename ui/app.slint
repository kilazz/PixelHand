// ui/app.slint

import {
    ProgressIndicator,
    Palette,
} from "std-widgets.slint";

import { ResultsRow, SelectedFile, GridRow } from "./structs.slint";
export { ResultsRow, SelectedFile, GridRow }from "./structs.slint";

import { Store } from "./store.slint";
export { Store }
import { TabButton } from "./components/buttons.slint";

// IMPORT CUSTOM POPUPS
import { SkippedFilesPopup } from "./components/skipped_popup.slint";
import { ContextMenuPopup } from "./components/context_menu.slint";
import { FileFormatsPopup } from "./components/file_formats_popup.slint";

// IMPORT MODULAR TABS
import { FindTab } from "./tabs/find_tab.slint";
import { CompareTab } from "./tabs/compare_tab.slint";
import { LogTab } from "./tabs/log_tab.slint";

export component AppWindow inherits Window {
    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    title: "PixelHand - AI Duplicate & Graphical QC Auditor";
    preferred-width: 1320px;
    preferred-height: 880px;
    min-width: 1000px;
    min-height: 700px;
    background: #1e1e1e;

    // --- ADAPTIVE GRID BEHAVIOR ---
    property <int> calc_cols: Math.max(1, Math.round(Math.floor((self.width - Store.sidebar_width - 40px) / (Store.grid_card_size + 12px))));
    changed calc_cols => {
        Store.grid_columns = self.calc_cols;
        Store.grid_columns_changed();
    }

    skipped_popup := SkippedFilesPopup { }

    context_popup := ContextMenuPopup { }

    ext_popup := FileFormatsPopup { }

    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        // TOP NAVIGATION TABS
        HorizontalLayout {
            spacing: 4px;
            alignment: start;
            height: 32px;
            TabButton {
                text: "Find";
                active: Store.active_tab == 0;
                clicked => { Store.active_tab = 0; }
            }

            TabButton {
                text: "Compare";
                active: Store.active_tab == 1;
                clicked => { Store.active_tab = 1; }
            }

            TabButton {
                text: "Log";
                active: Store.active_tab == 2;
                clicked => { Store.active_tab = 2; }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            background: #1e1e1e;

            // ================== TAB 0: FIND ==================
            if Store.active_tab == 0: FindTab {
                show_formats_popup => {
                    ext_popup.show();
                }
                show_skipped_popup(x_pos, y_pos) => {
                    Store.skipped_popup_x = x_pos;
                    Store.skipped_popup_y = y_pos;
                    skipped_popup.show();
                }
                show_context_menu(x_pos, y_pos, path) => {
                    Store.context_hovered_path = path;
                    Store.menu_x = x_pos;
                    Store.menu_y = y_pos;
                    context_popup.show();
                }
            }

            // ================== TAB 1: COMPARE ==================
            if Store.active_tab == 1: CompareTab { }

            // ================== TAB 2: LOG ==================
            if Store.active_tab == 2: LogTab { }
        }

        // FIXED BOTTOM SCANNING STATUS BANNER
        if Store.is_scanning: Rectangle {
            background: #2d2d2d;
            border-radius: 4px;
            border-color: #353535;
            border-width: 1px;
            height: 48px;
            HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text {
                    text: Store.status_text;
                    color: #cfcfcf;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 250px;
                    overflow: elide;
                }

                ProgressIndicator {
                    progress: Store.progress;
                    horizontal-stretch: 1;
                    height: 16px;
                }

                Text {
                    text: Math.round(Store.progress * 100) + "%";
                    color: #ffffff;
                    font-weight: 700;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 40px;
                }
            }
        }
    }
}
