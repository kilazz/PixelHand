// ui/app.slint

import {
    ListView,
    CheckBox,
    TextEdit,
    LineEdit,
    SpinBox,
    ComboBox,
    ScrollView,
    ProgressIndicator,
    Palette,
    Slider,
} from "std-widgets.slint";

// IMPORT COMPONENTS WITH CORRECT RELATIVE PATHS
import { ResultsRow, SelectedFile, GridRow } from "./structs.slint";
export { ResultsRow, SelectedFile, GridRow }from "./structs.slint";
import {
    MenuItem,
    TabButton,
    ChannelButton,
    CustomButton,
} from "./components/buttons.slint";
import { InteractiveThumbnail } from "./components/thumbnail.slint";
import {
    FormRow,
    SpecsRow,
    SectionTitle,
    PanelSection,
    WipeViewport,
} from "./components/common.slint";
import { GridCard } from "./components/grid_card.slint";

export component AppWindow inherits Window {
    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    title: "PixelHand - AI Duplicate & Graphical QC Auditor";

    preferred-width: 1320px;
    preferred-height: 880px;
    min-width: 1000px;
    min-height: 700px;

    background: #1e1f22;

    // --- STATE PROPERTIES ---
    in-out property <int> active_tab: 0;

    in-out property <bool> tonemap_enabled: true;
    in-out property <int> tonemap_operator: 0;

    in-out property <string> dir_a: "";
    in-out property <string> dir_b: "";
    in-out property <string> query_text: "";
    in-out property <float> similarity_threshold: 90;
    in-out property <int> batch_size: 128;
    in-out property <bool> is_scanning: false;
    in-out property <float> progress: 0.0;
    in-out property <string> status_text: "System Ready. Drop images or write path.";

    // Active file format selections
    in-out property <bool> ext_png: true;
    in-out property <bool> ext_jpg: true;
    in-out property <bool> ext_tga: true;
    in-out property <bool> ext_dds: true;
    in-out property <bool> ext_bmp: true;
    in-out property <bool> ext_exr: true;
    in-out property <bool> ext_hdr: true;
    in-out property <bool> ext_tif: true;
    in-out property <bool> ext_webp: true;
    in-out property <bool> ext_gif: true;
    in-out property <bool> ext_psd: true;
    in-out property <bool> ext_jxl: true;
    in-out property <bool> ext_heic: true;
    in-out property <bool> ext_avif: true;

    // Visual Reports (Contact Sheets) Settings
    in-out property <bool> save_visuals: false;
    in-out property <int> visuals_columns: 6;
    in-out property <int> visuals_max_count: 100;
    in-out property <int> visuals_font_size: 14;
    in-out property <float> visuals_scale: 1.5;

    // Image Pre-processing Options
    in-out property <bool> prep_luminance: false;
    in-out property <bool> prep_channels: false;
    in-out property <bool> prep_r: true;
    in-out property <bool> prep_g: true;
    in-out property <bool> prep_b: true;
    in-out property <bool> prep_a: true;
    in-out property <string> prep_tags: "";
    in-out property <bool> prep_ignore_solid: true;

    // Collapsible advanced options trigger
    in-out property <bool> show_advanced: false;

    // Viewport pan/zoom
    in-out property <float> zoom_factor: 1.0;
    in-out property <length> pan_x: 0px;
    in-out property <length> pan_y: 0px;

    // Excluded Folders List
    in-out property <string> excluded_folders: ".git, .svn, cache, temp";
    in-out property <bool> qc_match_by_stem: true;
    in-out property <bool> qc_hide_same_resolution: false;

    // Relative Quality Control parameters
    in-out property <bool> qc_check_bloat: true;
    in-out property <bool> qc_check_alpha: true;
    in-out property <bool> qc_check_colorspace: true;
    in-out property <bool> qc_check_compression: true;

    // Search precision and active model
    in-out property <int> search_precision: 1;
    in-out property <int> ai_model: 0;
    in-out property <string> custom_model_path: "";
    in-out property <int> custom_model_arch: 0;
    in-out property <int> custom_model_dim: 512;

    in-out property <[string]> skipped_files_list: [];
    in-out property <length> skipped_popup_x: 0px;
    in-out property <length> skipped_popup_y: 0px;

    // --- COLS WIDTH PROPERTIES ---
    in-out property <length> col_file_w: 300px;
    in-out property <length> col_score_w: 70px;
    in-out property <length> col_path_w: 350px;
    in-out property <length> list_preview_size: 40px;

    // Widths for Audit Columns
    in-out property <length> col_format_w: 110px;
    in-out property <length> col_dimensions_w: 110px;
    in-out property <length> col_mipmaps_w: 75px;
    in-out property <length> col_cubemap_w: 75px;
    in-out property <length> col_size_w: 85px;

    in-out property <length> duplicates_panel_height: 180px;
    in-out property <length> sidebar_width: 380px;
    in-out property <length> compare_sidebar_width: 440px;
    in-out property <length> grid_card_size: 135px;
    in-out property <image> checkerboard_pattern;

    in-out property <SelectedFile> original_meta: {
        name: "-",
        size_str: "-",
        format: "-",
        resolution: "-",
        bit_depth: "-",
        color_space: "-",
        mipmaps: "-",
        alpha: "-",
        similarity: "-",
        path: ""
    };
    in-out property <SelectedFile> duplicate_meta: {
        name: "-",
        size_str: "-",
        format: "-",
        resolution: "-",
        bit_depth: "-",
        color_space: "-",
        mipmaps: "-",
        alpha: "-",
        similarity: "-",
        path: ""
    };

    in-out property <image> image_original;
    in-out property <image> image_duplicate;
    in-out property <image> image_heatmap;

    in-out property <int> compare_mode: 0;
    in-out property <float> wipe_slider_val: 0.5;
    in-out property <float> bg_alpha: 1.0;

    in-out property <bool> active_r: false;
    in-out property <bool> active_g: false;
    in-out property <bool> active_g_or_r: false;
    in-out property <bool> active_b: false;
    in-out property <bool> active_a: false;

    // Tracking the active mip level selected in the UI
    in-out property <int> active_mip_level: 0;

    // Tracking the maximum available mipmaps for the selected file dynamically
    in-out property <int> max_available_mips: 1;

    in-out property <bool> qc_mode: false;
    in-out property <bool> qc_npot: true;
    in-out property <bool> qc_mipmaps: true;
    in-out property <bool> qc_block_align: true;
    in-out property <bool> qc_bit_depth: true;
    in-out property <bool> qc_solid_colors: true;
    in-out property <bool> qc_normals: true;
    in-out property <string> qc_normals_tags: "";

    in-out property <int> search_method: 0;
    in-out property <int> execution_provider: 0;

    in-out property <bool> results_grid_mode: false;
    in-out property <[ResultsRow]> selected_group_files: [];
    in-out property <[ResultsRow]> results: [];
    in-out property <[GridRow]> grid_row_results: []; // Holds rows of 4 columns for dynamic virtualized ListViews

    in-out property <string> results_search_query: "";
    in-out property <float> results_min_similarity: 0.0;
    in-out property <int> results_sort_index: 0;

    // --- PREVIEW & SMART FILTER PROPERTIES ---
    in-out property <bool> enable_previews: true;
    in-out property <int> preview_quality: 1;
    in-out property <bool> filter_only_npot: false;
    in-out property <bool> filter_only_uncompressed: false;
    in-out property <bool> filter_only_missing_mips: false;
    in-out property <bool> filter_only_cubemaps: false;

    in-out property <string> console_log: "Initializing ONNX Runtime Architecture...\nSystem ready.";

    in-out property <length> ext_popup_x: 0px;
    in-out property <length> ext_popup_y: 0px;
    in-out property <length> menu_x: 0px;
    in-out property <length> menu_y: 0px;
    in-out property <string> context_hovered_path: "";

    // --- CALLBACKS ---
    callback select_folder_a();
    callback select_folder_b();
    callback run_scan();
    callback cancel_scan();
    callback open_file_in_viewer(string);
    callback trigger_action(string);
    callback row_clicked(int, bool, int, string);
    callback row_checkbox_toggled(int);
    callback channel_toggled();
    callback mip_level_changed();
    callback compare_mode_changed();
    callback trigger_selection_rule(string);
    callback save_settings();
    callback tonemap_toggled();
    callback export_log(string);
    callback export_csv();
    callback sort_by_column(string);
    callback expand_all_groups();
    callback collapse_all_groups();
    callback results_filter_changed();
    callback results_sort_changed(int);
    callback clear_cache();
    callback clear_models();
    callback select_custom_model();
    callback auto_size_columns();
    callback context_menu_action(string, string);
    callback thumbnail_channel_hovered(string, string);
    callback select_reference_image();

    // POPUPS
    ext_popup := PopupWindow {
        x: root.ext_popup_x;
        y: root.ext_popup_y;
        width: 480px;
        height: 180px;
        close-policy: close-on-click;
        Rectangle {
            background: #2b2d31;
            border-color: #1f2023;
            border-width: 1px;
            border-radius: 4px;
            VerticalLayout {
                padding: 10px;
                spacing: 8px;
                Text {
                    text: "File Formats Selector";
                    font-weight: 700;
                    color: #ffffff;
                }

                HorizontalLayout {
                    spacing: 12px;
                    VerticalLayout {
                        spacing: 4px;
                        CheckBox {
                            text: ".png";
                            checked <=> root.ext_png;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".jpg / .jpeg";
                            checked <=> root.ext_jpg;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".tga";
                            checked <=> root.ext_tga;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".dds";
                            checked <=> root.ext_dds;
                            toggled => { root.save_settings(); }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        CheckBox {
                            text: ".bmp";
                            checked <=> root.ext_bmp;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".exr";
                            checked <=> root.ext_exr;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".hdr";
                            checked <=> root.ext_hdr;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".tif / .tiff";
                            checked <=> root.ext_tif;
                            toggled => { root.save_settings(); }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        CheckBox {
                            text: ".webp";
                            checked <=> root.ext_webp;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".gif";
                            checked <=> root.ext_gif;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".psd";
                            checked <=> root.ext_psd;
                            toggled => { root.save_settings(); }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        CheckBox {
                            text: ".jxl";
                            checked <=> root.ext_jxl;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".heic / .heif";
                            checked <=> root.ext_heic;
                            toggled => { root.save_settings(); }
                        }

                        CheckBox {
                            text: ".avif";
                            checked <=> root.ext_avif;
                            toggled => { root.save_settings(); }
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                HorizontalLayout {
                    alignment: end;
                    CustomButton {
                        text: "Close";
                        clicked => { ext_popup.close(); }
                    }
                }
            }
        }
    }

    skipped_popup := PopupWindow {
        x: root.skipped_popup_x;
        y: root.skipped_popup_y;
        width: 450px;
        height: 300px;
        close-policy: close-on-click;
        Rectangle {
            background: #2b2d31;
            border-color: #1f2023;
            border-width: 1.5px;
            border-radius: 4px;
            VerticalLayout {
                padding: 12px;
                spacing: 8px;
                Text {
                    text: "Skipped / Corrupted Files List";
                    font-weight: 700;
                    color: #ffffff;
                    font-size: 13px;
                }

                Rectangle {
                    background: #111214;
                    border-radius: 4px;
                    vertical-stretch: 1;
                    clip: true;
                    ListView {
                        width: 100%;
                        height: 100%;
                        for file in root.skipped_files_list: Rectangle {
                            height: 26px;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                Text {
                                    text: file;
                                    color: #dcddde;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    alignment: end;
                    CustomButton {
                        text: "Dismiss";
                        clicked => { skipped_popup.close(); }
                    }
                }
            }
        }
    }

    context_popup := PopupWindow {
        x: root.menu_x;
        y: root.menu_y;
        width: 160px;
        close-policy: close-on-click;
        Rectangle {
            background: #2b2d31;
            border-color: #1f2023;
            border-width: 1px;
            border-radius: 4px;
            VerticalLayout {
                padding: 4px;
                spacing: 2px;
                MenuItem {
                    text: "Open File";
                    clicked => { root.context_menu_action("open", root.context_hovered_path); context_popup.close(); }
                }

                MenuItem {
                    text: "Show in Explorer";
                    clicked => { root.context_menu_action("explore", root.context_hovered_path); context_popup.close(); }
                }

                Rectangle {
                    height: 1px;
                    background: #1f2023;
                }

                MenuItem {
                    text: "Move to Trash";
                    text-color: #f23f43;
                    clicked => { root.context_menu_action("trash", root.context_hovered_path); context_popup.close(); }
                }
            }
        }
    }

    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        HorizontalLayout {
            spacing: 4px;
            height: 32px;
            TabButton {
                text: "Find";
                active: root.active_tab == 0;
                clicked => { root.active_tab = 0; }
            }

            TabButton {
                text: "Compare";
                active: root.active_tab == 1;
                clicked => { root.active_tab = 1; }
            }

            TabButton {
                text: "Log";
                active: root.active_tab == 2;
                clicked => { root.active_tab = 2; }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            background: #1e1f22;

            // ------------------ TAB 0: FIND ------------------
            if root.active_tab == 0: HorizontalLayout {
                spacing: 0px;
                width: 100%;
                height: 100%;

                // ACCORDION SIDEBAR WITH FIXED FOOTER ACTION
                Rectangle {
                    width: root.sidebar_width;
                    background: #2b2d31;
                    border-color: #1f2023;
                    border-width: 1px;
                    border-radius: 4px;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 8px;

                        // Scrollable section for configurations
                        ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                alignment: start;
                                spacing: 12px;

                                PanelSection {
                                    title: "Operation Mode";
                                    ComboBox {
                                        model: [
                                            "Exact Match (xxHash)",
                                            "Simple Duplicates (dHash)",
                                            "AI Semantic/Visual Search",
                                            "Asset Inventory (Detailed Audit)",
                                            "Technical QC Audit"
                                        ];
                                        current-index <=> root.search_method;
                                        height: 32px;
                                        selected(val) => {
                                            root.qc_mode = root.search_method == 4;
                                            root.save_settings();
                                        }
                                    }
                                }

                                PanelSection {
                                    title: "Target Directories";
                                    VerticalLayout {
                                        spacing: 4px;
                                        FormRow {
                                            title: "Folder A:";
                                            HorizontalLayout {
                                                spacing: 4px;
                                                LineEdit {
                                                    text <=> root.dir_a;
                                                    height: 32px;
                                                    placeholder-text: "Source folder...";
                                                    horizontal-stretch: 1;
                                                    edited => { root.save_settings(); }
                                                }

                                                CustomButton {
                                                    text: "...";
                                                    width: 32px;
                                                    height: 32px;
                                                    clicked => { root.select_folder_a(); }
                                                }
                                            }
                                        }

                                        if root.search_method == 4: FormRow {
                                            title: "Folder B:";
                                            HorizontalLayout {
                                                spacing: 4px;
                                                LineEdit {
                                                    text <=> root.dir_b;
                                                    height: 32px;
                                                    placeholder-text: "Comparison folder...";
                                                    horizontal-stretch: 1;
                                                    edited => { root.save_settings(); }
                                                }

                                                CustomButton {
                                                    text: "...";
                                                    width: 32px;
                                                    height: 32px;
                                                    clicked => { root.select_folder_b(); }
                                                }
                                            }
                                        }
                                        FormRow {
                                            title: "Exclude:";
                                            LineEdit {
                                                text <=> root.excluded_folders;
                                                placeholder-text: "e.g. .cache, previews, temp_files";
                                                height: 22px;
                                                edited => { root.save_settings(); }
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: 6px;
                                            padding-top: 4px;
                                            CustomButton {
                                                text: "File Formats";
                                                height: 32px;
                                                clicked => { root.ext_popup_x = self.absolute-position.x; root.ext_popup_y = self.absolute-position.y + self.height; ext_popup.show(); }
                                            }
                                        }
                                    }
                                }

                                // MODE DRIVEN DYNAMIC CONFIGURATIONS

                                // A. Duplicates Parameters
                                if root.search_method == 0 || root.search_method == 1: PanelSection {
                                    title: "Duplicates Finder Options";
                                    VerticalLayout {
                                        spacing: 4px;
                                        FormRow {
                                            title: "Similarity:";
                                            HorizontalLayout {
                                                spacing: 6px;
                                                Slider {
                                                    value <=> root.similarity_threshold;
                                                    minimum: 50;
                                                    maximum: 100;
                                                    height: 32px;
                                                    changed(val) => { root.save_settings(); }
                                                }

                                                Text {
                                                    text: Math.round(root.similarity_threshold) + "%";
                                                    width: 36px;
                                                    horizontal-alignment: right;
                                                    vertical-alignment: center;
                                                    font-size: 12px;
                                                    color: #ffffff;
                                                }
                                            }
                                        }

                                        CheckBox {
                                            text: "Save Visual Reports";
                                            checked <=> root.save_visuals;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }

                                        if root.save_visuals: VerticalLayout {
                                            spacing: 4px;
                                            padding-left: 8px;
                                            HorizontalLayout {
                                                spacing: 6px;
                                                Text {
                                                    text: "Cols:";
                                                    vertical-alignment: center;
                                                    font-size: 11px;
                                                    color: #dcddde;
                                                    width: 35px;
                                                }

                                                SpinBox {
                                                    value <=> root.visuals_columns;
                                                    minimum: 2;
                                                    maximum: 12;
                                                    height: 32px;
                                                    width: 80px;
                                                    edited(val) => { root.save_settings(); }
                                                }

                                                Text {
                                                    text: "Max:";
                                                    vertical-alignment: center;
                                                    font-size: 11px;
                                                    color: #dcddde;
                                                    width: 35px;
                                                }

                                                SpinBox {
                                                    value <=> root.visuals_max_count;
                                                    minimum: 1;
                                                    maximum: 1000;
                                                    height: 32px;
                                                    width: 90px;
                                                    edited(val) => { root.save_settings(); }
                                                }

                                                Rectangle {
                                                    horizontal-stretch: 1;
                                                }
                                            }

                                            HorizontalLayout {
                                                spacing: 6px;
                                                Text {
                                                    text: "Font:";
                                                    vertical-alignment: center;
                                                    font-size: 11px;
                                                    color: #dcddde;
                                                    width: 35px;
                                                }

                                                SpinBox {
                                                    value <=> root.visuals_font_size;
                                                    minimum: 8;
                                                    maximum: 36;
                                                    height: 32px;
                                                    width: 80px;
                                                    edited(val) => { root.save_settings(); }
                                                }

                                                Text {
                                                    text: "Scale:";
                                                    vertical-alignment: center;
                                                    font-size: 11px;
                                                    color: #dcddde;
                                                    width: 35px;
                                                }

                                                Slider {
                                                    value <=> root.visuals_scale;
                                                    minimum: 1.0;
                                                    maximum: 3.0;
                                                    height: 32px;
                                                    width: 70px;
                                                    changed(val) => { root.save_settings(); }
                                                }

                                                Text {
                                                    text: (Math.round(root.visuals_scale * 10) / 10) + "x";
                                                    width: 30px;
                                                    horizontal-alignment: right;
                                                    vertical-alignment: center;
                                                    font-size: 11px;
                                                    color: #ffffff;
                                                }
                                            }
                                        }
                                        if root.search_method == 1: CheckBox {
                                            text: "Compare by luminance only";
                                            checked <=> root.prep_luminance;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }
                                        if root.search_method == 1: CheckBox {
                                            text: "Compare by specific channels";
                                            checked <=> root.prep_channels;
                                            height: 20px;
                                            toggled => { root.save_settings(); }
                                        }
                                        if root.search_method == 1 && root.prep_channels: VerticalLayout {
                                            spacing: 4px;
                                            padding-left: 12px;
                                            HorizontalLayout {
                                                spacing: 12px;
                                                CheckBox {
                                                    text: "R";
                                                    checked <=> root.prep_r;
                                                    toggled => { root.save_settings(); }
                                                }

                                                CheckBox {
                                                    text: "G";
                                                    checked <=> root.prep_g;
                                                    toggled => { root.save_settings(); }
                                                }

                                                CheckBox {
                                                    text: "B";
                                                    checked <=> root.prep_b;
                                                    toggled => { root.save_settings(); }
                                                }

                                                CheckBox {
                                                    text: "A";
                                                    checked <=> root.prep_a;
                                                    toggled => { root.save_settings(); }
                                                }

                                                Rectangle {
                                                    horizontal-stretch: 1;
                                                }
                                            }

                                            FormRow {
                                                title: "Tags:";
                                                label-width: 40px;
                                                LineEdit {
                                                    text <=> root.prep_tags;
                                                    placeholder-text: "_mask, _ddn";
                                                    height: 32px;
                                                    edited => { root.save_settings(); }
                                                }
                                            }

                                            CheckBox {
                                                text: "Ignore solid channels";
                                                checked <=> root.prep_ignore_solid;
                                                height: 20px;
                                                toggled => { root.save_settings(); }
                                            }
                                        }
                                    }
                                }

                                // B. AI Parameters
                                if root.search_method == 2: PanelSection {
                                    title: "AI Semantic Search Options";
                                    VerticalLayout {
                                        spacing: 4px;
                                        FormRow {
                                            title: "Query AI:";
                                            HorizontalLayout {
                                                spacing: 4px;
                                                LineEdit {
                                                    text <=> root.query_text;
                                                    height: 32px;
                                                    placeholder-text: root.ai_model == 4 ? "Text query disabled for DINOv2-B..." : "Optional text or path...";
                                                    enabled: root.ai_model != 4;
                                                    edited => { root.save_settings(); }
                                                }

                                                CustomButton {
                                                    text: "🖼️";
                                                    width: 32px;
                                                    height: 32px;
                                                    enabled: root.ai_model != 4;
                                                    clicked => { root.select_reference_image(); }
                                                }
                                            }
                                        }

                                        FormRow {
                                            title: "Model:";
                                            ComboBox {
                                                model: [
                                                    "Fastest (CLIP-B/32)",
                                                    "Balanced (CLIP-L/14)",
                                                    "Compact (SigLIP-B)",
                                                    "High Quality (SigLIP-L)",
                                                    "Visual Structure (DINOv2-B)",
                                                    "Custom (Local ONNX)"
                                                ];
                                                current-index <=> root.ai_model;
                                                height: 32px;
                                                selected(val) => { root.save_settings(); }
                                            }
                                        }

                                        if root.ai_model == 5: VerticalLayout {
                                            spacing: 4px;
                                            FormRow {
                                                title: "Local Path:";
                                                HorizontalLayout {
                                                    spacing: 4px;
                                                    LineEdit {
                                                        text <=> root.custom_model_path;
                                                        height: 32px;
                                                        horizontal-stretch: 1;
                                                        edited => { root.save_settings(); }
                                                    }

                                                    CustomButton {
                                                        text: "...";
                                                        width: 32px;
                                                        height: 32px;
                                                        clicked => { root.select_custom_model(); }
                                                    }
                                                }
                                            }

                                            HorizontalLayout {
                                                spacing: 6px;
                                                Text {
                                                    text: "Arch:";
                                                    vertical-alignment: center;
                                                    font-size: 11px;
                                                    color: #dcddde;
                                                    width: 30px;
                                                }

                                                ComboBox {
                                                    model: ["CLIP", "SigLIP", "DINOv2"];
                                                    current-index <=> root.custom_model_arch;
                                                    height: 32px;
                                                    selected(val) => { root.save_settings(); }
                                                }

                                                Text {
                                                    text: "Dim:";
                                                    vertical-alignment: center;
                                                    font-size: 11px;
                                                    color: #dcddde;
                                                    width: 30px;
                                                }

                                                SpinBox {
                                                    value: root.custom_model_dim;
                                                    minimum: 64;
                                                    maximum: 4096;
                                                    height: 32px;
                                                    edited(val) => { root.custom_model_dim = val; root.save_settings(); }
                                                }
                                            }
                                        }
                                    }
                                }

                                // C. Technical QC Audit Parameters
                                if root.search_method == 4: PanelSection {
                                    title: "QC Criteria List";
                                    VerticalLayout {
                                        spacing: 4px;
                                        CheckBox {
                                            text: "Match by stem";
                                            checked <=> root.qc_match_by_stem;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Hide same resolution";
                                            checked <=> root.qc_hide_same_resolution;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check NPOT (Power of 2)";
                                            checked <=> root.qc_npot;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Mip-Maps";
                                            checked <=> root.qc_mipmaps;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check BlockAlignment";
                                            checked <=> root.qc_block_align;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Bit Depth";
                                            checked <=> root.qc_bit_depth;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Solid Colors";
                                            checked <=> root.qc_solid_colors;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Validate Normal Maps";
                                            checked <=> root.qc_normals;
                                            toggled => { root.save_settings(); }
                                        }

                                        if root.qc_normals: LineEdit {
                                            text <=> root.qc_normals_tags;
                                            placeholder-text: "Tags: _norm, _ddn";
                                            height: 32px;
                                            edited => { root.save_settings(); }
                                        }
                                        CheckBox {
                                            text: "Check Size Bloat";
                                            checked <=> root.qc_check_bloat;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Alpha Mismatch";
                                            checked <=> root.qc_check_alpha;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Color Space";
                                            checked <=> root.qc_check_colorspace;
                                            toggled => { root.save_settings(); }
                                        }

                                        CheckBox {
                                            text: "Check Compression Change";
                                            checked <=> root.qc_check_compression;
                                            toggled => { root.save_settings(); }
                                        }
                                    }
                                }

                                // D. Advanced Options
                                PanelSection {
                                    title: "Advanced System Settings";
                                    VerticalLayout {
                                        spacing: 4px;
                                        HorizontalLayout {
                                            alignment: space-between;
                                            Text {
                                                text: "Show Advanced Settings";
                                                font-size: 11px;
                                                color: #dcddde;
                                                vertical-alignment: center;
                                            }

                                            CheckBox {
                                                checked <=> root.show_advanced;
                                            }
                                        }

                                        if root.show_advanced: VerticalLayout {
                                            spacing: 4px;
                                            padding-top: 6px;
                                            FormRow {
                                                title: "Batch Size:";
                                                SpinBox {
                                                    value <=> root.batch_size;
                                                    minimum: 16;
                                                    maximum: 1024;
                                                    height: 32px;
                                                    edited(val) => { root.save_settings(); }
                                                }
                                            }

                                            if root.search_method == 2: FormRow {
                                                title: "LanceDB Prec:";
                                                ComboBox {
                                                    model: ["Fast", "Balanced", "Accurate", "Exhaustive"];
                                                    current-index <=> root.search_precision;
                                                    height: 32px;
                                                    selected(val) => { root.save_settings(); }
                                                }
                                            }
                                            FormRow {
                                                title: "Provider:";
                                                ComboBox {
                                                    model: ["CPU", "DirectML", "CUDA", "TensorRT", "CoreML"];
                                                    current-index <=> root.execution_provider;
                                                    height: 32px;
                                                    selected(val) => { root.save_settings(); }
                                                }
                                            }

                                            CheckBox {
                                                text: "Enable Previews Window";
                                                checked <=> root.enable_previews;
                                                toggled => { root.save_settings(); }
                                            }

                                            if root.enable_previews: FormRow {
                                                title: "Preview Quality:";
                                                ComboBox {
                                                    model: ["Fast (64px)", "Balanced (128px)", "High Quality (256px)"];
                                                    current-index <=> root.preview_quality;
                                                    height: 32px;
                                                    selected(val) => { root.save_settings(); }
                                                }
                                            }

                                            CheckBox {
                                                text: "Enable HDR Tonemapping";
                                                checked <=> root.tonemap_enabled;
                                                toggled => { root.tonemap_toggled(); }
                                            }

                                            if root.tonemap_enabled: ComboBox {
                                                model: ["ACES Filmic", "ICtCp Perceptual", "Khronos PBR Neutral"];
                                                current-index <=> root.tonemap_operator;
                                                height: 32px;
                                                selected(val) => { root.tonemap_toggled(); }
                                            }
                                            HorizontalLayout {
                                                spacing: 6px;
                                                padding-top: 4px;
                                                CustomButton {
                                                    text: "Clear Caches";
                                                    height: 32px;
                                                    clicked => { root.clear_cache(); }
                                                }

                                                CustomButton {
                                                    text: "Clear Models";
                                                    height: 32px;
                                                    clicked => { root.clear_models(); }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // FIXED BOTTOM SCAN BUTTON
                        Rectangle {
                            height: 40px;
                            background: #1e1f22;
                            border-radius: 4px;

                            VerticalLayout {
                                padding: 4px;
                                CustomButton {
                                    text: root.is_scanning ? "STOP SCAN" : "RUN SCANNER";
                                    primary-color: root.is_scanning ? #f23f43 : #23a55a;
                                    height: 32px;
                                    clicked => {
                                        if (root.is_scanning) {
                                            root.cancel_scan();
                                        } else {
                                            root.run_scan();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // SPLITTER
                Rectangle {
                    width: 8px;
                    horizontal-stretch: 0;
                    background: sidebar-splitter-ta.has-hover ? #4e5058 : #1e1f22;
                    Rectangle {
                        width: 2px;
                        height: 20px;
                        background: #6d6f78;
                        border-radius: 1px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }

                    sidebar-splitter-ta := TouchArea {
                        mouse-cursor: MouseCursor.col-resize;
                        moved => { if (self.pressed) { root.sidebar_width = (self.x + self.mouse-x - self.pressed-x).clamp(320px, 600px); root.save_settings(); } }
                    }
                }

                // MAIN RESULTS LIST
                VerticalLayout {
                    padding-left: 12px;
                    horizontal-stretch: 1;
                    spacing: 8px;
                    VerticalLayout {
                        spacing: 8px;
                        vertical-stretch: 1;
                        HorizontalLayout {
                            alignment: space-between;
                            HorizontalLayout {
                                spacing: 12px;
                                Text {
                                    text: "Results (" + root.results.length + " items)";
                                    font-size: 14px;
                                    font-weight: 700;
                                    color: #ffffff;
                                    vertical-alignment: center;
                                }

                                LineEdit {
                                    text <=> root.results_search_query;
                                    placeholder-text: "Filter by name...";
                                    height: 24px;
                                    width: 130px;
                                    edited => { root.results_filter_changed(); }
                                }

                                ComboBox {
                                    model: root.search_method == 3 ? ["By Format Type", "By Size on Disk", "By Filename"] : ["By Duplicate Count", "By Size on Disk", "By Filename"];
                                    current-index <=> root.results_sort_index;
                                    height: 24px;
                                    width: 145px;
                                    selected(val) => { root.results_sort_changed(root.results_sort_index); }
                                }

                                if root.search_method == 2: HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: "Min Sim:";
                                        vertical-alignment: center;
                                        font-size: 12px;
                                        color: #dcddde;
                                    }

                                    Slider {
                                        value <=> root.results_min_similarity;
                                        minimum: 0.0;
                                        maximum: 100.0;
                                        width: 80px;
                                        height: 24px;
                                        changed(val) => { root.results_filter_changed(); }
                                    }

                                    Text {
                                        text: Math.round(root.results_min_similarity) + "%";
                                        vertical-alignment: center;
                                        font-size: 12px;
                                        color: #ffffff;
                                        width: 35px;
                                    }
                                }
                                if !root.results_grid_mode && root.results.length > 0: HorizontalLayout {
                                    spacing: 6px;
                                    if root.search_method == 3: CustomButton {
                                        text: "Export CSV";
                                        height: 24px;
                                        primary-color: #0e639c;
                                        clicked => { root.export_csv(); }
                                    }
                                    if root.search_method != 3: CustomButton {
                                        text: "Expand All";
                                        height: 24px;
                                        primary-color: #5865f2;
                                        clicked => { root.export_csv(); }
                                    }
                                    if root.search_method != 3: CustomButton {
                                        text: "Collapse All";
                                        height: 24px;
                                        primary-color: #5865f2;
                                        clicked => { root.collapse_all_groups(); }
                                    }
                                    CustomButton {
                                        text: "Auto Cols";
                                        height: 24px;
                                        primary-color: #5865f2;
                                        clicked => { root.auto_size_columns(); }
                                    }

                                    CustomButton {
                                        text: "Reset Cols";
                                        height: 24px;
                                        primary-color: #5865f2;
                                        clicked => { root.col_file_w = 300px; root.col_score_w = 70px; root.col_path_w = 350px; }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                if root.results.length > 0: HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: root.results_grid_mode ? "Card Size:" : "Row Size:";
                                        vertical-alignment: center;
                                        font-size: 12px;
                                        color: #dcddde;
                                    }

                                    Slider {
                                        value: root.results_grid_mode ? (root.grid_card_size / 1px) : (root.list_preview_size / 1px);
                                        minimum: root.results_grid_mode ? 100 : 32;
                                        maximum: root.results_grid_mode ? 250 : 120;
                                        width: 100px;
                                        height: 24px;
                                        changed(val) => { if (root.results_grid_mode) { root.grid_card_size = val * 1px; } else { root.list_preview_size = val * 1px; } root.save_settings(); }
                                    }
                                }
                                if root.skipped_files_list.length > 0: CustomButton {
                                    text: "⚠️ Skipped Files (" + root.skipped_files_list.length + ")";
                                    primary-color: #f23f43;
                                    height: 24px;
                                    clicked => { root.skipped_popup_x = self.absolute-position.x - 120px; root.skipped_popup_y = self.absolute-position.y + self.height; skipped_popup.show(); }
                                }
                                CustomButton {
                                    text: root.results_grid_mode ? "List Mode (☰)" : "Grid Mode (⊞)";
                                    height: 24px;
                                    clicked => { root.results_grid_mode = !root.results_grid_mode; }
                                }
                            }
                        }

                        if root.results.length > 0 || root.filter_only_npot || root.filter_only_uncompressed || root.filter_only_missing_mips || root.filter_only_cubemaps || root.results_search_query != "": HorizontalLayout {
                            spacing: 12px;
                            padding-left: 4px;
                            padding-bottom: 4px;
                            alignment: start;
                            Text {
                                text: "Smart Filters:";
                                vertical-alignment: center;
                                font-size: 12px;
                                color: #949ba4;
                            }

                            CheckBox {
                                text: "NPOT Only";
                                checked <=> root.filter_only_npot;
                                toggled => { root.results_filter_changed(); }
                            }

                            CheckBox {
                                text: "Uncompressed Only";
                                checked <=> root.filter_only_uncompressed;
                                toggled => { root.results_filter_changed(); }
                            }

                            CheckBox {
                                text: "Missing Mips Only";
                                checked <=> root.filter_only_missing_mips;
                                toggled => { root.results_filter_changed(); }
                            }

                            CheckBox {
                                text: "Cubemaps Only";
                                checked <=> root.filter_only_cubemaps;
                                toggled => { root.results_filter_changed(); }
                            }
                        }

                        Rectangle {
                            border-color: #1f2023;
                            border-width: 1px;
                            background: #2b2d31;
                            border-radius: 4px;
                            vertical-stretch: 1;
                            clip: true;
                            VerticalLayout {
                                if !root.results_grid_mode && root.results.length > 0: VerticalLayout {
                                    vertical-stretch: 0;
                                    Rectangle {
                                        height: 24px;
                                        background: #1e1f22;
                                        HorizontalLayout {
                                            padding-left: 28px;
                                            padding-right: 8px;
                                            spacing: 0px;
                                            Rectangle {
                                                width: 32px;
                                            }

                                            HorizontalLayout {
                                                width: root.col_file_w;
                                                TouchArea {
                                                    width: 100%;
                                                    height: 100%;
                                                    mouse-cursor: pointer;
                                                    clicked => { root.sort_by_column("name"); }
                                                    Text {
                                                        text: "FILE";
                                                        color: #949ba4;
                                                        font-size: 11px;
                                                        font-weight: 700;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                            }

                                            Rectangle {
                                                width: 8px;
                                                background: file_split.has-hover ? #4e5058 : transparent;
                                                file_split := TouchArea {
                                                    mouse-cursor: col-resize;
                                                    moved => { if (self.pressed) { root.col_file_w = (root.col_file_w + self.mouse-x - self.pressed-x).clamp(100px, 800px); } }
                                                }
                                            }

                                            if root.search_method != 3: HorizontalLayout {
                                                spacing: 0px;
                                                HorizontalLayout {
                                                    width: root.col_score_w;
                                                    TouchArea {
                                                        width: 100%;
                                                        height: 100%;
                                                        mouse-cursor: pointer;
                                                        clicked => { root.sort_by_column("score"); }
                                                        Text {
                                                            text: "SCORE";
                                                            color: #949ba4;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            vertical-alignment: center;
                                                            horizontal-alignment: center;
                                                            width: 100%;
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                    background: score_split.has-hover ? #4e5058 : transparent;
                                                    score_split := TouchArea {
                                                        mouse-cursor: col-resize;
                                                        moved => { if (self.pressed) { root.col_score_w = (root.col_score_w + self.mouse-x - self.pressed-x).clamp(50px, 200px); } }
                                                    }
                                                }

                                                HorizontalLayout {
                                                    width: root.col_path_w;
                                                    TouchArea {
                                                        width: 100%;
                                                        height: 100%;
                                                        mouse-cursor: pointer;
                                                        clicked => { root.sort_by_column("path"); }
                                                        Text {
                                                            text: "PATH";
                                                            color: #949ba4;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                    background: path_split.has-hover ? #4e5058 : transparent;
                                                    path_split := TouchArea {
                                                        mouse-cursor: col-resize;
                                                        moved => { if (self.pressed) { root.col_path_w = (root.col_path_w + self.mouse-x - self.pressed-x).clamp(100px, 1000px); } }
                                                    }
                                                }

                                                HorizontalLayout {
                                                    horizontal-stretch: 1;
                                                    Text {
                                                        text: "METADATA";
                                                        color: #949ba4;
                                                        font-size: 11px;
                                                        font-weight: 700;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                            }

                                            if root.search_method == 3: HorizontalLayout {
                                                spacing: 0px;
                                                HorizontalLayout {
                                                    width: root.col_format_w;
                                                    TouchArea {
                                                        width: 100%;
                                                        height: 100%;
                                                        mouse-cursor: pointer;
                                                        clicked => { root.sort_by_column("format"); }
                                                        Text {
                                                            text: "FORMAT";
                                                            color: #949ba4;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                    background: format_split.has-hover ? #4e5058 : transparent;
                                                    format_split := TouchArea {
                                                        mouse-cursor: col-resize;
                                                        moved => { if (self.pressed) { root.col_format_w = (root.col_format_w + self.mouse-x - self.pressed-x).clamp(50px, 300px); } }
                                                    }
                                                }

                                                HorizontalLayout {
                                                    width: root.col_dimensions_w;
                                                    TouchArea {
                                                        width: 100%;
                                                        height: 100%;
                                                        mouse-cursor: pointer;
                                                        clicked => { root.sort_by_column("dimensions"); }
                                                        Text {
                                                            text: "DIMENSIONS";
                                                            color: #949ba4;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                    background: dim_split.has-hover ? #4e5058 : transparent;
                                                    dim_split := TouchArea {
                                                        mouse-cursor: col-resize;
                                                        moved => { if (self.pressed) { root.col_dimensions_w = (root.col_dimensions_w + self.mouse-x - self.pressed-x).clamp(50px, 300px); } }
                                                    }
                                                }

                                                HorizontalLayout {
                                                    width: root.col_mipmaps_w;
                                                    TouchArea {
                                                        width: 100%;
                                                        height: 100%;
                                                        mouse-cursor: pointer;
                                                        clicked => { root.sort_by_column("mipmaps"); }
                                                        Text {
                                                            text: "MIPMAPS";
                                                            color: #949ba4;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            vertical-alignment: center;
                                                            horizontal-alignment: center;
                                                            width: 100%;
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                    background: mips_split.has-hover ? #4e5058 : transparent;
                                                    mips_split := TouchArea {
                                                        mouse-cursor: col-resize;
                                                        moved => { if (self.pressed) { root.col_mipmaps_w = (root.col_mipmaps_w + self.mouse-x - self.pressed-x).clamp(40px, 200px); } }
                                                    }
                                                }

                                                HorizontalLayout {
                                                    width: root.col_cubemap_w;
                                                    TouchArea {
                                                        width: 100%;
                                                        height: 100%;
                                                        mouse-cursor: pointer;
                                                        clicked => { root.sort_by_column("cubemap"); }
                                                        Text {
                                                            text: "CUBEMAP";
                                                            color: #949ba4;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            vertical-alignment: center;
                                                            horizontal-alignment: center;
                                                            width: 100%;
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                    background: cube_split.has-hover ? #4e5058 : transparent;
                                                    cube_split := TouchArea {
                                                        mouse-cursor: col-resize;
                                                        moved => { if (self.pressed) { root.col_cubemap_w = (root.col_cubemap_w + self.mouse-x - self.pressed-x).clamp(40px, 200px); } }
                                                    }
                                                }

                                                HorizontalLayout {
                                                    width: root.col_size_w;
                                                    TouchArea {
                                                        width: 100%;
                                                        height: 100%;
                                                        mouse-cursor: pointer;
                                                        clicked => { root.sort_by_column("size"); }
                                                        Text {
                                                            text: "SIZE";
                                                            color: #949ba4;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 8px;
                                                    background: size_split.has-hover ? #4e5058 : transparent;
                                                    size_split := TouchArea {
                                                        mouse-cursor: col-resize;
                                                        moved => { if (self.pressed) { root.col_size_w = (root.col_size_w + self.mouse-x - self.pressed-x).clamp(40px, 250px); } }
                                                    }
                                                }

                                                HorizontalLayout {
                                                    horizontal-stretch: 1;
                                                    TouchArea {
                                                        width: 100%;
                                                        height: 100%;
                                                        mouse-cursor: pointer;
                                                        clicked => { root.sort_by_column("path"); }
                                                        Text {
                                                            text: "PATH";
                                                            color: #949ba4;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    Rectangle {
                                        height: 1px;
                                        background: #1f2023;
                                    }
                                }

                                if !root.results_grid_mode && root.results.length > 0: ListView {
                                    for row[idx] in root.results: Rectangle {
                                        height: row.is_header ? 28px : (root.list_preview_size + 8px);
                                        background: row.is_header ? #1e1f22 : (row.is_best ? #2c3e50 : (main_row_ta.has-hover ? #393c41 : #2b2d31));
                                        border-color: #1f2023;
                                        border-width: 1px;

                                        main_row_ta := TouchArea {
                                            x: 28px + 24px + 8px + root.list_preview_size + 8px;
                                            width: parent.width - self.x;
                                            height: 100%;
                                            clicked => { root.row_clicked(idx, false, row.group_index, row.path); root.active_tab = 1; }
                                            pointer-event(evt) => { if (evt.button == PointerEventButton.right && evt.kind == PointerEventKind.down) { if (!row.is_header) { root.context_hovered_path = row.path; root.menu_x = self.absolute-position.x + self.mouse-x; root.menu_y = self.absolute-position.y + self.mouse-y; context_popup.show(); } } }
                                        }

                                        if row.is_header: TouchArea {
                                            width: 100%;
                                            height: 100%;
                                            clicked => { root.row_clicked(idx, true, row.group_index, row.path); }
                                            HorizontalLayout {
                                                padding-left: 8px;
                                                padding-right: 8px;
                                                spacing: 8px;
                                                alignment: space-between;
                                                Text {
                                                    text: row.is_qc ? ((row.is_checked ? "▶ " : "▼ ") + "QC Issue: " + row.hash_or_issue) : ((row.is_checked ? "▶ " : "▼ ") + "Group #" + (row.group_index + 1) + " (Hash: " + row.hash_or_issue + ")");
                                                    color: #949ba4;
                                                    font-size: 12px;
                                                    font-weight: 700;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                }

                                                Text {
                                                    text: row.size_str;
                                                    color: #949ba4;
                                                    font-size: 11px;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }

                                        if !row.is_header: HorizontalLayout {
                                            padding-left: 28px;
                                            padding-right: 8px;
                                            spacing: 0px;
                                            CheckBox {
                                                checked: row.is_checked;
                                                toggled => { root.row_checkbox_toggled(idx); }
                                                width: 24px;
                                            }

                                            Rectangle {
                                                width: 8px;
                                            }

                                            if root.enable_previews: InteractiveThumbnail {
                                                source: row.thumbnail;
                                                path: row.path;
                                                show_corners: true;
                                                checkerboard: root.checkerboard_pattern;
                                                width: root.list_preview_size;
                                                height: root.list_preview_size;
                                                corner_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                                clicked => { root.row_clicked(idx, false, row.group_index, row.path); root.active_tab = 1; }
                                            }
                                            if root.enable_previews: Rectangle {
                                                width: 8px;
                                            }

                                            Rectangle {
                                                horizontal-stretch: 1;
                                                HorizontalLayout {
                                                    spacing: 0px;
                                                    width: 100%;
                                                    height: 100%;

                                                    HorizontalLayout {
                                                        width: root.enable_previews ? (root.col_file_w - root.list_preview_size - 16px) : (root.col_file_w - 32px);
                                                        Text {
                                                            text: row.name;
                                                            color: #dcddde;
                                                            font-size: 12px;
                                                            vertical-alignment: center;
                                                            overflow: elide;
                                                        }
                                                    }

                                                    Rectangle {
                                                        width: 8px;
                                                    }

                                                    if root.search_method != 3: HorizontalLayout {
                                                        spacing: 0px;
                                                        HorizontalLayout {
                                                            width: root.col_score_w;
                                                            Text {
                                                                text: row.is_best ? "[Best]" : row.score_or_detail;
                                                                color: row.is_best ? #f0b132 : #dcddde;
                                                                font-size: 12px;
                                                                vertical-alignment: center;
                                                                horizontal-alignment: center;
                                                                width: 100%;
                                                            }
                                                        }

                                                        Rectangle {
                                                            width: 8px;
                                                        }

                                                        HorizontalLayout {
                                                            width: root.col_path_w;
                                                            Text {
                                                                text: row.path;
                                                                color: #949ba4;
                                                                font-size: 11px;
                                                                vertical-alignment: center;
                                                                overflow: elide;
                                                            }
                                                        }

                                                        Rectangle {
                                                            width: 8px;
                                                        }

                                                        HorizontalLayout {
                                                            horizontal-stretch: 1;
                                                            Text {
                                                                text: row.meta_str;
                                                                color: #949ba4;
                                                                font-size: 11px;
                                                                vertical-alignment: center;
                                                                overflow: elide;
                                                            }
                                                        }
                                                    }
                                                    if root.search_method == 3: HorizontalLayout {
                                                        spacing: 0px;
                                                        HorizontalLayout {
                                                            width: root.col_format_w;
                                                            Text {
                                                                text: row.format_str;
                                                                color: #dcddde;
                                                                font-size: 11px;
                                                                vertical-alignment: center;
                                                            }
                                                        }

                                                        Rectangle {
                                                            width: 8px;
                                                        }

                                                        HorizontalLayout {
                                                            width: root.col_dimensions_w;
                                                            Text {
                                                                text: row.dimensions_str;
                                                                color: #dcddde;
                                                                font-size: 11px;
                                                                vertical-alignment: center;
                                                            }
                                                        }

                                                        Rectangle {
                                                            width: 8px;
                                                        }

                                                        HorizontalLayout {
                                                            width: root.col_mipmaps_w;
                                                            Text {
                                                                text: row.mipmaps_str;
                                                                color: #dcddde;
                                                                font-size: 11px;
                                                                vertical-alignment: center;
                                                            }
                                                        }

                                                        Rectangle {
                                                            width: 8px;
                                                        }

                                                        HorizontalLayout {
                                                            width: root.col_cubemap_w;
                                                            Text {
                                                                text: row.cubemap_str;
                                                                color: row.cubemap_str == "YES" ? #f0b132 : #dcddde;
                                                                font-weight: row.cubemap_str == "YES" ? 700 : 400;
                                                                font-size: 11px;
                                                                vertical-alignment: center;
                                                            }
                                                        }

                                                        Rectangle {
                                                            width: 8px;
                                                        }

                                                        HorizontalLayout {
                                                            width: root.col_size_w;
                                                            Text {
                                                                text: row.size_str;
                                                                color: #dcddde;
                                                                font-size: 11px;
                                                                vertical-alignment: center;
                                                            }
                                                        }

                                                        Rectangle {
                                                            width: 8px;
                                                        }

                                                        HorizontalLayout {
                                                            horizontal-stretch: 1;
                                                            Text {
                                                                text: row.path;
                                                                color: #5865f2;
                                                                font-size: 11px;
                                                                vertical-alignment: center;
                                                                overflow: elide;
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }

                                // ---- GRID VIEW (Virtualized via GridRow and standard ListView) ----
                                if root.results_grid_mode && root.grid_row_results.length > 0: ListView {
                                    for row in root.grid_row_results: HorizontalLayout {
                                        spacing: 12px;
                                        padding: 10px;
                                        alignment: start;
                                        if row.has-col1: GridCard {
                                            row-data: row.col1;
                                            checkerboard: root.checkerboard_pattern;
                                            width: root.grid_card_size;
                                            height: root.grid_card_size + 45px;
                                            clicked => { root.row_clicked(-1, false, row.col1.group_index, row.col1.path); root.active_tab = 1; }
                                            right_clicked(mx, my) => { root.context_hovered_path = row.col1.path; root.menu_x = mx; root.menu_y = my; context_popup.show(); }
                                            channel_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                        }
                                        if row.has-col2: GridCard {
                                            row-data: row.col2;
                                            checkerboard: root.checkerboard_pattern;
                                            width: root.grid_card_size;
                                            height: root.grid_card_size + 45px;
                                            clicked => { root.row_clicked(-1, false, row.col2.group_index, row.col2.path); root.active_tab = 1; }
                                            right_clicked(mx, my) => { root.context_hovered_path = row.col2.path; root.menu_x = mx; root.menu_y = my; context_popup.show(); }
                                            channel_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                        }
                                        if row.has-col3: GridCard {
                                            row-data: row.col3;
                                            checkerboard: root.checkerboard_pattern;
                                            width: root.grid_card_size;
                                            height: root.grid_card_size + 45px;
                                            clicked => { root.row_clicked(-1, false, row.col3.group_index, row.col3.path); root.active_tab = 1; }
                                            right_clicked(mx, my) => { root.context_hovered_path = row.col3.path; root.menu_x = mx; root.menu_y = my; context_popup.show(); }
                                            channel_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                        }
                                        if row.has-col4: GridCard {
                                            row-data: row.col4;
                                            checkerboard: root.checkerboard_pattern;
                                            width: root.grid_card_size;
                                            height: root.grid_card_size + 45px;
                                            clicked => { root.row_clicked(-1, false, row.col4.group_index, row.col4.path); root.active_tab = 1; }
                                            right_clicked(mx, my) => { root.context_hovered_path = row.col4.path; root.menu_x = mx; root.menu_y = my; context_popup.show(); }
                                            channel_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                        }
                                    }
                                }

                                if root.results.length == 0: VerticalLayout {
                                    alignment: center;
                                    spacing: 12px;
                                    Text {
                                        text: "No duplicate assets loaded. Choose scan parameters in the left pane and begin auditing.";
                                        color: #7c808a;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        background: #2b2d31;
                        border-color: #1f2023;
                        border-width: 1px;
                        border-radius: 4px;
                        height: 56px;
                        VerticalLayout {
                            padding: 8px;
                            spacing: 4px;
                            Text {
                                text: "Selection Rules";
                                font-size: 12px;
                                font-weight: 700;
                                color: #949ba4;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                CustomButton {
                                    text: "Select All";
                                    primary-color: #4e5058;
                                    width: 85px;
                                    clicked => { root.trigger_selection_rule("all"); }
                                }

                                CustomButton {
                                    text: "Deselect All";
                                    primary-color: #4e5058;
                                    width: 95px;
                                    clicked => { root.trigger_selection_rule("none"); }
                                }

                                CustomButton {
                                    text: "Select All Except Best";
                                    primary-color: #4e5058;
                                    width: 140px;
                                    clicked => { root.trigger_selection_rule("except_best"); }
                                }

                                CustomButton {
                                    text: "Invert Selection";
                                    primary-color: #4e5058;
                                    width: 110px;
                                    clicked => { root.trigger_selection_rule("invert"); }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        height: 24px;
                        CustomButton {
                            text: "Replace with Hardlink";
                            primary-color: #5865f2;
                            width: 145px;
                            clicked => { root.trigger_action("hardlink"); }
                        }

                        CustomButton {
                            text: "Replace with Reflink";
                            primary-color: #5865f2;
                            width: 135px;
                            clicked => { root.trigger_action("reflink"); }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        CustomButton {
                            text: "Move to Trash";
                            primary-color: #f23f43;
                            width: 105px;
                            clicked => { root.trigger_action("trash"); }
                        }
                    }
                }
            }

            // ------------------ TAB 1: COMPARE ------------------
            if root.active_tab == 1: HorizontalLayout {
                spacing: 0px;
                width: 100%;
                height: 100%;
                VerticalLayout {
                    horizontal-stretch: 1;
                    padding-right: 12px;
                    spacing: 12px;
                    Text {
                        text: "Interactive Compare Viewport";
                        font-size: 15px;
                        font-weight: 700;
                        color: #ffffff;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        height: 28px;
                        ComboBox {
                            model: ["Side-by-Side", "Wipe Mode", "Overlay Blend", "Difference Heatmap"];
                            current-index <=> root.compare_mode;
                            width: 160px;
                            height: 24px;
                            selected(val) => { root.compare_mode_changed(); }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "Wipe Shift:";
                                vertical-alignment: center;
                                font-size: 12px;
                                color: #dcddde;
                            }

                            Slider {
                                value <=> root.wipe_slider_val;
                                minimum: 0.0;
                                maximum: 1.0;
                                height: 24px;
                            }
                        }

                        // Added option to select specific Mipmap level with custom padding and spacing
                        HorizontalLayout {
                            spacing: 8px;
                            width: 180px;
                            Text {
                                text: "Mip Level:";
                                vertical-alignment: center;
                                font-size: 12px;
                                color: root.max_available_mips > 1 ? #dcddde : #555555;
                            }

                            SpinBox {
                                value: root.active_mip_level;
                                minimum: 0;
                                maximum: root.max_available_mips > 1 ? root.max_available_mips - 1 : 0;
                                height: 24px;
                                width: 100px;
                                enabled: root.max_available_mips > 1;
                                edited(val) => { root.active_mip_level = val; root.mip_level_changed(); }
                            }
                        }

                        CheckBox {
                            text: "HDR";
                            checked <=> root.tonemap_enabled;
                            height: 24px;
                            toggled => { root.tonemap_toggled(); }
                        }

                        if root.tonemap_enabled: ComboBox {
                            model: ["ACES Filmic", "ICtCp Perceptual", "Khronos PBR Neutral"];
                            current-index <=> root.tonemap_operator;
                            height: 24px;
                            width: 165px;
                            selected(val) => { root.tonemap_toggled(); }
                        }
                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        CustomButton {
                            text: "Reset Zoom";
                            height: 24px;
                            primary-color: #4e5058;
                            clicked => { root.zoom_factor = 1.0; root.pan_x = 0px; root.pan_y = 0px; }
                        }
                    }

                    viewport_root := Rectangle {
                        background: #111214;
                        clip: true;
                        vertical-stretch: 1;
                        horizontal-stretch: 1;
                        TouchArea {
                            property <length> start_x;
                            property <length> start_y;
                            pointer-event(evt) => { if (evt.button == PointerEventButton.right && evt.kind == PointerEventKind.down) { root.zoom_factor = 1.0; root.pan_x = 0px; root.pan_y = 0px; } if (evt.button == PointerEventButton.left && evt.kind == PointerEventKind.down) { self.start_x = self.mouse-x; self.start_y = self.mouse-y; } if (evt.button == PointerEventButton.left && evt.kind == PointerEventKind.move) { if (self.pressed) { root.pan_x = root.pan_x + (self.mouse-x - self.start_x); root.pan_y = root.pan_y + (self.mouse-y - self.start_y); self.start_x = self.mouse-x; self.start_y = self.mouse-y; } } }
                            scroll-event(evt) => { let zoom_delta = (evt.delta-y / 1px) / 120.0 * 0.15; root.zoom_factor = (root.zoom_factor + zoom_delta).clamp(1.0, 10.0); if (root.zoom_factor == 1.0) { root.pan_x = 0px; root.pan_y = 0px; } EventResult.accept }
                            double-clicked => { if (self.mouse-x < parent.width / 2) { root.open_file_in_viewer(root.original_meta.path); } else { root.open_file_in_viewer(root.duplicate_meta.path); } }
                        }

                        if root.compare_mode == 0: Rectangle {
                            width: 100%;
                            height: 100%;
                            Rectangle {
                                x: 0px;
                                y: 0px;
                                width: parent.width / 2 - 6px;
                                height: parent.height;
                                clip: true;
                                Rectangle {
                                    width: parent.width;
                                    height: parent.height;
                                    background: #111214;
                                    border-color: #3e3e42;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    clip: true;
                                    Image {
                                        source: root.checkerboard_pattern;
                                        horizontal-tiling: repeat;
                                        vertical-tiling: repeat;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    Image {
                                        source: root.image_original;
                                        image-fit: contain;
                                        width: parent.width * root.zoom_factor;
                                        height: parent.height * root.zoom_factor;
                                        x: parent.width / 2 - self.width / 2 + root.pan_x;
                                        y: parent.height / 2 - self.height / 2 + root.pan_y;
                                    }
                                }
                            }

                            Rectangle {
                                x: parent.width / 2 + 6px;
                                y: 0px;
                                width: parent.width / 2 - 6px;
                                height: parent.height;
                                clip: true;
                                Rectangle {
                                    width: parent.width;
                                    height: parent.height;
                                    background: #111214;
                                    border-color: #3e3e42;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    clip: true;
                                    Image {
                                        source: root.checkerboard_pattern;
                                        horizontal-tiling: repeat;
                                        vertical-tiling: repeat;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    Image {
                                        source: root.image_duplicate;
                                        image-fit: contain;
                                        opacity: root.wipe_slider_val;
                                        width: parent.width * root.zoom_factor;
                                        height: parent.height * root.zoom_factor;
                                        x: parent.width / 2 - self.width / 2 + root.pan_x;
                                        y: parent.height / 2 - self.height / 2 + root.pan_y;
                                    }
                                }
                            }
                        }
                        if root.compare_mode == 1: WipeViewport {
                            original: root.image_original;
                            duplicate: root.image_duplicate;
                            checkerboard: root.checkerboard_pattern;
                            wipe-val <=> root.wipe_slider_val;
                            width: parent.width * root.zoom_factor;
                            height: parent.height * root.zoom_factor;
                            x: parent.width / 2 - self.width / 2 + root.pan_x;
                            y: parent.height / 2 - self.height / 2 + root.pan_y;
                        }
                        if root.compare_mode == 2: Rectangle {
                            width: 100%;
                            height: 100%;
                            clip: true;
                            Image {
                                source: root.checkerboard_pattern;
                                horizontal-tiling: repeat;
                                vertical-tiling: repeat;
                                width: 100%;
                                height: 100%;
                            }

                            Image {
                                source: root.image_original;
                                image-fit: contain;
                                width: parent.width * root.zoom_factor;
                                height: parent.height * root.zoom_factor;
                                x: parent.width / 2 - self.width / 2 + root.pan_x;
                                y: parent.height / 2 - self.height / 2 + root.pan_y;
                            }

                            Image {
                                source: root.image_duplicate;
                                image-fit: contain;
                                opacity: root.wipe_slider_val;
                                width: parent.width * root.zoom_factor;
                                height: parent.height * root.zoom_factor;
                                x: parent.width / 2 - self.width / 2 + root.pan_x;
                                y: parent.height / 2 - self.height / 2 + root.pan_y;
                            }
                        }
                        if root.compare_mode == 3: Rectangle {
                            width: 100%;
                            height: 100%;
                            clip: true;
                            Image {
                                source: root.checkerboard_pattern;
                                horizontal-tiling: repeat;
                                vertical-tiling: repeat;
                                width: 100%;
                                height: 100%;
                            }

                            Image {
                                source: root.image_heatmap;
                                image-fit: contain;
                                width: parent.width * root.zoom_factor;
                                height: parent.height * root.zoom_factor;
                                x: parent.width / 2 - self.width / 2 + root.pan_x;
                                y: parent.height / 2 - self.height / 2 + root.pan_y;
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        height: 28px;
                        alignment: center;
                        ChannelButton {
                            text: "R";
                            active-color: #f23f43;
                            active <=> root.active_r;
                            clicked => { root.active_r = !root.active_r; if root.active_r { root.active_g = false; root.active_b = false; root.active_a = false; } root.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "G";
                            active-color: #23a55a;
                            active <=> root.active_g;
                            clicked => { root.active_g = !root.active_g; if root.active_g { root.active_r = false; root.active_b = false; root.active_a = false; } root.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "B";
                            active-color: #5865f2;
                            active <=> root.active_b;
                            clicked => { root.active_b = !root.active_b; if root.active_b { root.active_r = false; root.active_g = false; root.active_a = false; } root.channel_toggled(); }
                        }

                        ChannelButton {
                            text: "A";
                            active-color: #ffffff;
                            text-color: #000000;
                            active <=> root.active_a;
                            clicked => { root.active_a = !root.active_a; if root.active_a { root.active_r = false; root.active_g = false; root.active_b = false; } root.channel_toggled(); }
                        }
                    }
                }

                // SPLITTER
                Rectangle {
                    width: 8px;
                    horizontal-stretch: 0;
                    background: compare-splitter-ta.has-hover ? #4e5058 : #1e1f22;
                    Rectangle {
                        width: 2px;
                        height: 20px;
                        background: #6d6f78;
                        border-radius: 1px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }

                    compare-splitter-ta := TouchArea {
                        mouse-cursor: MouseCursor.col-resize;
                        moved => { if (self.pressed) { root.compare_sidebar_width = (root.compare_sidebar_width + self.pressed-x - self.mouse-x).clamp(380px, 800px); root.save_settings(); } }
                    }
                }

                // RIGHT PANEL
                VerticalLayout {
                    width: root.compare_sidebar_width;
                    padding-left: 12px;
                    spacing: 12px;
                    Text {
                        text: "Group Duplicates (" + root.selected_group_files.length + " items)";
                        font-size: 13px;
                        font-weight: 700;
                        color: #949ba4;
                    }

                    Rectangle {
                        height: root.duplicates_panel_height;
                        background: #111214;
                        border-color: #1f2023;
                        border-width: 1px;
                        border-radius: 4px;
                        if root.selected_group_files.length > 0: ListView {
                            for row[idx] in root.selected_group_files: Rectangle {
                                height: 38px;
                                background: (row.path == root.duplicate_meta.path) ? #2c3e50 : (right_row_ta.has-hover ? #393c41 : #111214);
                                border-radius: 4px;
                                right_row_ta := TouchArea {
                                    x: 46px;
                                    width: parent.width - self.x;
                                    height: 100%;
                                    clicked => { root.row_clicked(idx, false, row.group_index, row.path); }
                                }

                                HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    spacing: 8px;
                                    alignment: space-between;
                                    InteractiveThumbnail {
                                        source: row.thumbnail;
                                        path: row.path;
                                        show_corners: true;
                                        checkerboard: root.checkerboard_pattern;
                                        width: 32px;
                                        height: 32px;
                                        corner_hovered(path, chan) => { root.thumbnail_channel_hovered(path, chan); }
                                        clicked => { root.row_clicked(idx, false, row.group_index, row.path); }
                                    }

                                    Text {
                                        text: row.name;
                                        color: #dcddde;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }

                                    Text {
                                        text: row.is_best ? "[Best]" : row.score_or_detail;
                                        color: row.is_best ? #f0b132 : #dcddde;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        if root.selected_group_files.length == 0: VerticalLayout {
                            alignment: center;
                            Text {
                                text: "No duplicates selected.";
                                color: #7c808a;
                                horizontal-alignment: center;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    Rectangle {
                        height: 8px;
                        vertical-stretch: 0;
                        background: splitter-ta.has-hover ? #4e5058 : #2b2d31;
                        border-radius: 4px;
                        Rectangle {
                            width: 20px;
                            height: 2px;
                            background: #6d6f78;
                            border-radius: 1px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }

                        splitter-ta := TouchArea {
                            mouse-cursor: row-resize;
                            moved => { if (self.pressed) { root.duplicates_panel_height = (self.y + self.mouse-y - self.pressed-y).clamp(80px, 450px); } }
                        }
                    }

                    Text {
                        text: "Comparison Specifications Matrix";
                        font-size: 13px;
                        font-weight: 700;
                        color: #949ba4;
                    }

                    Rectangle {
                        border-color: #1f2023;
                        border-width: 1px;
                        background: #111214;
                        border-radius: 4px;
                        vertical-stretch: 1;
                        ScrollView {
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                HorizontalLayout {
                                    Text {
                                        text: "Specification";
                                        width: 120px;
                                        font-weight: 700;
                                        color: #949ba4;
                                        font-size: 12px;
                                    }

                                    Text {
                                        text: "Original [Best]";
                                        font-weight: 700;
                                        color: #f0b132;
                                        font-size: 12px;
                                    }

                                    Text {
                                        text: "Duplicate";
                                        font-weight: 700;
                                        color: #dcddde;
                                        font-size: 12px;
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: #1f2023;
                                    vertical-stretch: 0;
                                }

                                SpecsRow {
                                    name: "File Name";
                                    val1: root.original_meta.name;
                                    val2: root.duplicate_meta.name;
                                }

                                SpecsRow {
                                    name: "File Size";
                                    val1: root.original_meta.size_str;
                                    val2: root.duplicate_meta.size_str;
                                }

                                SpecsRow {
                                    name: "Format / Codec";
                                    val1: root.original_meta.format;
                                    val2: root.duplicate_meta.format;
                                }

                                SpecsRow {
                                    name: "Resolution";
                                    val1: root.original_meta.resolution;
                                    val2: root.duplicate_meta.resolution;
                                }

                                SpecsRow {
                                    name: "Bit Depth";
                                    val1: root.original_meta.bit_depth;
                                    val2: root.duplicate_meta.bit_depth;
                                }

                                SpecsRow {
                                    name: "Color Space";
                                    val1: root.original_meta.color_space;
                                    val2: root.duplicate_meta.color_space;
                                }

                                SpecsRow {
                                    name: "Mipmaps";
                                    val1: root.original_meta.mipmaps;
                                    val2: root.duplicate_meta.mipmaps;
                                }

                                SpecsRow {
                                    name: "Alpha Channel";
                                    val1: root.original_meta.alpha;
                                    val2: root.duplicate_meta.alpha;
                                }

                                SpecsRow {
                                    name: "Similarity";
                                    val1: "100.0%";
                                    val2: root.duplicate_meta.similarity;
                                }

                                Rectangle {
                                    height: 1px;
                                    background: #1f2023;
                                    vertical-stretch: 0;
                                }

                                SpecsRow {
                                    name: "Full Path";
                                    val1: root.original_meta.path;
                                    val2: root.duplicate_meta.path;
                                }

                                Rectangle {
                                    vertical-stretch: 1;
                                }
                            }
                        }
                    }
                }
            }

            // ------------------ TAB 2: LOG (Console Output) ------------------
            if root.active_tab == 2: VerticalLayout {
                padding: 15px;
                spacing: 10px;
                width: 100%;
                height: 100%;
                Text {
                    text: "System Console Logs & Compiler Diagnostics";
                    font-weight: 700;
                    font-size: 14px;
                    color: #ffffff;
                }

                TextEdit {
                    text <=> root.console_log;
                    read-only: true;
                    font-family: "Consolas";
                    font-size: 12px;
                    vertical-stretch: 1;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    CustomButton {
                        text: "Export Log Output...";
                        width: 140px;
                        primary-color: #0e639c;
                        clicked => { root.export_log(root.console_log); }
                    }

                    CustomButton {
                        text: "Clear Console Buffer";
                        width: 140px;
                        primary-color: #3a3a3a;
                        clicked => { root.console_log = "Buffer cleared."; }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }
                }
            }
        }

        if root.is_scanning: Rectangle {
            background: #2b2d31;
            border-radius: 4px;
            border-color: #1f2023;
            border-width: 1px;
            height: 48px;
            HorizontalLayout {
                padding: 10px;
                spacing: 12px;
                Text {
                    text: root.status_text;
                    color: #dcddde;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 250px;
                    overflow: elide;
                }

                ProgressIndicator {
                    progress: root.progress;
                    horizontal-stretch: 1;
                    height: 16px;
                }

                Text {
                    text: Math.round(root.progress * 100) + "%";
                    color: #ffffff;
                    font-weight: 700;
                    font-size: 13px;
                    vertical-alignment: center;
                    width: 40px;
                }
            }
        }
    }
}
