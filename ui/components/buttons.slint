// ui/components/buttons.slint

export component MenuItem {
    in property <string> text;
    in property <color> text-color: #dcddde;
    callback clicked;

    height: 24px;
    rect := Rectangle {
        background: transparent;
        border-radius: 3px;
        txt := Text {
            x: 8px;
            text: root.text;
            color: root.text-color;
            vertical-alignment: center;
            font-size: 12px;
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    states [
        hover when ta.has-hover: {
            rect.background: #4752c4;
            txt.color: #ffffff;
        }
    ]
}

export component TabButton {
    in property <string> text;
    in property <bool> active;
    callback clicked;

    width: 100px;
    height: 26px;

    rect := Rectangle {
        background: active ? #2d2d30 : #1e1f22;
        border-color: active ? #3e3e42 : #1f2023;
        border-width: 1px;
        border-radius: 4px;

        animate background { duration: 100ms; }
        animate border-color { duration: 100ms; }

        txt := Text {
            text: root.text;
            color: active ? #ffffff : #858585;
            font-size: 13px;
            font-weight: active ? 600 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            animate color { duration: 100ms; }
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    states [
        hover when ta.has-hover && !active: {
            rect.background: #252526;
            rect.border-color: #3e3e42;
            txt.color: #cccccc;
        }
    ]
}

export component ChannelButton {
    in property <string> text;
    in property <color> active-color;
    in property <color> text-color: #ffffff;
    in property <bool> active;
    callback clicked;
    width: 26px;
    height: 26px;

    rect := Rectangle {
        background: active ? active-color : #1e1f22;
        border-color: active ? #ffffff : #1f2023;
        border-width: active ? 1.5px : 1px;
        border-radius: 4px;

        txt := Text {
            text: root.text;
            color: active ? root.text-color : #dcddde;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    TouchArea {
        clicked => { clicked(); }
    }
}

export component CustomButton {
    in property <string> text;
    in property <bool> enabled: true;
    in property <color> primary-color: #5865f2;
    in property <int> icon-type: 0; // 0: None, 1: Vector Image/Frame, 2: Vector List, 3: Vector Grid
    callback clicked;

    height: 26px; // Height adjusted to prevent vertical truncation
    min-width: 90px; // Raised min-width to support longer labels

    rect := Rectangle {
        background: !enabled ? #2f3136 : primary-color;
        border-radius: 4px;
        border-width: 1px;
        border-color: !enabled ? #1f2023 : primary-color;
        opacity: !enabled ? 0.5 : 1.0;

        animate background { duration: 100ms; }

        HorizontalLayout {
            alignment: center;
            spacing: 8px; // Spacing between the icon and text
            padding-left: 12px; // Raised horizontal padding to ensure text fits
            padding-right: 12px;

            if icon-type == 1: Rectangle { // Vector Frame Image (Clean alternative to emoji)
                width: 12px;
                height: 12px;
                border-color: !enabled ? #7c808a : #ffffff;
                border-width: 1px;
                border-radius: 1px;
                Path {
                    width: 100%;
                    height: 100%;
                    stroke: !enabled ? #7c808a : #ffffff;
                    stroke-width: 1px;
                    commands: "M 1 9 L 3.5 5 L 5.5 7.5 L 7.5 3.5 L 11 10";
                }
            }

            if icon-type == 2: Rectangle { // Vector List (Clean alternative to unicode ☰)
                width: 12px;
                height: 12px;
                VerticalLayout {
                    spacing: 2px;
                    alignment: center;
                    Rectangle {
                        height: 1.5px;
                        background: !enabled ? #7c808a : #ffffff;
                        border-radius: 0.5px;
                    }

                    Rectangle {
                        height: 1.5px;
                        background: !enabled ? #7c808a : #ffffff;
                        border-radius: 0.5px;
                    }

                    Rectangle {
                        height: 1.5px;
                        background: !enabled ? #7c808a : #ffffff;
                        border-radius: 0.5px;
                    }
                }
            }

            if icon-type == 3: Rectangle { // Vector Grid (Clean alternative to unicode ⊞)
                width: 12px;
                height: 12px;
                GridLayout {
                    spacing: 1.5px;
                    Row {
                        Rectangle {
                            background: !enabled ? #7c808a : #ffffff;
                            border-radius: 0.5px;
                        }

                        Rectangle {
                            background: !enabled ? #7c808a : #ffffff;
                            border-radius: 0.5px;
                        }
                    }

                    Row {
                        Rectangle {
                            background: !enabled ? #7c808a : #ffffff;
                            border-radius: 0.5px;
                        }

                        Rectangle {
                            background: !enabled ? #7c808a : #ffffff;
                            border-radius: 0.5px;
                        }
                    }
                }
            }

            txt := Text {
                text: root.text;
                color: !enabled ? #7c808a : #ffffff;
                font-size: 11px;
                font-weight: 600;
                vertical-alignment: center;
            }
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    states [
        hover when ta.has-hover && enabled: {
            rect.background: primary-color.brighter(12%);
        }
        active when ta.pressed && enabled: {
            rect.background: primary-color.darker(12%);
        }
    ]
}
