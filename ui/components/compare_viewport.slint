// ui/components/compare_viewport.slint

import { WipeViewport } from "./common.slint";
import { ViewportState } from "../store.slint";

export component InteractiveCompareViewport inherits Rectangle {
    background: #111214;
    clip: true;

    // Interactive TouchArea handling panning, zooming, magnifier loupe tracking & pixel inspection
    main_ta := TouchArea {
        property <length> pressed-pan-x;
        property <length> pressed-pan-y;

        // Custom mouse cursor feedback for dragging states
        mouse-cursor: self.pressed ? MouseCursor.grabbing : MouseCursor.grab;

        pointer-event(evt) => {
            // Right-click resets pan offset and zoom level to default
            if (evt.button == PointerEventButton.right && evt.kind == PointerEventKind.down) {
                ViewportState.viewer.fit_to_window = true;
                ViewportState.zoom_factor = 1.0;
                ViewportState.pan_x = 0px;
                ViewportState.pan_y = 0px;
            }
            // Left-click locks pan drag origin and disables Fit mode for free panning
            if (evt.button == PointerEventButton.left && evt.kind == PointerEventKind.down) {
                self.pressed-pan-x = ViewportState.pan_x;
                self.pressed-pan-y = ViewportState.pan_y;
            }
        }

        moved => {
            if (self.enabled && self.pressed) {
                // If panning while in Fit mode, exit Fit mode and keep current visual size
                if (ViewportState.viewer.fit_to_window) {
                    let current_scale = (root.width / 2) / Math.max(1px, ViewportState.sprite_width * 1px);
                    ViewportState.zoom_factor = current_scale;
                    ViewportState.viewer.fit_to_window = false;
                }
                ViewportState.pan_x = self.pressed-pan-x + (self.mouse-x - self.pressed-x);
                ViewportState.pan_y = self.pressed-pan-y + (self.mouse-y - self.pressed-y);
            }

            // Real-time Pixel Inspector coordinate sampling
            if (ViewportState.enable_inspector) {
                let img_w = ViewportState.viewer.fit_to_window ? root.width / 2 : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
                let img_h = ViewportState.viewer.fit_to_window ? root.height : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
                let img_x = root.width / 4 - img_w / 2 + ViewportState.pan_x;
                let img_y = root.height / 2 - img_h / 2 + ViewportState.pan_y;

                let scale = ViewportState.viewer.fit_to_window ? (img_w / Math.max(1px, ViewportState.sprite_width * 1px)) : ViewportState.zoom_factor;
                let rel_x = (self.mouse-x - img_x) / Math.max(0.001, scale);
                let rel_y = (self.mouse-y - img_y) / Math.max(0.001, scale);

                let px = Math.round(rel_x / 1px);
                let py = Math.round(rel_y / 1px);

                if (px >= 0 && py >= 0) {
                    ViewportState.inspect_pixel(px, py);
                }
            }
        }

        scroll-event(evt) => {
            // Seamless Zoom Sync: Convert current Fit scale into manual zoom_factor on wheel scroll
            if (ViewportState.viewer.fit_to_window) {
                let current_scale = (root.width / 2) / Math.max(1px, ViewportState.sprite_width * 1px);
                ViewportState.zoom_factor = current_scale;
                ViewportState.viewer.fit_to_window = false;
            }
            let zoom_delta = (evt.delta-y / 1px) / 120.0 * 0.15;
            ViewportState.zoom_factor = (ViewportState.zoom_factor + zoom_delta).clamp(0.1, 10.0);
            if (ViewportState.zoom_factor == 1.0) {
                ViewportState.pan_x = 0px;
                ViewportState.pan_y = 0px;
            }
            EventResult.accept
        }

        double-clicked => {
            if (self.mouse-x < parent.width / 2) {
                ViewportState.open_file_in_viewer(ViewportState.original_meta.path);
            } else {
                ViewportState.open_file_in_viewer(ViewportState.duplicate_meta.path);
            }
        }
    }

    // =========================================================================
    // MODE 0: SIDE-BY-SIDE (With Dynamic Magnifier Loupe)
    // =========================================================================
    if ViewportState.compare_mode == 0: Rectangle {
        width: 100%;
        height: 100%;

        // Left Viewport (Original / Master Source)
        left_box := Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width / 2 - 4px;
            height: parent.height;
            clip: true;
            background: ViewportState.viewer.background_mode == 2 ? #000000 : (ViewportState.viewer.background_mode == 3 ? #ffffff : #111214);
            border-color: #3e3e42;
            border-width: 1px;
            border-radius: 4px;

            if ViewportState.viewer.background_mode == 0: Image {
                source: ViewportState.checkerboard_pattern;
                horizontal-tiling: repeat;
                vertical-tiling: repeat;
                width: 100%;
                height: 100%;
            }

            if ViewportState.viewer.background_mode == 1: Image {
                source: ViewportState.checkerboard_pattern_light;
                horizontal-tiling: repeat;
                vertical-tiling: repeat;
                width: 100%;
                height: 100%;
            }

            orig_img := Image {
                source: ViewportState.image_original;
                image-fit: contain;
                width: ViewportState.viewer.fit_to_window ? parent.width : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
                height: ViewportState.viewer.fit_to_window ? parent.height : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
                x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
                y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
            }

            if ViewportState.viewer.enable_frame_blending: Image {
                source: ViewportState.image_original_next;
                opacity: ViewportState.blend_factor;
                image-fit: contain;
                width: orig_img.width;
                height: orig_img.height;
                x: orig_img.x;
                y: orig_img.y;
            }

            // Left Viewport Loupe with dynamic loupe_factor
            if ViewportState.enable_loupe && main_ta.has-hover && main_ta.mouse-x < root.width / 2: Rectangle {
                property <length> local-x: main_ta.mouse-x;
                property <length> local-y: main_ta.mouse-y;

                x: local-x - 75px;
                y: local-y - 75px;
                width: 150px;
                height: 150px;
                border-radius: 75px;
                border-color: #f0b132;
                border-width: 2.5px;
                background: #111214;
                clip: true;

                Image {
                    source: ViewportState.image_original;
                    image-fit: contain;
                    width: orig_img.width * ViewportState.loupe_factor;
                    height: orig_img.height * ViewportState.loupe_factor;
                    x: 75px - (local-x - orig_img.x) * ViewportState.loupe_factor;
                    y: 75px - (local-y - orig_img.y) * ViewportState.loupe_factor;
                }
            }
        }

        // Right Viewport (Duplicate / Target Candidate)
        right_box := Rectangle {
            x: parent.width / 2 + 4px;
            y: 0px;
            width: parent.width / 2 - 4px;
            height: parent.height;
            clip: true;
            background: ViewportState.viewer.background_mode == 2 ? #000000 : (ViewportState.viewer.background_mode == 3 ? #ffffff : #111214);
            border-color: #3e3e42;
            border-width: 1px;
            border-radius: 4px;

            if ViewportState.viewer.background_mode == 0: Image {
                source: ViewportState.checkerboard_pattern;
                horizontal-tiling: repeat;
                vertical-tiling: repeat;
                width: 100%;
                height: 100%;
            }

            if ViewportState.viewer.background_mode == 1: Image {
                source: ViewportState.checkerboard_pattern_light;
                horizontal-tiling: repeat;
                vertical-tiling: repeat;
                width: 100%;
                height: 100%;
            }

            dup_img := Image {
                source: ViewportState.image_duplicate;
                image-fit: contain;
                width: ViewportState.viewer.fit_to_window ? parent.width : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
                height: ViewportState.viewer.fit_to_window ? parent.height : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
                x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
                y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
            }

            if ViewportState.viewer.enable_frame_blending: Image {
                source: ViewportState.image_duplicate_next;
                opacity: ViewportState.blend_factor;
                image-fit: contain;
                width: dup_img.width;
                height: dup_img.height;
                x: dup_img.x;
                y: dup_img.y;
            }

            // Right Viewport Loupe with dynamic loupe_factor
            if ViewportState.enable_loupe && main_ta.has-hover && main_ta.mouse-x >= root.width / 2: Rectangle {
                property <length> local-x: main_ta.mouse-x - (root.width / 2 + 4px);
                property <length> local-y: main_ta.mouse-y;

                x: local-x - 75px;
                y: local-y - 75px;
                width: 150px;
                height: 150px;
                border-radius: 75px;
                border-color: #f0b132;
                border-width: 2.5px;
                background: #111214;
                clip: true;

                Image {
                    source: ViewportState.image_duplicate;
                    image-fit: contain;
                    width: dup_img.width * ViewportState.loupe_factor;
                    height: dup_img.height * ViewportState.loupe_factor;
                    x: 75px - (local-x - dup_img.x) * ViewportState.loupe_factor;
                    y: 75px - (local-y - dup_img.y) * ViewportState.loupe_factor;
                }
            }
        }
    }

    // =========================================================================
    // MODE 1: INTERACTIVE WIPE SLIDER VIEWPORT
    // =========================================================================
    if ViewportState.compare_mode == 1: WipeViewport {
        original: ViewportState.image_original;
        duplicate: ViewportState.image_duplicate;
        checkerboard: ViewportState.checkerboard_pattern;
        background-mode: ViewportState.viewer.background_mode;
        checkerboard-light: ViewportState.checkerboard_pattern_light;
        wipe-val <=> ViewportState.wipe_slider_val;
        width: ViewportState.viewer.fit_to_window ? parent.width : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
        height: ViewportState.viewer.fit_to_window ? parent.height : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
        x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
        y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
    }

    // =========================================================================
    // MODE 2: OVERLAY OPACITY BLEND VIEWPORT
    // =========================================================================
    if ViewportState.compare_mode == 2: Rectangle {
        width: 100%;
        height: 100%;
        clip: true;
        background: ViewportState.viewer.background_mode == 2 ? #000000 : (ViewportState.viewer.background_mode == 3 ? #ffffff : #111214);

        if ViewportState.viewer.background_mode == 0: Image {
            source: ViewportState.checkerboard_pattern;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        if ViewportState.viewer.background_mode == 1: Image {
            source: ViewportState.checkerboard_pattern_light;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        Image {
            source: ViewportState.image_original;
            image-fit: contain;
            width: ViewportState.viewer.fit_to_window ? parent.width : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
            height: ViewportState.viewer.fit_to_window ? parent.height : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
            x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
            y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
        }

        Image {
            source: ViewportState.image_duplicate;
            image-fit: contain;
            opacity: ViewportState.wipe_slider_val;
            width: ViewportState.viewer.fit_to_window ? parent.width : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
            height: ViewportState.viewer.fit_to_window ? parent.height : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
            x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
            y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
        }
    }

    // =========================================================================
    // MODE 3: DIFFERENCE HEATMAP DIAGNOSTIC VIEWPORT
    // =========================================================================
    if ViewportState.compare_mode == 3: Rectangle {
        width: 100%;
        height: 100%;
        clip: true;
        background: ViewportState.viewer.background_mode == 2 ? #000000 : (ViewportState.viewer.background_mode == 3 ? #ffffff : #111214);

        if ViewportState.viewer.background_mode == 0: Image {
            source: ViewportState.checkerboard_pattern;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        if ViewportState.viewer.background_mode == 1: Image {
            source: ViewportState.checkerboard_pattern_light;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        Image {
            source: ViewportState.image_heatmap;
            image-fit: contain;
            width: ViewportState.viewer.fit_to_window ? parent.width : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
            height: ViewportState.viewer.fit_to_window ? parent.height : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
            x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
            y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
        }
    }

    // =========================================================================
    // MODE 4: FLICKER COMPARISON VIEWPORT
    // =========================================================================
    if ViewportState.compare_mode == 4: Rectangle {
        width: 100%;
        height: 100%;
        clip: true;
        background: ViewportState.viewer.background_mode == 2 ? #000000 : (ViewportState.viewer.background_mode == 3 ? #ffffff : #111214);

        if ViewportState.viewer.background_mode == 0: Image {
            source: ViewportState.checkerboard_pattern;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        if ViewportState.viewer.background_mode == 1: Image {
            source: ViewportState.checkerboard_pattern_light;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        Image {
            source: ViewportState.flicker_show_duplicate ? ViewportState.image_duplicate : ViewportState.image_original;
            image-fit: contain;
            width: ViewportState.viewer.fit_to_window ? parent.width : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
            height: ViewportState.viewer.fit_to_window ? parent.height : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
            x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
            y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
        }

        if ViewportState.viewer.enable_frame_blending: Image {
            source: ViewportState.flicker_show_duplicate ? ViewportState.image_duplicate_next : ViewportState.image_original_next;
            opacity: ViewportState.blend_factor;
            image-fit: contain;
            width: ViewportState.viewer.fit_to_window ? parent.width : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
            height: ViewportState.viewer.fit_to_window ? parent.height : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
            x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
            y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
        }
    }

    // =========================================================================
    // PIXEL INSPECTOR OVERLAY HUD
    // =========================================================================
    if ViewportState.enable_inspector && ViewportState.inspection.valid: Rectangle {
        x: 12px;
        y: 12px;
        width: 220px;
        height: 125px;
        background: #18191cb0;
        border-color: #f0b132;
        border-width: 1.5px;
        border-radius: 6px;

        VerticalLayout {
            padding: 8px;
            spacing: 3px;

            HorizontalLayout {
                alignment: space-between;
                Text {
                    text: "Pixel (" + ViewportState.inspection.x + ", " + ViewportState.inspection.y + ")";
                    font-size: 11px;
                    font-weight: 700;
                    color: #ffffff;
                }

                Text {
                    text: ViewportState.inspection.hex_code;
                    font-size: 11px;
                    font-weight: 700;
                    color: #f0b132;
                }
            }

            Rectangle {
                height: 1px;
                background: #353535;
            }

            Text {
                text: "RGBA: [" + ViewportState.inspection.r_255 + ", " + ViewportState.inspection.g_255 + ", " + ViewportState.inspection.b_255 + ", " + ViewportState.inspection.a_255 + "]";
                font-size: 10px;
                color: #dcddde;
            }

            Text {
                text: "Normal: (" + ViewportState.inspection.norm_x + ", " + ViewportState.inspection.norm_y + ", " + ViewportState.inspection.norm_z + ")";
                font-size: 10px;
                color: #5865f2;
            }

            Text {
                text: "Diff ΔE: " + ViewportState.inspection.pixel_diff;
                font-size: 10px;
                color: #f23f43;
            }
        }
    }
}
