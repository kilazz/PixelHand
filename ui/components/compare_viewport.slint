// ui/components/compare_viewport.slint

import { WipeViewport } from "./common.slint";
import { ViewportState } from "../store.slint";

export component InteractiveCompareViewport inherits Rectangle {
    background: #111214;
    clip: true;

    TouchArea {
        property <length> pressed-pan-x;
        property <length> pressed-pan-y;

        // Custom mouse cursor states for dragging feedback
        mouse-cursor: self.pressed ? MouseCursor.grabbing : MouseCursor.grab;

        pointer-event(evt) => {
            if (evt.button == PointerEventButton.right && evt.kind == PointerEventKind.down) {
                // Right click resets the view to default
                ViewportState.zoom_factor = 1.0;
                ViewportState.pan_x = 0px;
                ViewportState.pan_y = 0px;
            }
            if (evt.button == PointerEventButton.left && evt.kind == PointerEventKind.down) {
                // Lock the initial pan positions when the left mouse button is pressed
                self.pressed-pan-x = ViewportState.pan_x;
                self.pressed-pan-y = ViewportState.pan_y;
            }
        }

        moved => {
            if (self.enabled && self.pressed) {
                // Calculate absolute delta from the drag origin to prevent jitter
                ViewportState.pan_x = self.pressed-pan-x + (self.mouse-x - self.pressed-x);
                ViewportState.pan_y = self.pressed-pan-y + (self.mouse-y - self.pressed-y);
            }
        }

        scroll-event(evt) => {
            let zoom_delta = (evt.delta-y / 1px) / 120.0 * 0.15;
            ViewportState.zoom_factor = (ViewportState.zoom_factor + zoom_delta).clamp(0.1, 10.0);
            if (ViewportState.zoom_factor == 1.0) {
                ViewportState.pan_x = 0px;
                ViewportState.pan_y = 0px;
            }
            EventResult.accept
        }

        double-clicked => {
            if (self.mouse-x < parent.width / 2) {
                ViewportState.open_file_in_viewer(ViewportState.original_meta.path);
            } else {
                ViewportState.open_file_in_viewer(ViewportState.duplicate_meta.path);
            }
        }
    }

    if ViewportState.compare_mode == 0: Rectangle { // Side-by-Side
        width: 100%;
        height: 100%;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width / 2 - 6px;
            height: parent.height;
            clip: true;

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: ViewportState.viewer.background_mode == 2 ? #000000 : (ViewportState.viewer.background_mode == 3 ? #ffffff : #111214);
                border-color: #3e3e42;
                border-width: 1px;
                border-radius: 4px;
                clip: true;

                if ViewportState.viewer.background_mode == 0: Image {
                    source: ViewportState.checkerboard_pattern;
                    horizontal-tiling: repeat;
                    vertical-tiling: repeat;
                    width: 100%;
                    height: 100%;
                }

                if ViewportState.viewer.background_mode == 1: Image {
                    source: ViewportState.checkerboard_pattern_light;
                    horizontal-tiling: repeat;
                    vertical-tiling: repeat;
                    width: 100%;
                    height: 100%;
                }

                Image {
                    source: ViewportState.image_original;
                    image-fit: contain;
                    width: ViewportState.viewer.fit_to_window ? (parent.width * ViewportState.zoom_factor) : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
                    height: ViewportState.viewer.fit_to_window ? (parent.height * ViewportState.zoom_factor) : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
                    x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
                    y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
                }

                // Smooth frame blending overlay (Original Image)
                if ViewportState.viewer.enable_frame_blending: Image {
                    source: ViewportState.image_original_next;
                    opacity: ViewportState.blend_factor;
                    image-fit: contain;
                    width: ViewportState.viewer.fit_to_window ? (parent.width * ViewportState.zoom_factor) : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
                    height: ViewportState.viewer.fit_to_window ? (parent.height * ViewportState.zoom_factor) : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
                    x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
                    y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
                }
            }
        }

        Rectangle {
            x: parent.width / 2 + 6px;
            y: 0px;
            width: parent.width / 2 - 6px;
            height: parent.height;
            clip: true;

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: ViewportState.viewer.background_mode == 2 ? #000000 : (ViewportState.viewer.background_mode == 3 ? #ffffff : #111214);
                border-color: #3e3e42;
                border-width: 1px;
                border-radius: 4px;
                clip: true;

                if ViewportState.viewer.background_mode == 0: Image {
                    source: ViewportState.checkerboard_pattern;
                    horizontal-tiling: repeat;
                    vertical-tiling: repeat;
                    width: 100%;
                    height: 100%;
                }

                if ViewportState.viewer.background_mode == 1: Image {
                    source: ViewportState.checkerboard_pattern_light;
                    horizontal-tiling: repeat;
                    vertical-tiling: repeat;
                    width: 100%;
                    height: 100%;
                }

                Image {
                    source: ViewportState.image_duplicate;
                    image-fit: contain;
                    width: ViewportState.viewer.fit_to_window ? (parent.width * ViewportState.zoom_factor) : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
                    height: ViewportState.viewer.fit_to_window ? (parent.height * ViewportState.zoom_factor) : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
                    x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
                    y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
                }

                // Smooth frame blending overlay (Duplicate Image)
                if ViewportState.viewer.enable_frame_blending: Image {
                    source: ViewportState.image_duplicate_next;
                    opacity: ViewportState.blend_factor;
                    image-fit: contain;
                    width: ViewportState.viewer.fit_to_window ? (parent.width * ViewportState.zoom_factor) : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
                    height: ViewportState.viewer.fit_to_window ? (parent.height * ViewportState.zoom_factor) : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
                    x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
                    y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
                }
            }
        }
    }

    if ViewportState.compare_mode == 1: WipeViewport { // Wipe Mode
        original: ViewportState.image_original;
        duplicate: ViewportState.image_duplicate;
        checkerboard: ViewportState.checkerboard_pattern;
        background-mode: ViewportState.viewer.background_mode;
        checkerboard-light: ViewportState.checkerboard_pattern_light;
        wipe-val <=> ViewportState.wipe_slider_val;
        width: ViewportState.viewer.fit_to_window ? (parent.width * ViewportState.zoom_factor) : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
        height: ViewportState.viewer.fit_to_window ? (parent.height * ViewportState.zoom_factor) : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
        x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
        y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
    }

    if ViewportState.compare_mode == 2: Rectangle { // Overlay Blend
        width: 100%;
        height: 100%;
        clip: true;
        background: ViewportState.viewer.background_mode == 2 ? #000000 : (ViewportState.viewer.background_mode == 3 ? #ffffff : #111214);

        if ViewportState.viewer.background_mode == 0: Image {
            source: ViewportState.checkerboard_pattern;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        if ViewportState.viewer.background_mode == 1: Image {
            source: ViewportState.checkerboard_pattern_light;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        Image {
            source: ViewportState.image_original;
            image-fit: contain;
            width: ViewportState.viewer.fit_to_window ? (parent.width * ViewportState.zoom_factor) : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
            height: ViewportState.viewer.fit_to_window ? (parent.height * ViewportState.zoom_factor) : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
            x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
            y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
        }

        Image {
            source: ViewportState.image_duplicate;
            image-fit: contain;
            opacity: ViewportState.wipe_slider_val;
            width: ViewportState.viewer.fit_to_window ? (parent.width * ViewportState.zoom_factor) : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
            height: ViewportState.viewer.fit_to_window ? (parent.height * ViewportState.zoom_factor) : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
            x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
            y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
        }
    }

    if ViewportState.compare_mode == 3: Rectangle { // Difference Heatmap
        width: 100%;
        height: 100%;
        clip: true;
        background: ViewportState.viewer.background_mode == 2 ? #000000 : (ViewportState.viewer.background_mode == 3 ? #ffffff : #111214);

        if ViewportState.viewer.background_mode == 0: Image {
            source: ViewportState.checkerboard_pattern;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        if ViewportState.viewer.background_mode == 1: Image {
            source: ViewportState.checkerboard_pattern_light;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        Image {
            source: ViewportState.image_heatmap;
            image-fit: contain;
            width: ViewportState.viewer.fit_to_window ? (parent.width * ViewportState.zoom_factor) : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
            height: ViewportState.viewer.fit_to_window ? (parent.height * ViewportState.zoom_factor) : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
            x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
            y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
        }
    }

    if ViewportState.compare_mode == 4: Rectangle { // Flicker Mode
        width: 100%;
        height: 100%;
        clip: true;
        background: ViewportState.viewer.background_mode == 2 ? #000000 : (ViewportState.viewer.background_mode == 3 ? #ffffff : #111214);

        if ViewportState.viewer.background_mode == 0: Image {
            source: ViewportState.checkerboard_pattern;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        if ViewportState.viewer.background_mode == 1: Image {
            source: ViewportState.checkerboard_pattern_light;
            horizontal-tiling: repeat;
            vertical-tiling: repeat;
            width: 100%;
            height: 100%;
        }

        Image {
            source: ViewportState.flicker_show_duplicate ? ViewportState.image_duplicate : ViewportState.image_original;
            image-fit: contain;
            width: ViewportState.viewer.fit_to_window ? (parent.width * ViewportState.zoom_factor) : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
            height: ViewportState.viewer.fit_to_window ? (parent.height * ViewportState.zoom_factor) : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
            x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
            y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
        }

        if ViewportState.viewer.enable_frame_blending: Image {
            source: ViewportState.flicker_show_duplicate ? ViewportState.image_duplicate_next : ViewportState.image_original_next;
            opacity: ViewportState.blend_factor;
            image-fit: contain;
            width: ViewportState.viewer.fit_to_window ? (parent.width * ViewportState.zoom_factor) : (ViewportState.sprite_width * 1px * ViewportState.zoom_factor);
            height: ViewportState.viewer.fit_to_window ? (parent.height * ViewportState.zoom_factor) : (ViewportState.sprite_height * 1px * ViewportState.zoom_factor);
            x: parent.width / 2 - self.width / 2 + ViewportState.pan_x;
            y: parent.height / 2 - self.height / 2 + ViewportState.pan_y;
        }
    }
}
