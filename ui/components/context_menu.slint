// ui/components/context_menu.slint

import { MenuItem } from "./buttons.slint";
import { ScanConfig, Diagnostics } from "../store.slint";

export component ContextMenuPopup inherits PopupWindow {
    width: 160px;
    close-policy: close-on-click;
    x: Diagnostics.menu_x;
    y: Diagnostics.menu_y;

    Rectangle {
        background: #2b2d31;
        border-color: #1f2023;
        border-width: 1px;
        border-radius: 4px;

        VerticalLayout {
            padding: 4px;
            spacing: 2px;

            MenuItem {
                text: "Open File";
                clicked => {
                    ScanConfig.context_menu_action("open", Diagnostics.context_hovered_path);
                    root.close();
                }
            }

            MenuItem {
                text: "Show in Explorer";
                clicked => {
                    ScanConfig.context_menu_action("explore", Diagnostics.context_hovered_path);
                    root.close();
                }
            }

            Rectangle {
                height: 1px;
                background: #1f2023;
            }

            MenuItem {
                text: "Move to Trash";
                text-color: #f23f43;
                clicked => {
                    ScanConfig.context_menu_action("trash", Diagnostics.context_hovered_path);
                    root.close();
                }
            }
        }
    }
}
