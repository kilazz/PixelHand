// ui/store.slint

import {
    PathSettings,
    ExtensionSettings,
    UiLayoutSettings,
    VisualReportSettings,
    PreprocessingSettings,
    QcSettings,
    AiSettings,
    TonemapSettings,
    ViewerConfig,
    PreviewSettings,
    ResultsRow,
    SelectedFile,
    GridRow,
    SearchMethod,
    ExecutionProvider,
    AiModelType,
} from "./structs.slint";

export global ScanConfig {
    // Persistent configuration structures
    in-out property <PathSettings> paths: { dir_a: "", dir_b: "", excluded_folders: ".git, .svn, cache, temp", query_text: "" };
    in-out property <ExtensionSettings> extensions: {
        ext_png: true,
        ext_jpg: true,
        ext_tga: true,
        ext_dds: true,
        ext_bmp: true,
        ext_exr: true,
        ext_hdr: true,
        ext_tif: true,
        ext_webp: true,
        ext_gif: true,
        ext_psd: true,
        ext_jxl: true,
        ext_heic: true,
        ext_avif: true,
        ext_ktx2: true,
        ext_raw: true,
        ext_svg: true,
        ext_astc: true,
        ext_qoi: true,
        ext_ico: true,
        ext_pvr: true,
        ext_atc: true,
        ext_crn: true
    };
    in-out property <UiLayoutSettings> ui: {
        duplicates_panel_height: 180px,
        sidebar_width: 380px,
        compare_sidebar_width: 440px,
        list_preview_size: 40px,
        grid_card_size: 135px
    };
    in-out property <VisualReportSettings> visuals: {
        save_visuals: false,
        visuals_columns: 6,
        visuals_max_count: 100,
        visuals_font_size: 14,
        visuals_scale: 1.5
    };
    in-out property <PreprocessingSettings> prep: {
        prep_luminance: false,
        prep_channels: false,
        prep_r: true,
        prep_g: true,
        prep_b: true,
        prep_a: true,
        prep_tags: "",
        prep_ignore_solid: true
    };
    in-out property <QcSettings> qc: {
        qc_mode: false,
        qc_npot: true,
        qc_mipmaps: true,
        qc_block_align: true,
        qc_bit_depth: true,
        qc_solid_colors: true,
        qc_normals: true,
        qc_normals_tags: "",
        qc_match_by_stem: true,
        qc_hide_same_resolution: false,
        qc_check_bloat: true,
        qc_check_alpha: true,
        qc_check_colorspace: true,
        qc_check_compression: true
    };
    in-out property <AiSettings> ai: {
        ai_model: AiModelType.clip-vit-b32,
        custom_model_path: "",
        custom_model_arch: 0,
        custom_model_dim: 512
    };
    in-out property <PreviewSettings> preview: {
        enable_previews: true,
        preview_quality: 1,
        filter_only_npot: false,
        filter_only_uncompressed: false,
        filter_only_missing_mips: false,
        filter_only_cubemaps: false
    };

    // Global scanning parameters
    in-out property <float> similarity_threshold: 90.0;
    in-out property <int> batch_size: 128;
    in-out property <SearchMethod> search_method: SearchMethod.exact;
    in-out property <ExecutionProvider> execution_provider: ExecutionProvider.cpu;
    in-out property <int> search_precision: 1;
    in-out property <bool> show_advanced: false;

    // Table Column Widths
    in-out property <length> col_file_w: 320px;
    in-out property <length> col_score_w: 80px;
    in-out property <length> col_path_w: 380px;
    in-out property <length> col_format_w: 110px;
    in-out property <length> col_dimensions_w: 110px;
    in-out property <length> col_mipmaps_w: 75px;
    in-out property <length> col_cubemap_w: 75px;
    in-out property <length> col_size_w: 85px;

    // Draggable columns for the Comparison Specifications Matrix
    in-out property <length> col_spec_name_w: 130px;
    in-out property <length> col_spec_val1_w: 140px;

    // Active Results Data
    in-out property <[ResultsRow]> results: [];
    in-out property <[GridRow]> grid_row_results: [];
    in-out property <[ResultsRow]> selected_group_files: [];
    in-out property <string> results_search_query: "";
    in-out property <float> results_min_similarity: 0.0;
    in-out property <int> results_sort_index: 0;

    // Pagination / Lazy Viewport Properties for 100,000+ files
    in-out property <int> active_page: 0;
    in-out property <int> total_pages: 1;
    in-out property <int> items_per_page: 1000;

    // View State Flags
    in-out property <bool> results_grid_mode: false;
    in-out property <bool> has_results: false;
    in-out property <string> active_sort_column: "";
    in-out property <bool> sort_ascending: true;
    in-out property <int> grid_columns: 4;

    // Callbacks
    callback select_folder_a();
    callback select_folder_b();
    callback select_custom_model();
    callback select_reference_image();
    callback trigger_action(string);
    callback row_clicked(int, bool, int, string);
    callback row_checkbox_toggled(int);
    callback trigger_selection_rule(string);
    callback expand_all_groups();
    callback collapse_all_groups();
    callback sort_by_column(string);
    callback results_filter_changed();
    callback results_sort_changed(int);
    callback clear_cache();
    callback clear_models();
    callback auto_size_columns();
    callback reset_size_columns();
    callback context_menu_action(string, string);
    callback thumbnail_channel_hovered(string, string);
    callback grid_columns_changed();
    callback save_settings();
    callback path_dropped(string);
    callback export_html();
}

export global ViewportState {
    // Viewport image and rendering buffers
    in-out property <image> image_original;
    in-out property <image> image_duplicate;
    in-out property <image> image_heatmap;
    in-out property <image> histogram_image;
    in-out property <image> checkerboard_pattern;
    in-out property <image> checkerboard_pattern_light;

    // Active configuration settings
    in-out property <TonemapSettings> tonemap: { tonemap_enabled: true, tonemap_auto_exposure: true, tonemap_operator: 2 };
    in-out property <ViewerConfig> viewer: {
        grid_cols: 1,
        grid_rows: 1,
        manual_brightness: 1.0,
        manual_contrast: 1.0,
        manual_gamma: 1.0,
        aspect_ratio_modifier: 1.0,
        background_mode: 0,
        flipbook_fps: 12.0,
        fit_to_window: true,
        play_speed: 1.0,
        enable_frame_blending: false
    };

    // Viewport interactive parameters
    in-out property <int> compare_mode: 0; // 0: Side-by-Side, 1: Wipe, 2: Overlay, 3: Difference, 4: Flicker
    in-out property <float> wipe_slider_val: 0.5;
    in-out property <float> bg_alpha: 1.0;
    in-out property <float> zoom_factor: 1.0;
    in-out property <length> pan_x: 0px;
    in-out property <length> pan_y: 0px;

    // Interactive Loupe (Magnifier) Toggle
    in-out property <bool> enable_loupe: false;

    // Viewport channel-isolation layers
    in-out property <bool> active_r: false;
    in-out property <bool> active_g: false;
    in-out property <bool> active_b: false;
    in-out property <bool> active_a: false;

    // Multi-frame Spritesheet/Flipbook runtime state
    in-out property <int> active_frame: 0;
    in-out property <int> sprites_count: 1;
    in-out property <int> sprite_width: 0;
    in-out property <int> sprite_height: 0;
    in-out property <bool> play_flipbook: false;

    // Multi-frame frame blending preview buffers
    in-out property <image> image_original_next;
    in-out property <image> image_duplicate_next;
    in-out property <float> blend_factor: 0.0;

    // Selected metadata files specifications (Compare Matrix)
    in-out property <SelectedFile> original_meta: {
        name: "-",
        size_str: "-",
        format: "-",
        resolution: "-",
        bit_depth: "-",
        color_space: "-",
        mipmaps: "-",
        alpha: "-",
        similarity: "-",
        path: ""
    };
    in-out property <SelectedFile> duplicate_meta: {
        name: "-",
        size_str: "-",
        format: "-",
        resolution: "-",
        bit_depth: "-",
        color_space: "-",
        mipmaps: "-",
        alpha: "-",
        similarity: "-",
        path: ""
    };

    // Mipmap resolution layers navigation
    in-out property <int> active_mip_level: 0;
    in-out property <int> max_available_mips: 1;

    // Interactive flicker loop state flags
    in-out property <bool> flicker_show_duplicate: false;
    in-out property <float> flicker_interval_val: 333.0;

    // Callbacks
    callback open_file_in_viewer(string);
    callback channel_toggled();
    callback mip_level_changed();
    callback compare_mode_changed();
    callback active_frame_changed();
    callback tonemap_toggled();
}

export global Diagnostics {
    // Process Tracking and Logging State
    in-out property <bool> is_scanning: false;
    in-out property <float> progress: 0.0;
    in-out property <string> status_text: "System Ready. Drop images or write path.";
    in-out property <[string]> skipped_files_list: [];
    in-out property <string> console_log: "Initializing ONNX Runtime Architecture...\nSystem ready.";

    // Active hovered/context item variables
    in-out property <string> context_hovered_path: "";

    // Coordinate alignments for popups
    in-out property <length> ext_popup_x: 0px;
    in-out property <length> ext_popup_y: 0px;
    in-out property <length> skipped_popup_x: 0px;
    in-out property <length> skipped_popup_y: 0px;
    in-out property <length> menu_x: 0px;
    in-out property <length> menu_y: 0px;

    // Shared global view tab
    in-out property <int> active_tab: 0; // 0: Find, 1: Compare, 2: Log

    // Callbacks
    callback run_scan();
    callback cancel_scan();
    callback export_log(string);
    callback export_csv();
}
