// ui/structs.slint

export struct ResultsRow {
    is_header: bool,
    is_qc: bool,
    is_ai: bool,
    group_index: int,
    hash_or_issue: string,
    path: string,
    name: string,
    score_or_detail: string,
    format_str: string,
    dimensions_str: string,
    mipmaps_str: string,
    cubemap_str: string,
    size_str: string,
    meta_str: string,
    is_best: bool,
    is_checked: bool,
    thumbnail: image,
}

export struct SelectedFile {
    name: string,
    size_str: string,
    format: string,
    resolution: string,
    bit_depth: string,
    color_space: string,
    mipmaps: string,
    alpha: string,
    similarity: string,
    path: string,
}

// Added to group results in batches of 4 on the Rust side to support native Slint ListView virtualization
export struct GridRow {
    col1: ResultsRow,
    col2: ResultsRow,
    col3: ResultsRow,
    col4: ResultsRow,
    has_col1: bool,
    has_col2: bool,
    has_col3: bool,
    has_col4: bool,
}
